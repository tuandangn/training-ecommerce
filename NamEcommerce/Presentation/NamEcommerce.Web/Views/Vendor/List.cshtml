@using System.Text.Encodings.Web
@using System.Text
@inject UrlEncoder MyUrlEncoder
@model VendorListModel
@{
    ViewData[ViewConstants.PageTitle] = "Nhà cung cấp";
    var successMessage = TempData[ViewConstants.VendorSuccessMessage] as string;
    var errorMessage = TempData[ViewConstants.VendorErrorMessage] as string;
    string? query = Model.Keywords;
}

<div class="page-header">
    <div>
        <h1 class="page-header-title">Nhà cung cấp</h1>
        <p class="page-header-subtitle">Quản lý các nhà cung cấp hàng hóa</p>
    </div>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-lg me-1"></i>Thêm mới
    </a>
</div>

@if (!string.IsNullOrEmpty(successMessage))
{
    <div class="alert alert-success alert-dismissible fade show alert-global mb-3" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i>@successMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-warning alert-dismissible fade show alert-global mb-3" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-2"></i>@errorMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="content-card">
    <div class="action-toolbar">
        <div class="search-group">
            <div class="search-input-group input-group">
                <span class="input-group-text"><i class="bi bi-search text-muted"></i></span>
                <partial name="_Search" model="@(new VendorListSearchModel { Keywords = Model.Keywords })" />
            </div>
            @if (!string.IsNullOrEmpty(query))
            {
                <a asp-action="List" class="btn btn-sm btn-outline-secondary">
                    <i class="bi bi-x"></i> Xóa lọc
                </a>
            }
        </div>
    </div>

    <div class="table-responsive">
        <table class="table data-table">
            <thead>
                <tr>
                    <th class="ps-4">Nhà cung cấp</th>
                    <th><i class="bi bi-phone me-1"></i>Điện thoại</th>
                    <th class="d-none d-md-table-cell"><i class="bi bi-map me-1"></i>Địa chỉ</th>
                    <th class="text-center" style="width: 100px;">Thứ tự</th>
                    <th style="width: 100px;"></th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Data.Pagination.TotalCount > 0)
                {
                    @foreach (var item in Model.Data)
                    {
                        <tr>
                            <td class="ps-4 fw-medium">@HighlighHelper.Highlight(item.Name, query)</td>
                            <td>
                                <a href="tel:@item.PhoneNumber" class="text-decoration-none text-muted">
                                    <i class="bi bi-telephone me-1"></i>
                                    @HighlighHelper.Highlight(item.PhoneNumber, query)
                                </a>
                            </td>
                            <td class="d-none d-md-table-cell">
                                @if (!string.IsNullOrEmpty(item.Address))
                                {
                                    var encodedAddress = MyUrlEncoder.Encode(item.Address);
                                    <a href="https://www.google.com/maps/search/@encodedAddress" target="_blank"
                                       class="text-decoration-none text-muted small">
                                        <i class="bi bi-geo-alt me-1"></i>
                                        @HighlighHelper.Highlight(item.Address, query)
                                    </a>
                                }
                            </td>
                            <td class="text-center text-muted">@item.DisplayOrder</td>
                            <td class="text-end pe-3">
                                <a class="btn-table-action me-1" asp-action="Edit" asp-route-id="@item.Id" title="Chỉnh sửa">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <button type="button" class="btn-table-action danger btnDelete"
                                        data-id="@item.Id" data-name="@item.Name" title="Xóa">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="5">
                            <div class="empty-state">
                                <div class="empty-icon"><i class="bi bi-building"></i></div>
                                <h5>Chưa có nhà cung cấp nào</h5>
                                <p>Thêm nhà cung cấp để bắt đầu quản lý đơn nhập hàng.</p>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (Model.Data.Pagination.TotalCount > 0)
    {
        <partial name="_Pager" model="Model.Data.Pagination" />
    }
</div>

@foreach (var item in Model.Data)
{
    <partial name="_DeleteForm" model="@item.Id" />
}

@section Scripts {
    <script type="module" defer>
        import { confirm } from "/modules/modals.js";
        (function () {
            $('.btnDelete').on('click', async function (e) {
                e.preventDefault();
                const name = $(this).data('name');
                $(this).prop('disabled', true);
                const confirmed = await confirm('Xóa nhà cung cấp', `Bạn muốn xóa nhà cung cấp <strong>${name}</strong>?`);
                if (!confirmed) { $(this).prop('disabled', false); return; }
                $(`#deleteForm${$(this).data('id')}`).submit();
            });
        })();
    </script>
}
