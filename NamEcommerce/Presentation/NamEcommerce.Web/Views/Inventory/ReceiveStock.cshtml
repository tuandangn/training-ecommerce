@model ReceiveStockModel
@{
    ViewData[ViewConstants.PageTitle] = "Nhập kho";
}
<section class="content-title my-4 text-center">
    <h1>Nhập kho</h1>
</section>
<section class="content-data p-4 mb-5 shadow">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <form asp-action="ReceiveStock" method="post">
                <input type="hidden" asp-for="ProductId" />
                <input type="hidden" asp-for="WarehouseId" />

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="mb-3">
                    <label asp-for="Quantity" class="form-label fw-bold"></label>
                    <input asp-for="Quantity" class="form-control" type="number" step="any" min="0.000000001" placeholder="Nhập số lượng" />
                    <span asp-validation-for="Quantity" class="text-danger"></span>
                    <div class="form-text">Số lượng sản phẩm nhập vào kho</div>
                </div>

                <div class="mb-3">
                    <label asp-for="ReferenceType" class="form-label fw-bold">Loại tham chiếu</label>
                    <select asp-for="ReferenceType" class="form-control">
                        <option value="0">Đơn mua hàng</option>
                        <option value="1">Điều chỉnh kho</option>
                        <option value="2">Nhập lại từ bán hàng</option>
                        <option value="3">Khác</option>
                    </select>
                    <span asp-validation-for="ReferenceType" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="ReferenceId" class="form-label fw-bold">Mã tham chiếu (tuỳ chọn)</label>
                    <input asp-for="ReferenceId" class="form-control" placeholder="VD: Mã đơn mua hàng" />
                    <span asp-validation-for="ReferenceId" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Note" class="form-label fw-bold">Ghi chú (tuỳ chọn)</label>
                    <textarea asp-for="Note" class="form-control" rows="3" placeholder="Nhập ghi chú"></textarea>
                    <span asp-validation-for="Note" class="text-danger"></span>
                </div>

                <div class="text-end">
                    <a asp-action="StockList" class="btn btn-secondary me-2">Hủy bỏ</a>
                    <button type="submit" class="btn btn-primary">Nhập kho</button>
                </div>
            </form>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
