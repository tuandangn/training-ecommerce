@model NamEcommerce.Web.Contracts.Models.Inventory.InventoryStockListModel
@{
    ViewData[ViewConstants.PageTitle] = "Tồn kho";
    var successMessage = TempData[ViewConstants.VendorSuccessMessage] as string;

    string? query = Context.Request.Query[Html.NameFor(m => m.Keywords)];
}
<section class="content-title my-4 text-center">
    <h1>Tồn kho</h1>
</section>
<section class="content-data p-4 mb-5 shadow">
    <div class="mb-2 d-flex align-items-start">
        <div class="d-flex flex-wrap align-items-center mb-2">
            <!-- Simple Search -->
            <form method="get" asp-action="StockList" class="d-flex me-2">
                <input type="text" name="Keywords" class="form-control form-control-sm me-2" placeholder="Tìm tên sản phẩm..." value="@Model.Keywords" />
                <button type="submit" class="btn btn-sm btn-primary">Tìm</button>
            </form>
            @if (!string.IsNullOrEmpty(query))
            {
                <a asp-action="StockList" class="btn btn-sm btn-link text-decoration-none text-muted">
                    <i class="bi bi-x"></i>
                    Xóa tìm kiếm
                </a>
            }
        </div>
    </div>
    @if (!string.IsNullOrEmpty(successMessage))
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @successMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead>
                <tr>
                    <th class="ps-3">Sản phẩm</th>
                    <th>Kho</th>
                    <th class="text-end">Đang tồn</th>
                    <th class="text-end">Chờ giao</th>
                    <th class="text-end">Còn lại</th>
                    <th class="text-center">Cập nhật lúc</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Data.Pagination.TotalCount > 0)
                {
                    @foreach (var item in Model.Data)
                    {
                        <tr>
                            <td class="ps-3 fw-bold">
                                @item.ProductName
                            </td>
                            <td>
                                @item.WarehouseName
                            </td>
                            <td class="text-end">
                                @item.QuantityOnHand.ToString(ViewConstants.NumberCustomFormat)
                            </td>
                            <td class="text-end text-danger">
                                @item.QuantityReserved.ToString(ViewConstants.NumberCustomFormat)
                            </td>
                            <td class="text-end @(item.QuantityAvailable < 5 ? "text-danger" : "text-success") fw-bold">
                                @item.QuantityAvailable.ToString(ViewConstants.NumberCustomFormat)
                                @if (item.QuantityAvailable < 5)
                                {
                                    <i class="bi bi-exclamation-triangle-fill ms-1" title="Sắp hết hàng!"></i>
                                }
                            </td>
                            <td class="text-muted text-center">
                                @item.UpdatedOnUtc.ToLocalTime().ToString("g")
                            </td>
                            <td class="text-end pe-3">
                                <div class="btn-group" role="group">
                                    <a class="btn btn-sm btn-outline-info" asp-action="MovementLogs" asp-route-productId="@item.ProductId" asp-route-warehouseId="@item.WarehouseId">
                                        <i class="bi bi-clock-history"></i> Lịch sử
                                    </a>
                                    <a class="btn btn-sm btn-primary" asp-action="AdjustStock" asp-route-productId="@item.ProductId" asp-route-warehouseId="@item.WarehouseId">
                                        Điều chỉnh
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="7">
                            <p class="my-2 ps-2 text-center">
                                <span class="text-muted">Chưa có dữ liệu tồn kho</span>
                            </p>
                        </td>
                    </tr>
                }
            </tbody>
            @if (Model.Data.Pagination.TotalCount > 0)
            {
                <tfoot>
                    <tr>
                        <td colspan="7" class="ps-0">
                            <partial name="_Pager" model="Model.Data.Pagination" />
                        </td>
                    </tr>
                </tfoot>
            }
        </table>
    </div>
</section>
