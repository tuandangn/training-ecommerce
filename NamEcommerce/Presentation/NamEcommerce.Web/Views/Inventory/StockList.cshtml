@model NamEcommerce.Web.Contracts.Models.Inventory.InventoryStockListModel
@{
    ViewData["Title"] = "Tồn kho";
    var query = Model.Keywords;
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-1 fw-bold">Quản lý Tồn kho</h1>
            <p class="text-muted small mb-0">Theo dõi và cân đối hàng hóa trên toàn hệ thống</p>
        </div>
        <div class="d-flex gap-2">
            <button type="button" class="btn btn-outline-primary rounded-3 px-4 shadow-sm" onclick="window.location.reload()">
                <i class="bi bi-arrow-clockwise me-1"></i> Làm mới
            </button>
        </div>
    </div>

    <!-- Search & Filters -->
    <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-body p-4">
            <form method="get" asp-action="StockList" class="row g-3">
                <div class="col-md-9">
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0"><i class="bi bi-search text-muted"></i></span>
                        <input type="text" name="Keywords" class="form-control border-start-0 ps-0" 
                               placeholder="Tìm theo tên sản phẩm hoặc mã..." value="@query">
                    </div>
                </div>
                <div class="col-md-3">
                    <button type="submit" class="btn btn-dark w-100 rounded-3">Tìm kiếm</button>
                </div>
            </form>
        </div>
    </div>

    @if (Model.Data.Pagination.TotalCount > 0)
    {
        <div class="row g-4">
            @foreach (var item in Model.Data)
            {
                var stockHealth = item.QuantityAvailable < 5 ? "danger" : (item.QuantityAvailable < 20 ? "warning" : "success");
                var availablePercent = item.QuantityOnHand > 0 ? (item.QuantityAvailable / item.QuantityOnHand * 100) : 0;

                <div class="col-md-6 col-lg-4">
                    <div class="card border-0 shadow-sm rounded-4 h-100 hover-shadow transition">
                        <div class="card-header bg-white border-0 pt-4 px-4 pb-0">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <span class="badge bg-light text-muted rounded-pill px-2">
                                    <i class="bi bi-geo-alt me-1"></i> @item.WarehouseName
                                </span>
                                @if (item.QuantityAvailable < 5)
                                {
                                    <span class="badge bg-danger rounded-pill px-2">
                                        <i class="bi bi-exclamation-triangle me-1"></i> Sắp hết hàng
                                    </span>
                                }
                            </div>
                            <h5 class="fw-bold mb-3 text-dark line-clamp-2" style="min-height: 3rem;">@item.ProductName</h5>
                        </div>
                        
                        <div class="card-body px-4 pt-0">
                            <div class="row g-0 mb-4 bg-light rounded-4 p-3 border border-light">
                                <div class="col-4 border-end border-white text-center">
                                    <div class="small text-muted mb-1">Thực tế</div>
                                    <div class="fw-bold fs-5">@item.QuantityOnHand.ToString("N1")</div>
                                </div>
                                <div class="col-4 border-end border-white text-center">
                                    <div class="small text-muted mb-1">Chờ giao</div>
                                    <div class="fw-bold fs-5 text-warning">@item.QuantityReserved.ToString("N1")</div>
                                </div>
                                <div class="col-4 text-center">
                                    <div class="small text-muted mb-1">Sẵn có</div>
                                    <div class="fw-bold fs-5 text-@stockHealth">@item.QuantityAvailable.ToString("N1")</div>
                                </div>
                            </div>

                            <div class="mb-4">
                                <div class="d-flex justify-content-between small mb-1">
                                    <span class="text-muted">Độ khả dụng</span>
                                    <span class="fw-bold text-@stockHealth">@availablePercent.ToString("N0")%</span>
                                </div>
                                <div class="progress rounded-pill" style="height: 8px;">
                                    <div class="progress-bar bg-@stockHealth" role="progressbar" style="width: @availablePercent%"></div>
                                </div>
                            </div>
                        </div>

                        <div class="card-footer bg-white border-0 px-4 pb-4 pt-0">
                            <div class="d-flex justify-content-between align-items-center">
                                <div class="text-muted small">
                                    <i class="bi bi-clock me-1"></i> @item.UpdatedOnUtc.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
                                </div>
                                <div class="btn-group shadow-sm rounded-pill overflow-hidden">
                                    <a class="btn btn-outline-dark btn-sm border-0 px-3" asp-action="MovementLogs" asp-route-productId="@item.ProductId" asp-route-warehouseId="@item.WarehouseId" title="Lịch sử">
                                        <i class="bi bi-clock-history"></i>
                                    </a>
                                    <a class="btn btn-primary btn-sm border-0 px-3" asp-action="AdjustStock" asp-route-productId="@item.ProductId" asp-route-warehouseId="@item.WarehouseId">
                                        Cân bằng <i class="bi bi-sliders ms-1"></i>
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

        <div class="mt-5 d-flex justify-content-center">
            <partial name="_Pager" model="Model.Data.Pagination" />
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <div class="mb-3">
                <i class="bi bi-box-seam text-muted display-1 opacity-25"></i>
            </div>
            <h4 class="text-muted">Kho hàng đang trống</h4>
            <p class="text-muted small">Chưa có sản phẩm nào được nhập kho.</p>
        </div>
    }
</div>

<style>
    .hover-shadow:hover { 
        transform: translateY(-5px);
        box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.15) !important;
    }
    .transition { transition: all 0.3s ease; }
    .line-clamp-2 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;  
        overflow: hidden;
    }
    .bg-danger { background-color: #dc3545 !important; }
    .bg-warning { background-color: #ffc107 !important; }
    .bg-success { background-color: #198754 !important; }
</style>
