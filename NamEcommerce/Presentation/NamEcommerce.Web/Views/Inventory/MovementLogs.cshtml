@model NamEcommerce.Web.Contracts.Models.Inventory.StockMovementLogListModel
@{
    ViewData[ViewConstants.PageTitle] = "Lịch sử biến động kho";
}
<section class="content-title my-4 text-center">
    <h1>
        Lịch sử thay đổi
        <span class="text-muted d-block fs-3 ps-2">
            @Model.Data.FirstOrDefault()?.ProductName
        </span>
    </h1>
</section>

<section class="content-data p-4 mb-5 shadow">
    <div class="mb-3">
        <a asp-action="StockList" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Quay lại
        </a>
    </div>

    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead>
                <tr>
                    <th>Ngày thay đổi</th>
                    <th>Loại thẻ</th>
                    <th class="text-end">Tồn trước đó</th>
                    <th class="text-end">Lượng thay đổi</th>
                    <th class="text-end">Tồn sau cùng</th>
                    <th>Ghi chú</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Data.Pagination.TotalCount > 0)
                {
                    @foreach (var item in Model.Data)
                    {
                        var isPositive = item.Quantity > 0;
                        var sign = isPositive ? "+" : "";
                        var colorClass = isPositive ? "text-success" : (item.Quantity < 0 ? "text-danger" : "text-muted");

                        <tr>
                            <td>@item.CreatedOnUtc.ToLocalTime().ToString("g")</td>
                            <td>
                                @switch (item.MovementType)
                                {
                                    case 10:
                                        <span class="badge bg-success">Nhập kho</span>
                                        break;
                                    case 20:

                                        <span class="badge bg-warning text-dark">Xuất kho</span>
                                        break;
                                    case 30:

                                        <span class="badge bg-info text-dark">Kiểm kê / Điều chỉnh</span>
                                        break;
                                    default:

                                        <span class="badge bg-secondary">Khác</span>
                                        break;
                                }
                            </td>
                            <td class="text-end">@item.QuantityBefore.ToString(ViewConstants.NumberCustomFormat)</td>
                            <td class="text-end fw-bold @colorClass">@sign@item.Quantity.ToString(ViewConstants.NumberCustomFormat)</td>
                            <td class="text-end fw-bold">@item.QuantityAfter.ToString(ViewConstants.NumberCustomFormat)</td>
                            <td class="text-muted"><small>@item.Note</small></td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6" class="text-center text-muted py-4">
                            Không có dữ liệu thay đổi nào.
                        </td>
                    </tr>
                }
            </tbody>
            @if (Model.Data.Pagination.TotalCount > 0)
            {
                <tfoot>
                    <tr>
                        <td colspan="6" class="ps-0">
                            <!-- Preserve Query parameters via route values for pager -->
                            <partial name="_Pager" model="Model.Data.Pagination" />
                        </td>
                    </tr>
                </tfoot>
            }
        </table>
    </div>
</section>
