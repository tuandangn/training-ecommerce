@model NamEcommerce.Web.Models.Inventory.AdjustStockModel
@{
    ViewData[ViewConstants.PageTitle] = "Điều chỉnh tồn kho";
}
<section class="content-title my-4 text-center">
    <h1>Điều chỉnh tồn kho</h1>
</section>
<section class="content-data p-4 mb-5 shadow">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <form asp-action="AdjustStock" method="post">
                <input type="hidden" asp-for="ProductId" />
                <input type="hidden" asp-for="WarehouseId" />

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="mb-3">
                    <label asp-for="NewQuantity" class="form-label fw-bold"></label>
                    <input asp-for="NewQuantity" class="form-control" type="number" step="0.01" />
                    <span asp-validation-for="NewQuantity" class="text-danger"></span>
                    <div class="form-text">Nhập số lượng tồn kho mới thực tế (thay thế số lượng hiện tại)</div>
                </div>

                <div class="mb-3">
                    <label asp-for="Note" class="form-label fw-bold"></label>
                    <textarea asp-for="Note" class="form-control" rows="3"></textarea>
                    <span asp-validation-for="Note" class="text-danger"></span>
                </div>

                <div class="text-end">
                    <a asp-action="StockList" class="btn btn-secondary me-2">Hủy bỏ</a>
                    <button type="submit" class="btn btn-primary">Lưu thay đổi</button>
                </div>
            </form>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
