@model GoodsReceiptDetailsModel
@{
    ViewData[ViewConstants.PageTitle] = $"Phiếu nhập - {Model.CreatedOn.ToString(ViewConstants.DefaultDateFormat)}";
    var totalValue = Model.IsPendingCosting ? (decimal?)null : Model.Items.Sum(i => i.Quantity * (i.UnitCost ?? 0));
}
@section TitleSection {
    <h1 class="topbar-page-title">
        Phiếu nhập hàng
        <span class="text-muted fw-normal">@Model.CreatedOn.ToString(ViewConstants.DefaultDateFormat)</span>
    </h1>
    <div class="topbar-page-subtitle">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a asp-action="Index" asp-controller="Home" class="text-decoration-none">Trang chủ</a></li>
                <li class="breadcrumb-item"><a asp-action="List" asp-controller="GoodsReceipt" class="text-decoration-none">Phiếu nhập hàng</a></li>
                <li class="breadcrumb-item active" aria-current="page">Chi tiết</li>
            </ol>
        </nav>
    </div>
}

<div class="row g-3">
    <div class="col-lg-8 order-1 order-lg-0">
        <div class="content-card">
            <div class="content-card-header">
                <h5 class="mb-0">
                    Danh sách hàng hóa
                    <span class="badge bg-light text-muted border ms-1" style="font-size:.72rem;font-weight:500;">
                        @Model.Items.Count mặt hàng
                    </span>
                </h5>
                @if (Model.IsPendingCosting)
                {
                    <span class="badge bg-warning text-dark">
                        <i class="bi bi-hourglass-split me-1"></i>Chờ định giá
                    </span>
                }
                else
                {
                    <span class="badge bg-success">
                        <i class="bi bi-check-circle me-1"></i>Đã định giá
                    </span>
                }
            </div>
            <div class="content-card-body-flush">
                <table class="table data-table mb-0">
                    <thead>
                        <tr>
                            <th class="ps-4">Sản phẩm</th>
                            <th style="width:130px">Kho</th>
                            <th class="text-end" style="width:100px">SL nhập</th>
                            <th class="text-end pe-4" style="width:160px">Đơn giá nhập</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Items)
                        {
                            <tr class="align-middle" data-item-id="@item.Id">
                                <td class="ps-4">
                                    <a href="@Url.Action("StockList", "Inventory", new { keywords = item.ProductName })"
                                       class="fw-medium text-body text-decoration-none details-product-link">
                                        @item.ProductName
                                    </a>
                                </td>
                                <td class="text-muted small">
                                    @if (!string.IsNullOrEmpty(item.WarehouseName))
                                    {
                                        <i class="bi bi-building me-1"></i>@item.WarehouseName
                                    }
                                    else
                                    {
                                        <span class="fst-italic">—</span>
                                    }
                                </td>
                                <td class="text-end fw-medium">
                                    @item.Quantity.DisplayQuantity()
                                </td>
                                <td class="text-end pe-4">
                                    @if (item.IsPendingCosting)
                                    {
                                        <button type="button"
                                                class="btn btn-sm btn-outline-warning btnSetUnitCost"
                                                data-item-id="@item.Id"
                                                data-product-name="@item.ProductName">
                                            <i class="bi bi-pencil-square me-1"></i>Định giá
                                        </button>
                                    }
                                    else
                                    {
                                        <div class="fw-semibold">@item.UnitCost!.Value.DisplayCurrency()</div>
                                        <div class="text-muted" style="font-size:.75rem;">
                                            = @((item.Quantity * item.UnitCost.Value).DisplayCurrency())
                                        </div>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                    @if (totalValue.HasValue)
                    {
                        <tfoot>
                            <tr class="table-light">
                                <td colspan="3" class="ps-4 text-end text-muted small fw-medium pe-3">Tổng giá trị phiếu</td>
                                <td class="text-end pe-4 fw-bold text-dark">@totalValue.Value.DisplayCurrency()</td>
                            </tr>
                        </tfoot>
                    }
                </table>
            </div>
            <div class="content-card-footer py-2 d-flex align-items-center justify-content-between">
                <a asp-action="List" class="btn btn-link text-decoration-none text-muted">
                    <i class="bi bi-arrow-left me-1"></i>Trở về
                </a>
                <form method="post" asp-action="Delete" asp-route-id="@Model.Id"
                      onsubmit="return confirm('Bạn có chắc muốn xóa phiếu nhập này?')">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-sm btn-outline-danger">
                        <i class="bi bi-trash me-1"></i>Xóa phiếu
                    </button>
                </form>
            </div>
        </div>
    </div>
    <div class="col-lg-4 order-0 order-lg-1">

        <!-- Thông tin phiếu -->
        <div class="content-card mb-3">
            <div class="content-card-header">
                <h5 class="mb-0">Thông tin phiếu</h5>
                <button type="button" class="btn btn-sm btn-light" data-bs-toggle="modal" data-bs-target="#editInfoModal">
                    <i class="bi bi-pencil me-1"></i>Sửa
                </button>
            </div>
            <div class="content-card-body p-0">
                <dl class="receipt-info-list mb-0">
                    <div class="receipt-info-row">
                        <dt>Ngày nhập</dt>
                        <dd class="fw-semibold">@Model.CreatedOn.ToString(ViewConstants.DefaultDateTimeFormat)</dd>
                    </div>
                    <div class="receipt-info-row">
                        <dt>Tài xế</dt>
                        <dd>
                            @if (!string.IsNullOrEmpty(Model.TruckDriverName))
                            {
                                @Model.TruckDriverName
                            }
                            else { <span class="text-muted fst-italic">—</span> }
                        </dd>
                    </div>
                    <div class="receipt-info-row">
                        <dt>Biển số</dt>
                        <dd>
                            @if (!string.IsNullOrEmpty(Model.TruckNumberSerial))
                            {
                                <i class="bi bi-truck me-1 text-muted"></i>@Model.TruckNumberSerial
                            }
                            else { <span class="text-muted fst-italic">—</span> }
                        </dd>
                    </div>
                    @if (!string.IsNullOrEmpty(Model.Note))
                    {
                        <div class="receipt-info-row">
                            <dt>Ghi chú</dt>
                            <dd class="text-secondary">@Model.Note</dd>
                        </div>
                    }
                </dl>
            </div>
        </div>

        <!-- Nhà cung cấp -->
        <div class="content-card mb-3">
            <div class="content-card-header">
                <h5 class="mb-0">Nhà cung cấp</h5>
                <button type="button" class="btn btn-sm btn-light" id="btnEditVendor"
                        data-bs-toggle="modal" data-bs-target="#editVendorModal">
                    <i class="bi bi-pencil me-1"></i>@(Model.VendorId.HasValue ? "Thay đổi" : "Gắn NCC")
                </button>
            </div>
            <div class="content-card-body p-0">
                @if (Model.VendorId.HasValue)
                {
                    <dl class="receipt-info-list mb-0">
                        <div class="receipt-info-row">
                            <dt>Tên NCC</dt>
                            <dd class="fw-semibold">
                                <i class="bi bi-building-fill me-1 text-primary"></i>@Model.VendorName
                            </dd>
                        </div>
                        @if (!string.IsNullOrEmpty(Model.VendorPhone))
                        {
                            <div class="receipt-info-row">
                                <dt>SĐT</dt>
                                <dd>
                                    <i class="bi bi-telephone me-1 text-muted"></i>@Model.VendorPhone
                                </dd>
                            </div>
                        }
                        @if (!string.IsNullOrEmpty(Model.VendorAddress))
                        {
                            <div class="receipt-info-row">
                                <dt>Địa chỉ</dt>
                                <dd class="text-secondary">
                                    <i class="bi bi-geo-alt me-1"></i>@Model.VendorAddress
                                </dd>
                            </div>
                        }
                        @if (Model.HasVendorDebt && Model.VendorDebtId.HasValue)
                        {
                            <div class="receipt-info-row">
                                <dt>Công nợ</dt>
                                <dd>
                                    @* Trang VendorDebt/Details liệt kê toàn bộ công nợ của 1 NCC theo vendorId.
                                       Phiếu nợ cụ thể từ phiếu nhập này nằm trong list đó. *@
                                    <a asp-controller="VendorDebt" asp-action="Details" asp-route-vendorId="@Model.VendorId"
                                       class="badge bg-success-subtle text-success border border-success-subtle text-decoration-none">
                                        <i class="bi bi-check-circle-fill me-1"></i>
                                        Đã ghi nợ @(Model.VendorDebtTotalAmount?.DisplayCurrency() ?? "")
                                    </a>
                                </dd>
                            </div>
                        }
                        else if (Model.IsPendingCosting)
                        {
                            <div class="receipt-info-row">
                                <dt>Công nợ</dt>
                                <dd>
                                    <span class="badge bg-warning-subtle text-warning border border-warning-subtle">
                                        <i class="bi bi-hourglass-split me-1"></i>
                                        Sẽ ghi sau khi định giá xong
                                    </span>
                                </dd>
                            </div>
                        }
                    </dl>
                }
                else
                {
                    <div class="px-3 py-3 text-center text-muted small fst-italic">
                        — Chưa có nhà cung cấp
                    </div>
                }
            </div>
        </div>

        <!-- Phiếu đặt hàng -->
        <div class="content-card mb-3" id="poLinkCard">
            <div class="content-card-header">
                <h5 class="mb-0">Phiếu đặt hàng</h5>
                @if (!Model.PurchaseOrderId.HasValue)
                {
                    <div class="d-flex gap-2">
                        <button type="button" class="btn btn-sm btn-light" id="btnSearchPoByCode">
                            <i class="bi bi-search me-1"></i>Tìm theo mã
                        </button>
                        <button type="button" class="btn btn-sm btn-outline-primary" id="btnQuickCreatePo"
                                data-bs-toggle="modal" data-bs-target="#quickCreatePoModal">
                            <i class="bi bi-plus-lg me-1"></i>Tạo mới PO
                        </button>
                    </div>
                }
            </div>
            <div class="content-card-body p-0">
                @if (Model.PurchaseOrderId.HasValue)
                {
                    <!-- Đã link — hiển thị badge tĩnh -->
                    <div class="px-3 py-3">
                        <a asp-controller="PurchaseOrder" asp-action="Details" asp-route-id="@Model.PurchaseOrderId"
                           class="badge bg-success-subtle text-success border border-success-subtle text-decoration-none fs-6 px-3 py-2">
                            <i class="bi bi-link-45deg me-1"></i>@Model.PurchaseOrderCode
                        </a>
                    </div>
                }
                else
                {
                    <!-- Chưa link — render danh sách gợi ý qua JS -->
                    <div id="poSuggestionsPanel" data-receipt-id="@Model.Id">
                        <div id="poSuggestionsLoading" class="px-3 py-3 text-center text-muted small">
                            <span class="spinner-border spinner-border-sm me-1"></span>Đang tìm phiếu phù hợp...
                        </div>
                        <div id="poSuggestionsList" class="d-none"></div>
                        <div id="poSuggestionsEmpty" class="d-none px-3 py-3 text-center text-muted small fst-italic">
                            — Không tìm thấy phiếu đặt hàng phù hợp
                        </div>
                        <div id="poSuggestionsError" class="d-none px-3 py-2 text-danger small"></div>
                    </div>
                }
            </div>
        </div>

        <!-- Ảnh chụp -->
        <div class="content-card">
            <div class="content-card-header">
                <h5 class="mb-0">Ảnh chụp</h5>
            </div>
            <div class="content-card-body">
                <div class="d-flex align-items-center">
                    <div id="inlinePictureList" class="d-flex flex-wrap"></div>
                    <div id="inlinePicturePicker" class="d-flex flex-wrap gap-2"></div>
                </div>
                <div id="inlinePictureSaving" class="d-none mt-2">
                    <span class="spinner-border spinner-border-sm text-secondary me-1"></span>
                    <span class="text-muted small">Đang lưu...</span>
                </div>
                <div id="inlinePictureError" class="text-danger small mt-1 d-none"></div>
                <div id="inlinePictureData" data-receipt-id="@Model.Id"
                     data-picture-ids="@string.Join(",", Model.PictureIds)"></div>
            </div>
        </div>

    </div>
</div>

<!-- ── Modal: Tìm PO theo mã ── -->
<div class="modal fade" id="searchPoByCodeModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content border-0 shadow rounded-4">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold">Tìm theo mã phiếu</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body py-3">
                <label class="form-label small fw-medium text-muted" for="poCodeInput">Mã phiếu đặt hàng</label>
                <input type="text" id="poCodeInput" class="form-control" placeholder="VD: PO-2024-001" autocomplete="off" />
                <div id="searchPoByCodeError" class="alert alert-danger d-none mt-2 py-2 mb-0 small"></div>
            </div>
            <div class="modal-footer border-0 pt-0 pb-3">
                <button type="button" class="btn btn-light" data-bs-dismiss="modal">Hủy</button>
                <button type="button" id="btnConfirmPoByCode" class="btn btn-primary">
                    <i class="bi bi-check-lg me-1"></i>Xác nhận
                </button>
            </div>
        </div>
    </div>
</div>

<!-- ── Modal: Tạo nhanh PO từ GoodsReceipt ── -->
<div class="modal fade" id="quickCreatePoModal" data-receipt-id="@Model.Id" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content border-0 shadow rounded-4">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold"><i class="bi bi-file-earmark-plus me-2 text-primary"></i>Tạo phiếu đặt hàng từ phiếu nhập</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body py-3">
                <p class="text-muted small mb-3">
                    Hệ thống sẽ tạo một PO mới với các mặt hàng bên dưới, sau đó tự động gắn vào phiếu nhập này.
                </p>

                <!-- Vendor picker -->
                <div class="mb-3">
                    <label class="form-label small fw-medium text-muted">Nhà cung cấp <span class="text-danger">*</span></label>
                    <div id="quickPoVendorPicker"></div>
                    <input type="hidden" id="quickPoSelectedVendorId" />
                    <div id="quickPoVendorError" class="invalid-feedback d-none">Vui lòng chọn nhà cung cấp.</div>
                </div>

                <!-- Ngày đặt hàng -->
                <div class="mb-3">
                    <label class="form-label small fw-medium text-muted" for="quickPoPlacedOn">Ngày đặt hàng <span class="text-danger">*</span></label>
                    <input type="datetime-local" id="quickPoPlacedOn" class="form-control"
                           value="@Model.CreatedOn.ToString("s")" required />
                </div>

                <!-- Ghi chú -->
                <div class="mb-3">
                    <label class="form-label small fw-medium text-muted" for="quickPoNote">Ghi chú</label>
                    <textarea id="quickPoNote" class="form-control" rows="2"
                              placeholder="Ghi chú cho phiếu đặt hàng..." maxlength="2000"></textarea>
                </div>

                <!-- Items preview -->
                <div>
                    <label class="form-label small fw-medium text-muted mb-1">Hàng hóa sẽ được đưa vào PO</label>
                    <div class="table-responsive rounded-3 border">
                        <table class="table table-sm mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th class="ps-3">Sản phẩm</th>
                                    <th class="text-end" style="width:100px">Số lượng</th>
                                    <th class="text-end pe-3" style="width:140px">Đơn giá nhập</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.Items)
                                {
                                    <tr>
                                        <td class="ps-3 text-truncate" style="max-width:220px">@item.ProductName</td>
                                        <td class="text-end">@item.Quantity.DisplayQuantity()</td>
                                        <td class="text-end pe-3">
                                            @if (item.UnitCost.HasValue)
                                            {
                                                <span>@item.UnitCost.Value.DisplayCurrency()</span>
                                            }
                                            else
                                            {
                                                <span class="text-warning small"><i class="bi bi-hourglass-split me-1"></i>Chưa định giá</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>

                <div id="quickPoError" class="alert alert-danger d-none mt-3 py-2 mb-0"></div>
            </div>
            <div class="modal-footer border-0 pt-0 pb-3">
                <button type="button" class="btn btn-light" data-bs-dismiss="modal">Hủy</button>
                <button type="button" id="btnConfirmQuickCreatePo" class="btn btn-primary">
                    <span class="spinner-border spinner-border-sm d-none me-1" id="quickPoSpinner"></span>
                    <i class="bi bi-check-lg me-1" id="quickPoIcon"></i>Tạo & Gắn PO
                </button>
            </div>
        </div>
    </div>
</div>

<!-- ── Modal: Sửa thông tin ── -->
<div class="modal fade" id="editInfoModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow rounded-4">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold">Cập nhật thông tin</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body py-3">
                <form id="editInfoForm">
                    <input type="hidden" name="Id" value="@Model.Id" />
                    <div class="mb-3">
                        <label class="form-label small fw-medium text-muted" for="editCreatedOn">Ngày nhập hàng</label>
                        <input type="datetime-local" id="editCreatedOn" name="CreatedOn"
                               value="@Model.CreatedOn.ToString("s")" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-medium text-muted" for="editTruckDriverName">Tên tài xế</label>
                        <input id="editTruckDriverName" name="TruckDriverName" class="form-control"
                               value="@Model.TruckDriverName" placeholder="Nhập tên tài xế" maxlength="500" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-medium text-muted" for="editTruckNumberSerial">Biển số xe</label>
                        <input id="editTruckNumberSerial" name="TruckNumberSerial" class="form-control"
                               value="@Model.TruckNumberSerial" placeholder="Nhập biển số xe" maxlength="100" />
                    </div>
                    <div class="mb-0">
                        <label class="form-label small fw-medium text-muted" for="editNote">Ghi chú</label>
                        <textarea id="editNote" name="Note" class="form-control" rows="2"
                                  placeholder="Ghi chú..." maxlength="2000">@Model.Note</textarea>
                    </div>
                </form>
                <div id="editInfoError" class="alert alert-danger d-none mt-3 py-2 mb-0"></div>
            </div>
            <div class="modal-footer border-0 pt-0 pb-3">
                <button type="button" class="btn btn-light" data-bs-dismiss="modal">Hủy</button>
                <button type="button" id="btnSaveInfo" class="btn btn-primary">
                    <i class="bi bi-check-lg me-1"></i>Lưu thay đổi
                </button>
            </div>
        </div>
    </div>
</div>

<!-- ── Modal: Gắn / đổi nhà cung cấp ── -->
<div class="modal fade" id="editVendorModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow rounded-4">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold">@(Model.VendorId.HasValue ? "Thay đổi nhà cung cấp" : "Gắn nhà cung cấp")</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body py-3">
                <p class="text-muted small mb-2">
                    Tìm theo tên hoặc số điện thoại. Để trống và nhấn <em>Lưu</em> nếu muốn gỡ NCC khỏi phiếu.
                </p>
                <div id="vendorPicker"
                     data-id="@Model.VendorId"
                     data-name="@Model.VendorName"
                     data-phone="@Model.VendorPhone"
                     data-address="@Model.VendorAddress"></div>
                <input type="hidden" id="selectedVendorId" value="@(Model.VendorId?.ToString() ?? "")" />
                <div id="editVendorError" class="alert alert-danger d-none mt-3 py-2 mb-0"></div>
            </div>
            <div class="modal-footer border-0 pt-0 pb-3">
                <button type="button" class="btn btn-light" data-bs-dismiss="modal">Hủy</button>
                <button type="button" id="btnSaveVendor" class="btn btn-primary">
                    <i class="bi bi-check-lg me-1"></i>Lưu
                </button>
            </div>
        </div>
    </div>
</div>

<!-- ── Modal: Định giá nhập ── -->
<div class="modal fade" id="setUnitCostModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content border-0 shadow rounded-4">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold">Định giá nhập</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p class="text-muted small mb-3" id="setUnitCostProductName"></p>
                <form id="setUnitCostForm">
                    <input type="hidden" name="GoodsReceiptId" value="@Model.Id" />
                    <input type="hidden" name="ItemId" id="setUnitCostItemId" />
                    <label class="form-label small fw-medium text-muted" for="setUnitCostValue">Đơn giá nhập</label>
                    <input type="number" id="setUnitCostValue" name="UnitCost" class="form-control"
                           min="0" step="any" placeholder="0" />
                </form>
                <div id="setUnitCostError" class="alert alert-danger d-none mt-2 py-2 mb-0"></div>
            </div>
            <div class="modal-footer border-0 pt-0 pb-3">
                <button type="button" class="btn btn-light" data-bs-dismiss="modal">Hủy</button>
                <button type="button" id="btnSaveUnitCost" class="btn btn-warning">
                    <i class="bi bi-check-lg me-1"></i>Xác nhận
                </button>
            </div>
        </div>
    </div>
</div>

@section Styles {
<style>
    /* ── Receipt info DL ── */
    .receipt-info-list { margin: 0; }
    .receipt-info-row {
        display: flex;
        align-items: baseline;
        padding: .6rem 1.25rem;
        border-bottom: 1px solid var(--bs-border-color-translucent);
        gap: .75rem;
    }
    .receipt-info-row:last-child { border-bottom: none; }
    .receipt-info-row dt {
        font-size: .75rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: .03em;
        color: var(--bs-secondary);
        width: 72px;
        flex-shrink: 0;
    }
    .receipt-info-row dd { margin: 0; font-size: .875rem; }

    /* ── Product links ── */
    .details-product-link:hover { color: var(--bs-primary) !important; text-decoration: underline !important; }

    /* ── PO Suggestion rows ── */
    .po-suggestion-row {
        display: flex; align-items: center; gap: .6rem;
        padding: .6rem 1rem; border-bottom: 1px solid var(--bs-border-color-translucent);
    }
    .po-suggestion-row:last-child { border-bottom: none; }
    .po-score-bar { height: 5px; flex: 1; border-radius: 3px; background: var(--bs-border-color); overflow: hidden; min-width: 40px; }
    .po-score-fill { height: 100%; border-radius: 3px; transition: width .3s; }
    .po-score-full { background: var(--bs-success); }
    .po-score-partial { background: var(--bs-warning); }

    /* ── Picture picker ── */
    .picture-upload-slot {
        position: relative; width: 100px; height: 100px;
        border-radius: 10px; overflow: hidden; flex-shrink: 0;
    }
    .picture-upload-label {
        display: flex; flex-direction: column; align-items: center;
        justify-content: center; width: 100px; height: 100px;
        border: 2px dashed var(--bs-border-color); border-radius: 10px;
        cursor: pointer; background: #f8f9fa;
        transition: border-color .15s, background .15s;
        font-size: .7rem; color: var(--bs-secondary); gap: 3px;
    }
    .picture-upload-label:hover, .picture-upload-label.drag-over {
        border-color: var(--bs-primary); background: #eef3ff; color: var(--bs-primary);
    }
    .picture-upload-placeholder { display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 3px; pointer-events: none; }
    .picture-thumbnail-wrapper { position: relative; width: 100px; height: 100px; margin-right:.5rem; flex-shrink: 0; }
    .picture-thumbnail-img { width: 100px; height: 100px; object-fit: cover; border-radius: 10px; border: 1px solid var(--bs-border-color); display: block; }
    .btn-remove-picture {
        position: absolute; top: 3px; right: 3px; width: 18px; height: 18px;
        border-radius: 50%; border: none; background: rgba(0,0,0,.55); color: #fff;
        font-size: .6rem; display: flex; align-items: center; justify-content: center;
        cursor: pointer; padding: 0; transition: background .15s;
    }
    .btn-remove-picture:hover { background: var(--bs-danger); }
</style>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script type="module">
        import VendorPicker from "/modules/VendorPicker.js";
        import { apiPost } from "/modules/ajax-helper.js";
        import { toast } from "/modules/modals.js";

        const antiForgeryToken = document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';

        // ── Vendor picker (modal) ────────────────────────────────────────────
        (function initVendorPicker() {
            const pickerEl = document.getElementById('vendorPicker');
            const selectedIdInput = document.getElementById('selectedVendorId');
            const errorEl = document.getElementById('editVendorError');
            const saveBtn = document.getElementById('btnSaveVendor');
            if (!pickerEl || !selectedIdInput || !saveBtn) return;

            const picker = new VendorPicker(pickerEl);

            pickerEl.addEventListener('select', (e) => {
                selectedIdInput.value = e.detail?.vendor?.id ?? '';
                errorEl?.classList.add('d-none');
            });
            pickerEl.addEventListener('remove', () => {
                selectedIdInput.value = '';
                errorEl?.classList.add('d-none');
            });

            // Initial vendor (nếu phiếu đã có).
            // Pass plain object trực tiếp (không qua Vendor constructor) để giữ field
            // `address` — Vendor class hiện chỉ destructure {id, name, phone}.
            const initial = pickerEl.dataset;
            if (initial.id) {
                picker.displayVendor({
                    id: initial.id,
                    name: initial.name ?? '',
                    phone: initial.phone ?? '',
                    address: initial.address ?? ''
                });
            }

            saveBtn.addEventListener('click', async () => {
                errorEl?.classList.add('d-none');
                const vendorIdRaw = (selectedIdInput.value || '').trim();
                const vendorId = vendorIdRaw === '' ? null : vendorIdRaw;

                // No-op nếu vendor không thay đổi
                const currentVendorId = (initial.id || '') || null;
                if ((vendorId ?? '') === (currentVendorId ?? '')) {
                    bootstrap.Modal.getOrCreateInstance(document.getElementById('editVendorModal')).hide();
                    return;
                }

                saveBtn.disabled = true;
                try {
                    const fd = new FormData();
                    fd.append('goodsReceiptId', '@Model.Id');
                    if (vendorId) fd.append('vendorId', vendorId);

                    const result = await apiPost('@Url.Action("SetVendor")', fd);
                    if (result.success) {
                        toast('Thành công', vendorId
                            ? 'Đã cập nhật nhà cung cấp.'
                            : 'Đã gỡ nhà cung cấp khỏi phiếu.', 'success');
                        // Reload để: hiển thị vendor mới + cập nhật badge "Đã ghi nợ" nếu trigger sinh nợ.
                        location.reload();
                    } else {
                        if (errorEl) {
                            errorEl.textContent = result.message || 'Cập nhật thất bại.';
                            errorEl.classList.remove('d-none');
                        }
                    }
                } catch (err) {
                    if (errorEl) {
                        errorEl.textContent = 'Lỗi kết nối. Vui lòng thử lại.';
                        errorEl.classList.remove('d-none');
                    }
                } finally {
                    saveBtn.disabled = false;
                }
            });
        })();

        // ── Inline Picture Picker ──────────────────────────────────────────────
        (function initInlinePictures() {
            const dataEl   = document.getElementById('inlinePictureData');
            const listEl   = document.getElementById('inlinePictureList');
            const pickEl   = document.getElementById('inlinePicturePicker');
            const savingEl = document.getElementById('inlinePictureSaving');
            const errorEl  = document.getElementById('inlinePictureError');
            if (!dataEl || !listEl || !pickEl) return;

            const receiptId = dataEl.dataset.receiptId;
            const MAX = 2;
            let ids = (dataEl.dataset.pictureIds || '').split(',').map(s => s.trim()).filter(Boolean);

            function render() {
                listEl.innerHTML = '';
                ids.forEach(id => addThumb(id));
                renderSlots();
            }

            function renderSlots() {
                pickEl.innerHTML = '';
                for (let i = 0; i < MAX - ids.length; i++) pickEl.appendChild(buildSlot());
            }

            function addThumb(id) {
                const w = document.createElement('div');
                w.className = 'picture-thumbnail-wrapper';
                w.innerHTML = `<a href="/Picture/${id}" target="_blank"><img src="/Picture/${id}" class="picture-thumbnail-img" alt="Ảnh chụp"/></a>
                    <button type="button" class="btn-remove-picture"><i class="bi bi-x-lg"></i></button>`;
                w.querySelector('.btn-remove-picture').onclick = async () => {
                    ids = ids.filter(x => x !== id);
                    w.remove(); renderSlots(); await save();
                };
                listEl.appendChild(w);
            }

            function buildSlot() {
                const s = document.createElement('div');
                s.className = 'picture-upload-slot';
                s.innerHTML = `<label class="picture-upload-label"><input type="file" class="d-none" accept="image/*"/>
                    <div class="picture-upload-placeholder"><i class="bi bi-camera fs-5"></i></div></label>`;
                s.querySelector('input').onchange = async e => { if (e.target.files?.[0]) await upload(e.target.files[0], s); };
                s.addEventListener('dragover', e => { e.preventDefault(); s.querySelector('.picture-upload-label').classList.add('drag-over'); });
                s.addEventListener('dragleave', () => s.querySelector('.picture-upload-label').classList.remove('drag-over'));
                s.addEventListener('drop', async e => { e.preventDefault(); s.querySelector('.picture-upload-label').classList.remove('drag-over'); if (e.dataTransfer?.files?.[0]) await upload(e.dataTransfer.files[0], s); });
                return s;
            }

            async function upload(file, slot) {
                const ph = slot.querySelector('.picture-upload-placeholder');
                if (ph) ph.innerHTML = `<div class="spinner-border spinner-border-sm text-primary"></div>`;
                try {
                    const fd = new FormData(); fd.append('file', file);
                    const data = await fetch('/Picture/Upload', { method: 'POST', headers: { 'RequestVerificationToken': antiForgeryToken }, body: fd }).then(r => r.json());
                    if (!data.success) { if (ph) ph.innerHTML = `<i class="bi bi-x-circle text-danger"></i>`; return; }
                    slot.remove(); ids.push(data.id); addThumb(data.id); renderSlots(); await save();
                } catch { if (ph) ph.innerHTML = `<i class="bi bi-x-circle text-danger"></i>`; }
            }

            async function save() {
                savingEl?.classList.remove('d-none'); errorEl?.classList.add('d-none');
                try {
                    const fd = new FormData(); fd.append('id', receiptId);
                    ids.forEach(id => fd.append('pictureIds', id));
                    fd.append('__RequestVerificationToken', antiForgeryToken);
                    const data = await fetch('@Url.Action("UpdatePictures")', { method: 'POST', body: fd }).then(r => r.json());
                    if (!data.success && errorEl) { errorEl.textContent = data.message ?? 'Lưu thất bại'; errorEl.classList.remove('d-none'); }
                } catch { if (errorEl) { errorEl.textContent = 'Lỗi kết nối'; errorEl.classList.remove('d-none'); } }
                finally { savingEl?.classList.add('d-none'); }
            }

            render();
        })();

        // ── Định giá ──────────────────────────────────────────────────────────
        document.querySelectorAll('.btnSetUnitCost').forEach(btn => {
            btn.onclick = () => {
                document.getElementById('setUnitCostItemId').value = btn.dataset.itemId;
                document.getElementById('setUnitCostProductName').textContent = btn.dataset.productName;
                document.getElementById('setUnitCostValue').value = '';
                document.getElementById('setUnitCostError').classList.add('d-none');
                bootstrap.Modal.getOrCreateInstance(document.getElementById('setUnitCostModal')).show();
            };
        });

        document.getElementById('btnSaveUnitCost')?.addEventListener('click', async () => {
            const val = document.getElementById('setUnitCostValue').value;
            if (!val || parseFloat(val) < 0) {
                document.getElementById('setUnitCostError').textContent = 'Vui lòng nhập đơn giá hợp lệ.';
                document.getElementById('setUnitCostError').classList.remove('d-none'); return;
            }
            const fd = new FormData(document.getElementById('setUnitCostForm'));
            fd.append('__RequestVerificationToken', antiForgeryToken);
            try {
                const json = await fetch('@Url.Action("SetItemUnitCost")', { method: 'POST', body: fd }).then(r => r.json());
                if (json.success) location.reload();
                else { document.getElementById('setUnitCostError').textContent = json.message; document.getElementById('setUnitCostError').classList.remove('d-none'); }
            } catch {
                document.getElementById('setUnitCostError').textContent = 'Đã xảy ra lỗi.';
                document.getElementById('setUnitCostError').classList.remove('d-none');
            }
        });

        // ── Phiếu đặt hàng — Suggested PO ────────────────────────────────────
        (function initPoSuggestions() {
            const panel = document.getElementById('poSuggestionsPanel');
            if (!panel) return; // Đã linked — không cần load

            const receiptId = panel.dataset.receiptId;
            const loadingEl = document.getElementById('poSuggestionsLoading');
            const listEl    = document.getElementById('poSuggestionsList');
            const emptyEl   = document.getElementById('poSuggestionsEmpty');
            const errorEl   = document.getElementById('poSuggestionsError');

            async function linkToPurchaseOrder(purchaseOrderId, poCode) {
                if (!confirm(`Xác nhận gắn phiếu nhập này với phiếu đặt hàng "${poCode}"?`)) return;

                const fd = new FormData();
                fd.append('id', receiptId);
                fd.append('purchaseOrderId', purchaseOrderId);
                fd.append('__RequestVerificationToken', antiForgeryToken);

                try {
                    const res = await fetch('@Url.Action("SetToPurchaseOrder")', { method: 'POST', body: fd }).then(r => r.json());
                    if (res.success) {
                        location.reload();
                    } else {
                        alert(res.message || 'Gắn phiếu thất bại. Vui lòng thử lại.');
                    }
                } catch {
                    alert('Lỗi kết nối. Vui lòng thử lại.');
                }
            }

            function renderRow(po) {
                const isFullMatch = po.isFullMatch;
                const scoreClass  = isFullMatch ? 'po-score-full' : 'po-score-partial';
                const badgeClass  = isFullMatch ? 'bg-success-subtle text-success border-success-subtle' : 'bg-warning-subtle text-warning border-warning-subtle';
                const badgeIcon   = isFullMatch ? 'bi-check-circle-fill' : 'bi-lightning-charge-fill';
                const badgeLabel  = isFullMatch ? 'Khớp hoàn toàn' : `Khớp ${po.matchScore}%`;
                const placedDate  = new Date(po.placedOn).toLocaleDateString('vi-VN');

                const row = document.createElement('div');
                row.className = 'po-suggestion-row';
                row.innerHTML = `
                    <div style="flex:1;min-width:0;">
                        <div class="d-flex align-items-center gap-2 mb-1 flex-wrap">
                            <span class="badge border ${badgeClass} py-1" style="font-size:.7rem;">
                                <i class="bi ${badgeIcon} me-1"></i>${badgeLabel}
                            </span>
                            <span class="fw-semibold text-truncate" style="font-size:.875rem;">${po.purchaseOrderCode}</span>
                        </div>
                        <div class="d-flex align-items-center gap-2">
                            <span class="text-muted" style="font-size:.75rem;">${placedDate}</span>
                            <div class="po-score-bar"><div class="po-score-fill ${scoreClass}" style="width:${po.matchScore}%"></div></div>
                        </div>
                    </div>
                    <button type="button" class="btn btn-sm btn-outline-primary flex-shrink-0 btnSelectPo"
                            data-po-id="${po.purchaseOrderId}" data-po-code="${po.purchaseOrderCode}">
                        Chọn
                    </button>`;

                row.querySelector('.btnSelectPo').addEventListener('click', () => {
                    linkToPurchaseOrder(po.purchaseOrderId, po.purchaseOrderCode);
                });
                return row;
            }

            async function loadSuggestions() {
                try {
                    const res = await fetch(`@Url.Action("GetSuggestedPurchaseOrders")?id=${receiptId}`).then(r => r.json());

                    loadingEl.classList.add('d-none');

                    if (!res || res.length === 0) {
                        emptyEl.classList.remove('d-none');
                        return;
                    }

                    res.forEach(po => listEl.appendChild(renderRow(po)));
                    listEl.classList.remove('d-none');
                } catch {
                    loadingEl.classList.add('d-none');
                    if (errorEl) {
                        errorEl.textContent = 'Không thể tải danh sách phiếu đặt hàng.';
                        errorEl.classList.remove('d-none');
                    }
                }
            }

            loadSuggestions();

            // ── Tìm theo mã thủ công ──
            document.getElementById('btnSearchPoByCode')?.addEventListener('click', () => {
                document.getElementById('poCodeInput').value = '';
                document.getElementById('searchPoByCodeError').classList.add('d-none');
                bootstrap.Modal.getOrCreateInstance(document.getElementById('searchPoByCodeModal')).show();
            });

            document.getElementById('btnConfirmPoByCode')?.addEventListener('click', async () => {
                const code = document.getElementById('poCodeInput').value.trim();
                const errEl = document.getElementById('searchPoByCodeError');
                errEl.classList.add('d-none');

                if (!code) {
                    errEl.textContent = 'Vui lòng nhập mã phiếu.';
                    errEl.classList.remove('d-none');
                    return;
                }

                const btn = document.getElementById('btnConfirmPoByCode');
                btn.disabled = true;
                try {
                    const fd = new FormData();
                    fd.append('id', receiptId);
                    fd.append('code', code);
                    fd.append('__RequestVerificationToken', antiForgeryToken);

                    const res = await fetch('@Url.Action("SetToPurchaseOrderByCode")', { method: 'POST', body: fd }).then(r => r.json());
                    if (res.success) {
                        location.reload();
                    } else {
                        errEl.textContent = res.message || 'Không tìm thấy phiếu đặt hàng.';
                        errEl.classList.remove('d-none');
                    }
                } catch {
                    errEl.textContent = 'Lỗi kết nối. Vui lòng thử lại.';
                    errEl.classList.remove('d-none');
                } finally {
                    btn.disabled = false;
                }
            });
        })();

        // ── Quick Create PO từ GoodsReceipt ──────────────────────────────────
        (function initQuickCreatePo() {
            const modalEl = document.getElementById('quickCreatePoModal');
            if (!modalEl) return;

            const vendorPickerEl   = document.getElementById('quickPoVendorPicker');
            const vendorIdInput    = document.getElementById('quickPoSelectedVendorId');
            const vendorErrorEl    = document.getElementById('quickPoVendorError');
            const errorEl          = document.getElementById('quickPoError');
            const confirmBtn       = document.getElementById('btnConfirmQuickCreatePo');
            const spinner          = document.getElementById('quickPoSpinner');
            const icon             = document.getElementById('quickPoIcon');

            if (!vendorPickerEl || !confirmBtn) return;

            const receiptId = modalEl.dataset.receiptId;

            // Khởi tạo VendorPicker rỗng (chưa có vendor mặc định).
            const picker = new VendorPicker(vendorPickerEl);
            vendorPickerEl.addEventListener('select', (e) => {
                vendorIdInput.value = e.detail?.vendor?.id ?? '';
                vendorErrorEl.classList.add('d-none');
                errorEl.classList.add('d-none');
            });
            vendorPickerEl.addEventListener('remove', () => {
                vendorIdInput.value = '';
            });

            // Reset form khi mở modal.
            modalEl.addEventListener('show.bs.modal', () => {
                picker.clear?.();
                vendorIdInput.value = '';
                vendorErrorEl.classList.add('d-none');
                errorEl.classList.add('d-none');
                confirmBtn.disabled = false;
                spinner.classList.add('d-none');
                icon.classList.remove('d-none');
            });

            confirmBtn.addEventListener('click', async () => {
                vendorErrorEl.classList.add('d-none');
                errorEl.classList.add('d-none');

                const vendorId  = (vendorIdInput.value || '').trim();
                const placedOn  = document.getElementById('quickPoPlacedOn').value;
                const note      = document.getElementById('quickPoNote').value;

                if (!vendorId) {
                    vendorErrorEl.classList.remove('d-none');
                    vendorErrorEl.style.display = 'block';
                    return;
                }
                if (!placedOn) {
                    errorEl.textContent = 'Vui lòng chọn ngày đặt hàng.';
                    errorEl.classList.remove('d-none');
                    return;
                }

                confirmBtn.disabled = true;
                spinner.classList.remove('d-none');
                icon.classList.add('d-none');

                try {
                    const fd = new FormData();
                    fd.append('id', receiptId);
                    fd.append('vendorId', vendorId);
                    fd.append('placedOn', placedOn);
                    if (note) fd.append('note', note);
                    fd.append('__RequestVerificationToken', antiForgeryToken);

                    const res = await fetch('@Url.Action("QuickCreateAndLink")', { method: 'POST', body: fd }).then(r => r.json());
                    if (res.success) {
                        bootstrap.Modal.getOrCreateInstance(modalEl).hide();
                        location.reload();
                    } else {
                        errorEl.textContent = res.message || 'Tạo phiếu đặt hàng thất bại.';
                        errorEl.classList.remove('d-none');
                    }
                } catch {
                    errorEl.textContent = 'Lỗi kết nối. Vui lòng thử lại.';
                    errorEl.classList.remove('d-none');
                } finally {
                    confirmBtn.disabled = false;
                    spinner.classList.add('d-none');
                    icon.classList.remove('d-none');
                }
            });
        })();

        // ── Lưu thông tin ─────────────────────────────────────────────────────
        document.getElementById('btnSaveInfo')?.addEventListener('click', async () => {
            const fd = new FormData(document.getElementById('editInfoForm'));
            fd.append('__RequestVerificationToken', antiForgeryToken);
            document.getElementById('editInfoError').classList.add('d-none');
            try {
                const json = await fetch('@Url.Action("EditInfo")', { method: 'POST', body: fd }).then(r => r.json());
                if (json.success) location.reload();
                else { document.getElementById('editInfoError').textContent = json.message; document.getElementById('editInfoError').classList.remove('d-none'); }
            } catch {
                document.getElementById('editInfoError').textContent = 'Đã xảy ra lỗi.';
                document.getElementById('editInfoError').classList.remove('d-none');
            }
        });
    </script>
}
