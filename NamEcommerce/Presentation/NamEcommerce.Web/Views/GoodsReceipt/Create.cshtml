@model CreateGoodsReceiptModel
@inject WarehouseSettings WarehouseSettings
@{
    ViewData[ViewConstants.PageTitle] = "Tạo phiếu nhập hàng";
}
@section TitleSection {
    <h1 class="topbar-page-title">
        Thêm mới
        <span class="text-muted">Phiếu nhập hàng</span>
    </h1>
    <div class="topbar-page-subtitle">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a asp-action="Index" asp-controller="Home" class="text-decoration-none">Trang chủ</a></li>
                <li class="breadcrumb-item"><a asp-action="List" asp-controller="GoodsReceipt" class="text-decoration-none">Phiếu nhập hàng</a></li>
                <li class="breadcrumb-item active" aria-current="page">Thêm mới</li>
            </ol>
        </nav>
    </div>
}
<div>
    <div asp-validation-summary="ModelOnly" class="alert alert-warning alert-global alert-dismissible"></div>
    <form method="post" id="createGoodsReceiptForm" asp-antiforgery="true">
        <div class="row g-3">
            <div class="col-lg-8 order-1 order-lg-0">
                <div class="content-card mb-3">
                    <div class="content-card-header">
                        <h5>Danh sách hàng hóa</h5>
                        <button type="button" class="btn btn-sm bg-light text-primary"
                                data-bs-toggle="modal" data-bs-target="#addItemModal">
                            <i class="bi bi-plus-lg me-1"></i>
                            <span class="d-none d-lg-inline">Thêm hàng hóa</span>
                            <span class="d-lg-none">Thêm</span>
                        </button>
                    </div>
                    <div class="content-card-body-flush">
                        <div class="table-responsive">
                            <table class="table data-table mb-0" id="goodsReceiptItemsTable">
                                <thead>
                                    <tr>
                                        <th class="ps-3">Hàng hóa</th>
                                        <th class="text-center">Số lượng</th>
                                        <th class="t@(Model.WarehouseId.HasValue ? "d-none" : "")">Kho nhập</th>
                                        <th class="text-end">Giá nhập</th>
                                        <th></th>
                                    </tr>
                                </thead>
                                <tbody id="itemsTableBody">
                                    @for (var i = 0; i < Model.Items.Count; i++)
                                    {
                                        var item = Model.Items[i];
                                        <tr id="item-row-@i">
                                            <td class="ps-3">
                                                <div class="d-flex align-items-center">
                                                    @if (!string.IsNullOrEmpty(item.ProductDisplayPicture))
                                                    {
                                                        <img src="@item.ProductDisplayPicture" class="rounded me-2 product-picture"
                                                             style="width:36px;height:36px;object-fit:cover;flex-shrink:0;" alt="" />
                                                    }
                                                    else
                                                    {
                                                        <div class="d-flex align-items-center justify-content-center rounded bg-light me-2"
                                                             style="width:36px;height:36px;flex-shrink:0;">
                                                            <i class="bi bi-image text-muted small"></i>
                                                        </div>
                                                    }
                                                    <div>
                                                        <div class="fw-medium item-product-name">@item.ProductDisplayName</div>
                                                        @if (!string.IsNullOrEmpty(item.WarehouseDisplayName))
                                                        {
                                                            <div class="text-muted small">
                                                                <i class="bi bi-building me-1"></i>@item.WarehouseDisplayName
                                                            </div>
                                                        }
                                                    </div>
                                                </div>
                                                <input type="hidden" name="Items[@i].ProductId" value="@item.ProductId" class="item-product-id" />
                                            </td>
                                            <td class="text-center">
                                                <input name="Items[@i].Quantity" value="@item.Quantity.DisplayQuantity()"
                                                       class="form-control form-control-sm text-end item-qty no-additional-element"
                                                       data-decimal="quantity" min="0.001" placeholder="0"
                                                       data-val="true" data-val-number="Số lượng không đúng."
                                                       data-val-required="Vui lòng nhập số lượng."
                                                       data-val-range="Số lượng phải lớn hơn 0." data-val-range-min="0.001" />
                                                <span class="small text-danger field-validation-valid" data-valmsg-for="Items[@i].Quantity" data-valmsg-replace="true"></span>
                                            </td>
                                            <td>
                                                <select asp-for="Items[i].WarehouseId" class="form-select item-warehouse" disabled="@Model.WarehouseId.HasValue" data-val="@(WarehouseSettings.AllowNonWarehouse ? "false" : "true")" data-required="Vui lòng chọn kho hàng">
                                                    @if (WarehouseSettings.AllowNonWarehouse)
                                                    {
                                                        <option value="" selected="@(!Model.Items[i].WarehouseId.HasValue)">(Không chọn)</option>
                                                    }
                                                    @if (Model.AvailableWarehouses is not null)
                                                    {
                                                        foreach (var warehouse in Model.AvailableWarehouses)
                                                        {
                                                            <option value="@warehouse.Id" selected="@(Model.Items[i].WarehouseId == warehouse.Id)">@warehouse.Name</option>
                                                        }
                                                    }
                                                </select>
                                                <span asp-validation-for="Items[i].WarehouseId" class="small text-danger"></span>
                                            </td>
                                            <td class="text-end">
                                                <input name="Items[@i].UnitCost"
                                                       value="@(item.UnitCost.HasValue ? item.UnitCost.Value.DisplayCurrency() : "")"
                                                       class="form-control form-control-sm text-end item-unit-cost no-additional-element no-hint"
                                                       data-decimal="currency" placeholder="(Không rõ)" min="0"
                                                       data-val="true" data-val-number="Đơn giá không đúng."
                                                       data-val-range="Đơn giá không được âm." data-val-range-min="0" />
                                                <span class="small text-danger field-validation-valid" data-valmsg-for="Items[@i].UnitCost" data-valmsg-replace="true"></span>
                                            </td>
                                            <td class="text-end pe-3">
                                                <button type="button" class="btn-table-action danger border-0 bg-transparent shadow-none btn-remove-item">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                        <div id="noItemsMessage" class="py-4 text-center text-muted" style="@(Model.Items.Count == 0 ? "display:block" : "display:none")">
                            Chưa có hàng hóa nào được chọn.
                            <div class="mt-1">
                                <span asp-validation-for="Items" class="text-danger small"></span>
                            </div>
                        </div>
                    </div>
                    <div class="content-card-footer py-2 d-flex align-items-center justify-content-between">
                        <a asp-action="List" class="btn btn-link text-decoration-none">
                            <span class="text-muted small">Trở về</span>
                        </a>
                        <button type="submit" class="btn btn-primary btnSubmit d-lg-none" id="btnSubmitMobile">
                            Tạo phiếu
                        </button>
                    </div>
                </div>
                <!-- Product Browser -->
                <div class="content-card">
                    <div class="content-card-header">
                        <h5><i class="bi bi-grid me-2 text-primary"></i>Chọn hàng hóa</h5>
                        <span class="text-muted small">Nhấn <i class="bi bi-plus-lg"></i> để thêm vào phiếu</span>
                    </div>
                    <div class="content-card-body">
                        <div id="productBrowser"></div>
                    </div>
                </div>
            </div>
            <div class="col-lg-4">
                <div class="content-card">
                    <div class="content-card-header">
                        <h5>Thông tin phiếu nhập</h5>
                    </div>
                    <div class="content-card-body">
                        <div class="mb-3">
                            <label asp-for="ReceivedOn" class="form-label small fw-bold text-muted text-uppercase d-block"></label>
                            <input type="datetime-local" asp-for="ReceivedOn" class="form-control" />
                            <span asp-validation-for="ReceivedOn" class="small text-danger"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="WarehouseId" class="form-label small fw-bold text-muted text-uppercase d-block"></label>
                            <select asp-for="WarehouseId" class="form-select">
                                <option value="" selected="@(!Model.WarehouseId.HasValue)">(Nhập vào nhiều kho hàng)</option>
                                @if (Model.AvailableWarehouses is not null)
                                {
                                    foreach (var warehouse in Model.AvailableWarehouses)
                                    {
                                        <option value="@warehouse.Id" selected="@(Model.WarehouseId == warehouse.Id)">@warehouse.Name</option>
                                    }
                                }
                            </select>
                            <span asp-validation-for="WarehouseId" class="small text-danger"></span>
                        </div>
                        <div class="mb-3">
                            <label class="form-label small fw-bold text-muted text-uppercase d-block">
                                Nhà cung cấp <span class="text-muted text-lowercase fw-normal">(không bắt buộc)</span>
                            </label>
                            <input type="hidden" asp-for="VendorId" id="VendorId" />
                            <div id="vendorPicker"
                                 data-id="@Model.VendorId"
                                 data-name="@Model.VendorDisplayName"
                                 data-phone="@Model.VendorDisplayPhone"
                                 data-address="@Model.VendorDisplayAddress"></div>
                            <div class="form-text small">
                                Chọn nhà cung cấp tại đây hoặc gắn sau ở trang chi tiết. Khi định giá đủ tất cả mặt hàng, hệ thống sẽ tự động sinh phiếu nợ.
                            </div>
                        </div>
                        <div class="mb-3">
                            <label asp-for="TruckDriverName" class="form-label small fw-bold text-muted text-uppercase d-block"></label>
                            <input asp-for="TruckDriverName" class="form-control" placeholder="Nhập tên tài xế" />
                            <span asp-validation-for="TruckDriverName" class="small text-danger"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="TruckNumberSerial" class="form-label small fw-bold text-muted text-uppercase d-block"></label>
                            <input asp-for="TruckNumberSerial" class="form-control" placeholder="Nhập biển số xe" />
                            <span asp-validation-for="TruckNumberSerial" class="small text-danger"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="Note" class="form-label small fw-bold text-muted text-uppercase d-block"></label>
                            <textarea asp-for="Note" class="form-control" rows="2" placeholder="Ghi chú..."></textarea>
                            <span asp-validation-for="Note" class="small text-danger"></span>
                        </div>
                        <div class="mb-2">
                            <label class="form-label small fw-bold text-muted text-uppercase d-block">
                                Ảnh chụp
                            </label>
                            <div class="d-flex align-items-center">
                                <div id="pictureList"></div>
                                <div id="picturePicker"></div>
                            </div>
                            <span asp-validation-for="PictureIds" class="small text-danger d-block mt-1"></span>
                            <div id="pictureHiddenContainer">
                                @foreach (var id in Model.PictureIds)
                                {
                                    <input type="hidden" name="PictureIds" value="@id" />
                                }
                            </div>
                        </div>
                    </div>
                    <div class="content-card-footer d-none d-lg-block">
                        <div class="d-grid">
                            <button type="submit" class="btn btn-primary btnSubmit" id="btnSubmitDesktop">
                                Tạo phiếu
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

<!-- Add Item Modal (thêm thủ công qua search) -->
<div class="modal fade" id="addItemModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow rounded-4">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold">Thêm hàng hóa</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body py-3">
                <div class="mb-3">
                    <div id="productPicker"></div>
                    <input type="hidden" id="modalProductId" />
                    <span class="small text-danger d-none" id="productPickerError">Vui lòng chọn hàng hóa.</span>
                </div>
                <div id="modalProductDetails" class="d-none">
                    <div class="row g-2">
                        <div class="col-12" id="modalWarehouseContainer">
                            <label for="modalWarehouseId" class="form-label small fw-medium text-muted">Kho hàng</label>
                            <select id="modalWarehouseId" class="form-select">
                                @if (Model.AvailableWarehouses is not null)
                                {
                                    <option value="" selected="@(!Model.WarehouseId.HasValue)">(Không chọn)</option>
                                    foreach (var warehouse in Model.AvailableWarehouses)
                                    {
                                        <option value="@warehouse.Id" selected="@(Model.WarehouseId == warehouse.Id)">@warehouse.Name</option>
                                    }
                                }
                            </select>
                            <span class="small text-danger d-none" id="modalWarehouseError">Vui lòng chọn kho hàng</span>
                        </div>
                        <div class="col-6">
                            <label class="form-label small fw-medium text-muted" for="modalQty">Số lượng</label>
                            <input id="modalQty" class="form-control no-additional-element" data-decimal="quantity" value="1" min="0.001" placeholder="0" />
                            <span class="small text-danger d-none" id="modalQtyError">Số lượng phải lớn hơn 0.</span>
                        </div>
                        <div class="col-6">
                            <label class="form-label small fw-medium text-muted" for="modalUnitCost">Giá nhập</label>
                            <input id="modalUnitCost" class="form-control no-additional-element" data-decimal="currency" placeholder="Không rõ" />
                            <span class="small text-danger d-none" id="modalUnitCostError">Giá nhập phải lớn hơn 0</span>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer border-0 pt-0 pb-3">
                <button type="button" class="btn btn-light" data-bs-dismiss="modal">Hủy</button>
                <button type="button" id="btnAddItemConfirm" class="btn btn-success d-none">
                    <i class="bi bi-plus-lg me-1"></i>Thêm vào
                </button>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        /* ── Product Browser ─────────────────────────────── */
        .pb-product-card {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 10px 12px;
            border: 1px solid var(--bs-border-color);
            border-radius: 10px;
            background: #fff;
            transition: box-shadow .15s, border-color .15s;
            min-height: 72px;
        }

            .pb-product-card:hover {
                box-shadow: 0 2px 8px rgba(0,0,0,.08);
                border-color: var(--bs-primary);
            }

        .pb-product-thumb {
            flex-shrink: 0;
            width: 48px;
            height: 48px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 8px;
            overflow: hidden;
            background: #f8f9fa;
        }

        .pb-product-img {
            width: 48px;
            height: 48px;
            object-fit: cover;
            border-radius: 8px;
        }

        .pb-product-img-placeholder {
            width: 48px;
            height: 48px;
            display: flex;
            align-items: center;
            justify-content: center;
            background: #f1f3f5;
            border-radius: 8px;
        }

        .pb-product-info {
            flex: 1;
            min-width: 0;
        }

        .pb-product-name {
            font-size: .875rem;
            line-height: 1.3;
        }

        .pb-product-category {
            font-size: .72rem;
            color: var(--bs-secondary);
            margin-top: 1px;
        }

        .pb-product-stock {
            margin-top: 2px;
            font-size: .75rem;
            color: var(--bs-secondary);
        }

        .pb-add-btn {
            flex-shrink: 0;
            width: 32px;
            height: 32px;
            padding: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 8px;
            font-size: 1rem;
        }

        .pb-categories .btn {
            font-size: .8rem;
            padding: 3px 10px;
            border-radius: 20px;
        }
        /* flash khi thêm thành công */
        tr.table-success > td {
            transition: background-color .4s;
        }

        /* ── PicturePicker ───────────────────────────────── */
        #picturePicker, #pictureList {
            display: flex;
            align-items: center;
            justify-content: start;
        }

        #picturePicker {
            gap: .5rem;
        }

        .picture-upload-slot {
            position: relative;
            width: 100px;
            height: 100px;
            border-radius: 10px;
            overflow: hidden;
            flex-shrink: 0;
        }

        .picture-thumbnail-item {
            width: 100px;
            height: 100px;
            object-fit: cover;
            border-radius: 10px;
            display: block;
            position: relative;
            margin-right: .5rem;
        }

        .picture-upload-label {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            width: 100px;
            height: 100px;
            border: 2px dashed var(--bs-border-color);
            border-radius: 10px;
            cursor: pointer;
            background: #f8f9fa;
            transition: border-color .15s, background .15s;
            font-size: .7rem;
            color: var(--bs-secondary);
            gap: 4px;
        }

            .picture-upload-label:hover,
            .picture-upload-label.drag-over {
                border-color: var(--bs-primary);
                background: #eef3ff;
                color: var(--bs-primary);
            }

        .picture-upload-placeholder {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            gap: 4px;
            pointer-events: none;
        }

        .btn-remove-picture {
            position: absolute;
            top: 3px;
            right: 3px;
            width: 20px;
            height: 20px;
            border-radius: 50%;
            border: none;
            background: rgba(0,0,0,.55);
            color: #fff;
            font-size: .65rem;
            line-height: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            padding: 0;
            transition: background .15s;
        }

            .btn-remove-picture:hover {
                background: var(--bs-danger);
            }

        .drag-over .picture-upload-label {
            border-color: var(--bs-primary);
            background: #eef3ff;
        }
    </style>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script type="module">
        import GoodsReceiptCreateController from "/modules/GoodsReceiptCreateController.js";
        import VendorPicker from "/modules/VendorPicker.js";

        new GoodsReceiptCreateController();

        // ── Vendor picker (optional) ──────────────────────────────────────────
        const vendorPickerEl = document.getElementById('vendorPicker');
        const vendorIdInput  = document.getElementById('VendorId');
        if (vendorPickerEl && vendorIdInput) {
            const vendorPicker = new VendorPicker(vendorPickerEl);

            vendorPickerEl.addEventListener('select', (e) => {
                vendorIdInput.value = e.detail?.vendor?.id ?? '';
            });
            vendorPickerEl.addEventListener('remove', () => {
                vendorIdInput.value = '';
            });

            // Initial vendor (re-render khi ModelState fail hoặc reload form).
            // Pass plain object trực tiếp (không qua Vendor constructor) để giữ field
            // `address` — Vendor class hiện chỉ destructure {id, name, phone}.
            const initial = vendorPickerEl.dataset;
            if (initial.id) {
                vendorPicker.displayVendor({
                    id: initial.id,
                    name: initial.name ?? '',
                    phone: initial.phone ?? '',
                    address: initial.address ?? ''
                });
            }
        }

        document.getElementById('@Html.IdFor(m => m.WarehouseId)').addEventListener('change', function(e) {
        const value = e.target.value;
        const table = document.getElementById('goodsReceiptItemsTable');
        const rows = table.querySelectorAll('tbody tr');
        for(let i = 0; i < rows.length; i++){
        const row = rows[i];
        const warehouse = row.querySelector('.item-warehouse');
        if (value) {
        warehouse.value = value;
        warehouse.disabled = true;
        } else{
        //warehouse.value = value;
        warehouse.disabled = false;
        }
        }
        });
    </script>
}
