@model NamEcommerce.Application.Contracts.Dtos.Finance.UpdateExpenseAppDto

@{
    ViewData[ViewConstants.PageTitle] = "Chỉnh sửa Chi phí";
    var expenseTypes = new List<SelectListItem>
    {
        new SelectListItem { Value = "1", Text = "Lương thưởng" },
        new SelectListItem { Value = "2", Text = "Mặt bằng" },
        new SelectListItem { Value = "3", Text = "Tiếp thị" },
        new SelectListItem { Value = "4", Text = "Điện nước" },
        new SelectListItem { Value = "5", Text = "Khác" }
    };
}

<div class="page-header">
    <div>
        <h1 class="page-header-title">Cập nhật Chi phí</h1>
        <p class="page-header-subtitle">Thay đổi thông tin khoản chi @Model.Title</p>
    </div>
</div>

<div class="form-card">
    <div class="form-card-header">
        <h2 class="form-card-title"><i class="bi bi-pencil-square me-2 text-primary"></i>Thông tin chi phí</h2>
        <a asp-action="List" class="form-card-breadcrumb">
            <i class="bi bi-arrow-left"></i> Trở về danh sách
        </a>
    </div>
    <div class="form-card-body">
        <div asp-validation-summary="ModelOnly" class="alert alert-warning alert-global"></div>
        <form class="row g-3" asp-action="Edit" method="post" asp-antiforgery="true">
            <input type="hidden" asp-for="Id" />
            
            <div class="col-md-6">
                <label asp-for="Title" class="form-label">Khoản chi</label>
                <input asp-for="Title" class="form-control" autofocus />
                <span asp-validation-for="Title" class="text-danger small"></span>
            </div>

            <div class="col-md-6">
                <label asp-for="Amount" class="form-label">Số tiền (₫)</label>
                <input asp-for="Amount" type="number" class="form-control" />
                <span asp-validation-for="Amount" class="text-danger small"></span>
            </div>

            <div class="col-md-6">
                <label asp-for="ExpenseType" class="form-label">Loại phí</label>
                <select asp-for="ExpenseType" asp-items="expenseTypes" class="form-select"></select>
                <span asp-validation-for="ExpenseType" class="text-danger small"></span>
            </div>

            <div class="col-md-6">
                <label asp-for="IncurredDate" class="form-label">Ngày thanh toán / Hóa đơn</label>
                <input asp-for="IncurredDate" type="date" class="form-control" value="@Model.IncurredDate.ToString("yyyy-MM-dd")" />
                <span asp-validation-for="IncurredDate" class="text-danger small"></span>
            </div>

            <div class="col-12">
                <label asp-for="Description" class="form-label">Ghi chú thêm</label>
                <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                <span asp-validation-for="Description" class="text-danger small"></span>
            </div>

            <div class="form-card-footer" style="margin: 0 -1.5rem -1.5rem; border-radius: 0 0 var(--card-radius) var(--card-radius);">
                <a asp-action="List" class="btn btn-outline-secondary">Hủy</a>
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-save me-1"></i>Lưu thay đổi
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
