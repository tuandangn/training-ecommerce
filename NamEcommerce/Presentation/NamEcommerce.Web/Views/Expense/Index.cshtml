@model NamEcommerce.Application.Contracts.Dtos.Common.IPagedDataAppDto<NamEcommerce.Application.Contracts.Dtos.Finance.ExpenseAppDto>

@{
    ViewData["Title"] = "Quản lý Chi phí";
    string? kwValue   = ViewData["Keywords"] as string;
    string? fromValue = ViewData["FromDate"] as string;
    string? toValue   = ViewData["ToDate"] as string;
    int?    typeValue = ViewData["ExpenseType"] as int?;
    bool    hasFilter = !string.IsNullOrEmpty(kwValue) || !string.IsNullOrEmpty(fromValue) || !string.IsNullOrEmpty(toValue) || typeValue.HasValue;

    string TypeLabel(int t) => t switch
    {
        1 => "Lương thưởng",
        2 => "Mặt bằng",
        3 => "Tiếp thị",
        4 => "Điện nước",
        _ => "Khác"
    };

    string TypeBadge(int t) => t switch
    {
        1 => "bg-primary",
        2 => "bg-warning text-dark",
        3 => "bg-info text-dark",
        4 => "bg-secondary",
        _ => "bg-light text-dark border"
    };
}

<div class="container-fluid py-4">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-0"><i class="bi bi-wallet2 me-2 text-primary"></i>Chi phí Vận hành (OPEX)</h2>
            <small class="text-muted">Theo dõi các khoản chi phí hoạt động kinh doanh</small>
        </div>
        <a asp-action="Create" class="btn btn-primary px-4">
            <i class="bi bi-plus-lg me-1"></i>Thêm Mới
        </a>
    </div>

    <!-- Filter Bar -->
    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body py-3">
            <form method="get" class="row g-2 align-items-end">
                <div class="col-md-3">
                    <label class="form-label text-muted fw-semibold small mb-1">Tìm kiếm</label>
                    <input type="text" name="keywords" class="form-control" placeholder="Tên khoản chi..." value="@kwValue" />
                </div>
                <div class="col-md-2">
                    <label class="form-label text-muted fw-semibold small mb-1">Từ ngày</label>
                    <input type="date" name="fromDate" class="form-control" value="@fromValue" />
                </div>
                <div class="col-md-2">
                    <label class="form-label text-muted fw-semibold small mb-1">Đến ngày</label>
                    <input type="date" name="toDate" class="form-control" value="@toValue" />
                </div>
                <div class="col-md-2">
                    <label class="form-label text-muted fw-semibold small mb-1">Loại phí</label>
                    <select name="expenseType" class="form-select">
                        <option value="">-- Tất cả --</option>
                        <option value="1" selected="@(typeValue == 1)">Lương thưởng</option>
                        <option value="2" selected="@(typeValue == 2)">Mặt bằng</option>
                        <option value="3" selected="@(typeValue == 3)">Tiếp thị</option>
                        <option value="4" selected="@(typeValue == 4)">Điện nước</option>
                        <option value="5" selected="@(typeValue == 5)">Khác</option>
                    </select>
                </div>
                <div class="col-md-3 d-flex gap-2">
                    <button type="submit" class="btn btn-primary flex-grow-1">
                        <i class="bi bi-funnel me-1"></i>Lọc
                    </button>
                    @if (hasFilter)
                    {
                        <a asp-action="Index" class="btn btn-outline-secondary">
                            <i class="bi bi-x-lg"></i>
                        </a>
                    }
                </div>
            </form>
        </div>
    </div>

    <!-- Table -->
    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Ngày hóa đơn</th>
                            <th>Khoản chi</th>
                            <th class="d-none d-md-table-cell">Mô tả</th>
                            <th>Loại phí</th>
                            <th>Số tiền</th>
                            <th class="text-end">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Pagination.TotalCount > 0)
                        {
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td class="text-nowrap">@item.IncurredDate.ToLocalTime().ToString("dd/MM/yyyy")</td>
                                    <td class="fw-semibold">@item.Title</td>
                                    <td class="text-muted small d-none d-md-table-cell">@item.Description</td>
                                    <td><span class="badge @TypeBadge(item.ExpenseType)">@TypeLabel(item.ExpenseType)</span></td>
                                    <td class="fw-bold text-danger text-nowrap">@item.Amount.ToString("N0") ₫</td>
                                    <td class="text-end">
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-light btn-sm px-3 fw-semibold border">Sửa</a>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6" class="text-center py-5">
                                    <i class="bi bi-inbox fs-1 text-muted d-block mb-2"></i>
                                    <span class="text-muted">Chưa có chi phí nào @(hasFilter ? "khớp với bộ lọc" : "được ghi nhận").</span>
                                </td>
                            </tr>
                        }
                    </tbody>
                    @if (Model.Pagination.TotalCount > 0)
                    {
                        <tfoot class="table-light">
                            <tr>
                                <td colspan="4" class="fw-bold text-end text-uppercase small text-muted">Tổng cộng trang này:</td>
                                <td class="fw-bold text-danger fs-6">@Model.Sum(x => x.Amount).ToString("N0") ₫</td>
                                <td></td>
                            </tr>
                        </tfoot>
                    }
                </table>
            </div>
        </div>
    </div>

    <!-- Pagination -->
    @if (Model.Pagination.TotalCount > 0)
    {
        <partial name="_Pager" model="Model.Pagination" />
    }
</div>
