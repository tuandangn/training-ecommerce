@model DeliveryNoteListModel
@using NamEcommerce.Web.Constants
@{
    ViewData["Title"] = "Phiếu xuất kho";
    var query = Model.Keywords ?? "";
}

<div class="page-header">
    <div>
        <h1 class="page-header-title">Phiếu xuất kho</h1>
        <p class="page-header-subtitle">Quản lý phiếu xuất kho và giao hàng</p>
    </div>
</div>

@if (TempData[ViewConstants.CustomerSuccessMessage] != null)
{
    <div class="alert alert-success alert-dismissible fade show alert-global mb-3" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i>@TempData[ViewConstants.CustomerSuccessMessage]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData[ViewConstants.CustomerErrorMessage] != null)
{
    <div class="alert alert-danger alert-dismissible fade show alert-global mb-3" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData[ViewConstants.CustomerErrorMessage]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="content-card">
    <div class="action-toolbar">
        <partial name="_Search" model="query" />
    </div>
    
    <div class="table-responsive">
        <table class="table data-table">
            <thead>
                <tr>
                    <th class="ps-4">Mã PXK</th>
                    <th class="text-center">Đơn hàng</th>
                    <th>
                        <i class="bi bi-person me-1"></i>
                        Khách hàng
                    </th>
                    <th class="d-none d-lg-table-cell">
                        <i class="bi bi-geo-alt me-1"></i>
                        Địa chỉ giao
                    </th>
                    <th class="text-center" style="width: 140px;">
                        Trạng thái
                    </th>
                    <th class="d-none d-md-table-cell">
                        <i class="bi bi-calendar me-1"></i>
                        Ngày tạo
                    </th>
                    <th style="width: 100px;"></th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Data.Items.Any())
                {
                    foreach (var deliveryNote in Model.Data.Items)
                    {
                        var statusTuple = deliveryNote.Status switch
                        {
                            10 => ("secondary", "Bản nháp", "bi-pencil"),
                            20 => ("info text-white", "Đã xác nhận", "bi-check-all"),
                            30 => ("warning", "Đang giao", "bi-truck"),
                            40 => ("success", "Đã giao", "bi-check-circle-fill"),
                            50 => ("danger", "Đã hủy", "bi-x-circle"),
                            _ => ("secondary", "Không rõ", "bi-question-circle")
                        };

                        <tr>
                            <td class="ps-4">
                                <a asp-action="Details" asp-route-id="@deliveryNote.Id" class="text-decoration-none fw-bold">
                                    @HighlighHelper.Highlight(deliveryNote.Code, query)
                                </a>
                            </td>
                            <td class="text-center fw-medium">
                                <a asp-action="Details" asp-controller="Order" asp-route-id="@deliveryNote.OrderId" class="text-decoration-none">
                                    @deliveryNote.OrderCode
                                </a>
                            </td>
                            <td>
                                <div class="fw-bold">
                                    @HighlighHelper.Highlight(deliveryNote.CustomerName ?? "", query)
                                </div>
                                @if (!string.IsNullOrEmpty(deliveryNote.CustomerPhone))
                                {
                                    <a href="tel:@deliveryNote.CustomerPhone" class="small text-muted text-decoration-none">
                                        @HighlighHelper.Highlight(deliveryNote.CustomerPhone ?? "", query)
                                    </a>
                                }
                                <div class="d-md-none mt-1">
                                    <small class="text-muted d-block">
                                        <i class="bi bi-calendar me-1"></i>@deliveryNote.CreatedOnUtc.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
                                    </small>
                                </div>
                            </td>
                            <td class="d-none d-lg-table-cell">
                                <span class="d-inline-block text-truncate" style="max-width: 250px;" title="@deliveryNote.ShippingAddress">
                                    @deliveryNote.ShippingAddress
                                </span>
                            </td>
                            <td class="text-center">
                                <span class="status-badge @statusTuple.Item1 w-100">
                                    <i class="bi @statusTuple.Item3 me-1"></i>@deliveryNote.StatusName
                                </span>
                                @if (deliveryNote.Status == 40 && deliveryNote.DeliveredOnUtc.HasValue)
                                {
                                    <div class="small text-muted mt-1 fst-italic">@deliveryNote.DeliveredOnUtc.Value.ToLocalTime().ToString("dd/MM HH:mm")</div>
                                }
                            </td>
                            <td class="d-none d-md-table-cell text-muted">@deliveryNote.CreatedOnUtc.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                            <td>
                                <div class="dropdown position-static text-end pe-3">
                                    <button class="btn btn-sm btn-outline-secondary" type="button" id="dropdownMenuButton-@deliveryNote.Id" data-bs-toggle="dropdown" aria-expanded="false" data-bs-boundary="window">
                                        <i class="bi bi-three-dots"></i>
                                    </button>
                                    <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0" aria-labelledby="dropdownMenuButton-@deliveryNote.Id">
                                        <li><a class="dropdown-item py-2" asp-action="Details" asp-route-id="@deliveryNote.Id"><i class="bi bi-info-circle me-2 text-primary"></i>Chi tiết</a></li>
                                        <li><a class="dropdown-item py-2" asp-action="Print" asp-route-id="@deliveryNote.Id" target="_blank"><i class="bi bi-printer me-2 text-secondary"></i>In phiếu (2 bản)</a></li>
                                        @if (deliveryNote.Status == 10)
                                        {
                                            <li><hr class="dropdown-divider"></li>
                                            <li><a class="dropdown-item py-2 text-primary btn-confirm fw-medium" href="#" data-id="@deliveryNote.Id"><i class="bi bi-check-all me-2"></i>Xác nhận xuất</a></li>
                                        }
                                        @if (deliveryNote.Status == 20)
                                        {
                                            <li><hr class="dropdown-divider"></li>
                                            <li><a class="dropdown-item py-2 text-warning btn-delivering fw-medium" href="#" data-id="@deliveryNote.Id"><i class="bi bi-truck me-2"></i>Bắt đầu đi giao</a></li>
                                        }
                                        @if (deliveryNote.Status == 30 || deliveryNote.Status == 20)
                                        {
                                            <li><hr class="dropdown-divider"></li>
                                            <li><a class="dropdown-item py-2 text-success btn-delivered fw-medium" href="#" data-id="@deliveryNote.Id"><i class="bi bi-check-circle-fill me-2"></i>Xác nhận Đã giao</a></li>
                                        }
                                        @if (deliveryNote.Status != 40 && deliveryNote.Status != 50)
                                        {
                                            <li><hr class="dropdown-divider"></li>
                                            <li><a class="dropdown-item py-2 text-danger btn-cancel fw-medium" href="#" data-id="@deliveryNote.Id"><i class="bi bi-x-circle me-2"></i>Hủy phiếu</a></li>
                                        }
                                    </ul>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6">
                            <div class="empty-state">
                                <div class="empty-icon"><i class="bi bi-inbox"></i></div>
                                <h5>Không tìm thấy phiếu xuất kho nào</h5>
                                <p>Thử thay đổi từ khóa tìm kiếm hoặc tạo phiếu mới từ đơn hàng.</p>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (Model.Data.Pagination.TotalPages > 1)
    {
        <div class="card-footer bg-white border-top-0 d-flex justify-content-end p-3">
            <nav aria-label="Page navigation">
                <ul class="pagination mb-0">
                    <li class="page-item @(Model.Data.Pagination.PageNumber == 1 ? "disabled" : "")">
                        <a class="page-link" asp-action="List" asp-route-pageNumber="@(Model.Data.Pagination.PageNumber - 1)" asp-route-keywords="@Model.Keywords">Trước</a>
                    </li>
                    @for (int i = 1; i <= Model.Data.Pagination.TotalPages; i++)
                    {
                        <li class="page-item @(i == Model.Data.Pagination.PageNumber ? "active" : "")">
                            <a class="page-link" asp-action="List" asp-route-pageNumber="@i" asp-route-keywords="@Model.Keywords">@i</a>
                        </li>
                    }
                    <li class="page-item @(Model.Data.Pagination.PageNumber == Model.Data.Pagination.TotalPages ? "disabled" : "")">
                        <a class="page-link" asp-action="List" asp-route-pageNumber="@(Model.Data.Pagination.PageNumber + 1)" asp-route-keywords="@Model.Keywords">Sau</a>
                    </li>
                </ul>
            </nav>
        </div>
    }
</div>

<!-- Modal Mark Delivered (Bằng chứng) -->
<div class="modal fade" id="markDeliveredModal" tabindex="-1" aria-labelledby="markDeliveredModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <form id="markDeliveredForm" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <input type="hidden" id="deliveryNoteId" name="deliveryNoteId" />
            
            <div class="modal-content border-0 shadow rounded-4">
                <div class="modal-header border-0 pb-0">
                    <h5 class="modal-title fw-bold" id="markDeliveredModalLabel">Xác nhận giao hàng thành công</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body py-4">
                    <div class="alert alert-info border-0 rounded-3 mb-4">
                        Phiếu xuất này đã được giao đến tay khách hàng. Hãy chụp ảnh để xác nhận.
                    </div>
                    <div class="mb-3">
                        <label for="receiverName" class="form-label small fw-bold text-muted text-uppercase mb-2">Tên người nhận (Không bắt buộc)</label>
                        <input type="text" class="form-control form-control-lg rounded-3 fs-6" id="receiverName" name="receiverName" placeholder="Ví dụ: Anh Tâm">
                    </div>
                    <div class="mb-3">
                        <label for="deliveryProofPicture" class="form-label small fw-bold text-muted text-uppercase mb-2">Hình ảnh bằng chứng <span class="text-danger">*</span></label>
                        <input class="form-control form-control-lg rounded-3 fs-6" type="file" id="deliveryProofPicture" name="pictureFile" accept="image/*" capture="environment" required>
                        <div class="form-text mt-2 mb-0">Ví dụ: Chụp ảnh hàng hóa đã xếp lên cửa hàng, chữ ký người nhận. Bắt buộc chụp/tải ảnh lên!</div>
                    </div>
                    <div class="mt-3 text-center d-none" id="previewContainer">
                        <img id="imagePreview" src="#" alt="Preview" class="img-fluid rounded-4 shadow-sm" style="max-height: 250px; display: none; object-fit: cover; width: 100%; border: 1px solid var(--bs-border-color);" />
                    </div>
                </div>
                <div class="modal-footer border-0 pt-0 pb-4 px-4">
                    <button type="button" class="btn btn-light px-4 rounded-3" data-bs-dismiss="modal">Đóng</button>
                    <button type="submit" class="btn btn-success px-4 rounded-3 shadow-sm px-5" id="btnSubmitDelivery">
                        <i class="bi bi-camera me-1"></i> Xác nhận Đã giao
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            
            // Confirm
            $('.btn-confirm').click(function(e) {
                e.preventDefault();
                var id = $(this).data('id');
                if (confirm('Xác nhận phiếu xuất kho này?')) {
                    postAction('/DeliveryNote/Confirm/' + id);
                }
            });

            // Mark Delivering
            $('.btn-delivering').click(function(e) {
                e.preventDefault();
                var id = $(this).data('id');
                postAction('/DeliveryNote/MarkDelivering/' + id);
            });

            // Cancel
            $('.btn-cancel').click(function(e) {
                e.preventDefault();
                var id = $(this).data('id');
                if (confirm('Bạn có chắc chắn muốn hủy phiếu xuất này?')) {
                    postAction('/DeliveryNote/Cancel/' + id);
                }
            });

            // Mark Delivered Flow
            var markDeliveredModal = new bootstrap.Modal(document.getElementById('markDeliveredModal'));
            
            $('.btn-delivered').click(function(e) {
                e.preventDefault();
                var id = $(this).data('id');
                $('#deliveryNoteId').val(id);
                $('#deliveryProofPicture').val(''); // clear input
                $('#receiverName').val('');
                $('#previewContainer').addClass('d-none');
                $('#imagePreview').hide().attr('src', '#');
                markDeliveredModal.show();
            });

            // Image Preview inside Modal
            $("#deliveryProofPicture").change(function () {
                var input = this;
                if (input.files && input.files[0]) {
                    var reader = new FileReader();

                    reader.onload = function (e) {
                        $('#previewContainer').removeClass('d-none');
                        $('#imagePreview').attr('src', e.target.result).show();
                    }

                    reader.readAsDataURL(input.files[0]);
                } else {
                    $('#previewContainer').addClass('d-none');
                    $('#imagePreview').hide();
                }
            });

            // Form Submit for Delivery Proof
            $('#markDeliveredForm').submit(function(e) {
                e.preventDefault();
                var form = $(this)[0];
                var formData = new FormData(form);
                
                var actionUrl = '/DeliveryNote/MarkDelivered';
                
                var btn = $('#btnSubmitDelivery');
                var originalText = btn.html();
                btn.prop('disabled', true).html('<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span> Đang tải ảnh...');

                $.ajax({
                    url: actionUrl,
                    type: 'POST',
                    data: formData,
                    processData: false, // important
                    contentType: false, // important
                    success: function(res) {
                        if (res.success) {
                            alert(res.message);
                            location.reload();
                        } else {
                            alert("Lỗi: " + res.message);
                            btn.prop('disabled', false).html(originalText);
                        }
                    },
                    error: function(err) {
                        alert('Có lỗi hệ thống xảy ra.');
                        console.error(err);
                        btn.prop('disabled', false).html(originalText);
                    }
                });
            });

            function postAction(url) {
                $.ajax({
                    url: url,
                    type: 'POST',
                    data: {
                        __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                    },
                    success: function(res) {
                        if (res.success) {
                            location.reload();
                        } else {
                            alert(res.message);
                        }
                    },
                    error: function(err) {
                        alert("Lỗi hệ thống.");
                        console.error(err);
                    }
                });
            }
        });
    </script>
}
