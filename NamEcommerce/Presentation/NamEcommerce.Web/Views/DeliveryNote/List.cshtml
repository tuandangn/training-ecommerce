@model NamEcommerce.Web.Contracts.Models.DeliveryNotes.DeliveryNoteListModel
@using NamEcommerce.Web.Constants
@{
    ViewBag.PageTitle = "Danh sách phiếu xuất kho";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0 text-gray-800">Danh sách phiếu xuất kho</h1>
</div>

@if (TempData[ViewConstants.CustomerSuccessMessage] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData[ViewConstants.CustomerSuccessMessage]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData[ViewConstants.CustomerErrorMessage] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData[ViewConstants.CustomerErrorMessage]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="card shadow mb-4">
    <div class="card-header py-3 d-flex justify-content-between align-items-center">
        <h6 class="m-0 font-weight-bold text-primary">Danh sách</h6>
        <form class="d-flex" method="get" asp-action="List">
            <input class="form-control me-2" type="search" placeholder="Mã phiếu, Tên KH, SĐT" aria-label="Search" name="Keywords" value="@Model.Keywords">
            <button class="btn btn-outline-primary" type="submit">Tìm kiếm</button>
        </form>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-striped table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Mã PXK</th>
                        <th>Thời gian</th>
                        <th>Khách hàng</th>
                        <th>Địa chỉ giao</th>
                        <th>Trạng thái</th>
                        <th>Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Data.Items.Any())
                    {
                        foreach (var item in Model.Data.Items)
                        {
                            <tr>
                                <td>@item.Code</td>
                                <td>@item.CreatedOnUtc.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                                <td>
                                    @item.CustomerName <br />
                                    <small class="text-muted">@item.CustomerPhone</small>
                                </td>
                                <td>@item.ShippingAddress</td>
                                <td>
                                    @{
                                        string badgeClass = item.Status switch
                                        {
                                            10 => "bg-secondary", // Draft
                                            20 => "bg-info", // Confirmed
                                            30 => "bg-warning", // Delivering
                                            40 => "bg-success", // Delivered
                                            50 => "bg-danger", // Cancelled
                                            _ => "bg-secondary"
                                        };
                                    }
                                    <span class="badge @badgeClass">@item.StatusName</span>
                                    
                                    @if (item.Status == 40 && item.DeliveredOnUtc.HasValue)
                                    {
                                        <br/><small class="text-muted">Lúc: @item.DeliveredOnUtc.Value.ToLocalTime().ToString("dd/MM/yy HH:mm")</small>
                                    }
                                </td>
                                <td>
                                    <div class="dropdown">
                                        <button class="btn btn-sm btn-outline-secondary dropdown-toggle" type="button" id="dropdownMenuButton-@item.Id" data-bs-toggle="dropdown" aria-expanded="false">
                                            Tùy chọn
                                        </button>
                                        <ul class="dropdown-menu" aria-labelledby="dropdownMenuButton-@item.Id">
                                            <li><a class="dropdown-item" asp-action="Details" asp-route-id="@item.Id">Chi tiết</a></li>
                                            <li><a class="dropdown-item" asp-action="Print" asp-route-id="@item.Id" target="_blank">In phiếu (2 bản)</a></li>
                                            @if (item.Status == 10)
                                            {
                                                <li><hr class="dropdown-divider"></li>
                                                <li><a class="dropdown-item text-primary btn-confirm" href="#" data-id="@item.Id">Xác nhận xuất</a></li>
                                            }
                                            @if (item.Status == 20)
                                            {
                                                <li><hr class="dropdown-divider"></li>
                                                <li><a class="dropdown-item text-warning btn-delivering" href="#" data-id="@item.Id">Bắt đầu đi giao</a></li>
                                            }
                                            @if (item.Status == 30 || item.Status == 20)
                                            {
                                                <li><hr class="dropdown-divider"></li>
                                                <li><a class="dropdown-item text-success btn-delivered" href="#" data-id="@item.Id">Xác nhận Đã giao</a></li>
                                            }
                                            @if (item.Status != 40 && item.Status != 50)
                                            {
                                                <li><hr class="dropdown-divider"></li>
                                                <li><a class="dropdown-item text-danger btn-cancel" href="#" data-id="@item.Id">Hủy phiếu</a></li>
                                            }
                                        </ul>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center text-muted">Không có dữ liệu</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
    @if (Model.Data.Pagination.TotalPages > 1)
    {
        <div class="card-footer d-flex justify-content-end">
            <nav aria-label="Page navigation">
                <ul class="pagination mb-0">
                    <li class="page-item @(Model.Data.Pagination.PageNumber == 1 ? "disabled" : "")">
                        <a class="page-link" asp-action="List" asp-route-pageNumber="@(Model.Data.Pagination.PageNumber - 1)" asp-route-keywords="@Model.Keywords">Trước</a>
                    </li>
                    @for (int i = 1; i <= Model.Data.Pagination.TotalPages; i++)
                    {
                        <li class="page-item @(i == Model.Data.Pagination.PageNumber ? "active" : "")">
                            <a class="page-link" asp-action="List" asp-route-pageNumber="@i" asp-route-keywords="@Model.Keywords">@i</a>
                        </li>
                    }
                    <li class="page-item @(Model.Data.Pagination.PageNumber == Model.Data.Pagination.TotalPages ? "disabled" : "")">
                        <a class="page-link" asp-action="List" asp-route-pageNumber="@(Model.Data.Pagination.PageNumber + 1)" asp-route-keywords="@Model.Keywords">Sau</a>
                    </li>
                </ul>
            </nav>
        </div>
    }
</div>

<!-- Modal Mark Delivered (Bằng chứng) -->
<div class="modal fade" id="markDeliveredModal" tabindex="-1" aria-labelledby="markDeliveredModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <form id="markDeliveredForm" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <input type="hidden" id="deliveryNoteId" name="deliveryNoteId" />
            
            <div class="modal-content border-top-success">
                <div class="modal-header">
                    <h5 class="modal-title" id="markDeliveredModalLabel">Xác nhận giao hàng thành công</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="alert alert-info">
                        Phiếu xuất này đã được giao đến tay khách hàng. Hãy chụp ảnh để xác nhận.
                    </div>
                    <div class="mb-3">
                        <label for="receiverName" class="form-label">Tên người nhận (không bắt buộc)</label>
                        <input type="text" class="form-control" id="receiverName" name="receiverName" placeholder="Ví dụ: Anh Tâm">
                    </div>
                    <div class="mb-3">
                        <label for="deliveryProofPicture" class="form-label fw-bold">Hình ảnh bằng chứng <span class="text-danger">*</span></label>
                        <input class="form-control form-control-lg" type="file" id="deliveryProofPicture" name="pictureFile" accept="image/*" capture="environment" required>
                        <div class="form-text">Ví dụ: Chụp ảnh hàng hóa đã xếp lên cửa hàng, chữ ký người nhận. Bắt buộc chụp/tải ảnh lên!</div>
                    </div>
                    <div class="mt-3 text-center d-none" id="previewContainer">
                        <img id="imagePreview" src="#" alt="Preview" class="img-fluid rounded" style="max-height: 250px; display: none;" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
                    <button type="submit" class="btn btn-success" id="btnSubmitDelivery">
                        <i class="bi bi-camera"></i> Xác nhận Đã giao
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            
            // Confirm
            $('.btn-confirm').click(function(e) {
                e.preventDefault();
                var id = $(this).data('id');
                if (confirm('Xác nhận phiếu xuất kho này?')) {
                    postAction('/DeliveryNote/Confirm/' + id);
                }
            });

            // Mark Delivering
            $('.btn-delivering').click(function(e) {
                e.preventDefault();
                var id = $(this).data('id');
                postAction('/DeliveryNote/MarkDelivering/' + id);
            });

            // Cancel
            $('.btn-cancel').click(function(e) {
                e.preventDefault();
                var id = $(this).data('id');
                if (confirm('Bạn có chắc chắn muốn hủy phiếu xuất này?')) {
                    postAction('/DeliveryNote/Cancel/' + id);
                }
            });

            // Mark Delivered Flow
            var markDeliveredModal = new bootstrap.Modal(document.getElementById('markDeliveredModal'));
            
            $('.btn-delivered').click(function(e) {
                e.preventDefault();
                var id = $(this).data('id');
                $('#deliveryNoteId').val(id);
                $('#deliveryProofPicture').val(''); // clear input
                $('#receiverName').val('');
                $('#previewContainer').addClass('d-none');
                $('#imagePreview').hide().attr('src', '#');
                markDeliveredModal.show();
            });

            // Image Preview inside Modal
            $("#deliveryProofPicture").change(function () {
                var input = this;
                if (input.files && input.files[0]) {
                    var reader = new FileReader();

                    reader.onload = function (e) {
                        $('#previewContainer').removeClass('d-none');
                        $('#imagePreview').attr('src', e.target.result).show();
                    }

                    reader.readAsDataURL(input.files[0]);
                } else {
                    $('#previewContainer').addClass('d-none');
                    $('#imagePreview').hide();
                }
            });

            // Form Submit for Delivery Proof
            $('#markDeliveredForm').submit(function(e) {
                e.preventDefault();
                var form = $(this)[0];
                var formData = new FormData(form);
                
                var actionUrl = '/DeliveryNote/MarkDelivered';
                
                var btn = $('#btnSubmitDelivery');
                var originalText = btn.html();
                btn.prop('disabled', true).html('<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span> Đang tải ảnh...');

                $.ajax({
                    url: actionUrl,
                    type: 'POST',
                    data: formData,
                    processData: false, // important
                    contentType: false, // important
                    success: function(res) {
                        if (res.success) {
                            alert(res.message);
                            location.reload();
                        } else {
                            alert("Lỗi: " + res.message);
                            btn.prop('disabled', false).html(originalText);
                        }
                    },
                    error: function(err) {
                        alert('Có lỗi hệ thống xảy ra.');
                        console.error(err);
                        btn.prop('disabled', false).html(originalText);
                    }
                });
            });

            function postAction(url) {
                $.ajax({
                    url: url,
                    type: 'POST',
                    data: {
                        __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                    },
                    success: function(res) {
                        if (res.success) {
                            location.reload();
                        } else {
                            alert(res.message);
                        }
                    },
                    error: function(err) {
                        alert("Lỗi hệ thống.");
                        console.error(err);
                    }
                });
            }
        });
    </script>
}
