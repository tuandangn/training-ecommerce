@model UnitMeasurementListSearchModel

<form asp-action="List" method="get" class="d-flex flex-wrap gap-2">
    <div class="search-group">
        <div class="search-input-group">
            <i class="bi bi-search text-muted"></i>
            <input type="text" asp-for="Keywords" class="form-control" placeholder="Tìm kiếm đơn vị tính..." />
        </div>
        @if (!string.IsNullOrEmpty(Model.Keywords))
        {
            <a asp-action="List" class="btn btn-outline-secondary" title="Xóa tìm kiếm">
                <i class="bi bi-x-lg"></i>
            </a>
        }
        <button class="btn btn-primary" type="submit">Tìm kiếm</button>
    </div>
</form>