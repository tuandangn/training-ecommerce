@model CreateWarehouseModel
@{
    ViewData[ViewConstants.PageTitle] = "Thêm mới Nhà kho";
}
<section class="content-title my-4 text-center">
    <h1>
        Thêm mới
        <a asp-action="List" class="text-muted d-block fs-3 ps-2 text-decoration-none">Nhà kho</a>
    </h1>
</section>
<section class="content-data">
    <div>
        <div class="p-4 shadow border roundedoffset-lg-3 col-lg-6 offset-md-2 col-md-8">
            <div class="d-flex justify-content-end mb-2">
                <a asp-action="List" class="text-muted small text-decoration-none">
                    <i class="bi bi-arrow-90deg-left"></i>
                    Trở lại
                </a>
            </div>
            <div asp-validation-summary="ModelOnly" class="alert alert-warning"></div>
            <form class="row g-3" method="post" asp-antiforgery="true">
                <ul class="nav nav-tabs" id="warehouseTabs" role="tablist">
                    <li class="nav-item" role="presentation">
                        <button class="nav-link active" id="infoTab" data-bs-toggle="tab" data-bs-target="#info" type="button" role="tab" aria-controls="info" aria-selected="true">
                            Thông tin
                        </button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link" id="additionalTab" data-bs-toggle="tab" data-bs-target="#additional" type="button" role="tab" aria-controls="additional" aria-selected="false">
                            Cài đặt
                        </button>
                    </li>
                </ul>
                <div class="tab-content" id="warehouseContent">
                    <div class="tab-pane fade show active" id="info" role="tabpanel" aria-labelledby="infoTab">
                        <div class="row">
                            <div class="col-6 col-lg-9 col-md-8 mb-3">
                                <label asp-for="Name" class="form-label"></label>
                                <input asp-for="Name" class="form-control" placeholder="@Html.DisplayNameFor(m => m.Name)" autofocus />
                                <span asp-validation-for="Name" class="text-danger small"></span>
                            </div>
                            <div class="col-6 col-lg-3 col-md-4 mb-3">
                                <label asp-for="Code" class="form-label"></label>
                                <input asp-for="Code" class="form-control" placeholder="@Html.DisplayNameFor(m => m.Code)" />
                                <span asp-validation-for="Code" class="text-danger small"></span>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-6 col-lg-8 mb-3">
                                <label asp-for="Address" class="form-label"></label>
                                <input asp-for="Address" class="form-control" placeholder="@Html.DisplayNameFor(m => m.Address)" />
                                <span asp-validation-for="Address" class="text-danger small"></span>
                            </div>
                            <div class="col-6 col-lg-4 mb-3">
                                <label asp-for="PhoneNumber" class="form-label"></label>
                                <input asp-for="PhoneNumber" class="form-control" placeholder="@Html.DisplayNameFor(m => m.PhoneNumber)" />
                                <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                            </div>
                        </div>
                        <div class="col-12 mb-3">
                            <label asp-for="WarehouseType" class="form-label"></label>
                            <select asp-for="WarehouseType" class="form-select" placeholder="@Html.DisplayNameFor(m => m.WarehouseType)">
                                @if (Model.AvailableWarehouseTypes is not null)
                                {
                                    foreach (var warehouseType in Model.AvailableWarehouseTypes)
                                    {
                                        <option value="@warehouseType.Value" selected="@(warehouseType.Value == Model.WarehouseType.ToString())">
                                            @warehouseType.Text
                                        </option>
                                    }
                                }
                            </select>
                            <span asp-validation-for="WarehouseType" class="text-danger small"></span>
                        </div>
                    </div>
                    <div class="tab-pane fade" id="additional" role="tabpanel" aria-labelledby="additionalTab">
                        <div class="col-12 mb-3">
                            <label asp-for="IsActive" class="form-label visually-hidden"></label>
                            <div class="form-check form-switch">
                                <input asp-for="IsActive" class="form-check-input" role="switch" />
                                <label class="form-check-label" asp-for="IsActive">@Html.DisplayNameFor(m => m.IsActive)</label>
                            </div>
                            <span asp-validation-for="IsActive" class="text-danger small"></span>
                        </div>
                    </div>
                </div>
                <div class="col-12">
                    <button type="submit" class="btn btn-primary">Thêm mới</button>
                </div>
            </form>
        </div>
    </div>
</section>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}