@model CreateWarehouseModel
@{
    ViewData[ViewConstants.PageTitle] = "Thêm mới Kho hàng";
}

<div class="page-header">
    <div>
        <h1 class="page-header-title">Thêm mới Kho hàng</h1>
        <p class="page-header-subtitle">Tạo kho hàng mới để lưu trữ hàng hóa</p>
    </div>
</div>

<div class="form-card">
    <div class="form-card-header">
        <h2 class="form-card-title"><i class="bi bi-geo-alt me-2" style="color: var(--info);"></i>Thông tin kho hàng</h2>
        <a asp-action="List" class="form-card-breadcrumb">
            <i class="bi bi-arrow-left"></i> Trở về danh sách
        </a>
    </div>
    <div class="form-card-body">
        <div asp-validation-summary="ModelOnly" class="alert alert-warning alert-global"></div>
        <form class="row g-3" method="post" asp-antiforgery="true">
            <ul class="nav nav-tabs" id="warehouseTabs" role="tablist">
                <li class="nav-item" role="presentation">
                    <button class="nav-link active" id="infoTab" data-bs-toggle="tab" data-bs-target="#info"
                            type="button" role="tab" aria-selected="true">
                        <i class="bi bi-info-circle me-1"></i>Thông tin
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" id="additionalTab" data-bs-toggle="tab" data-bs-target="#additional"
                            type="button" role="tab" aria-selected="false">
                        <i class="bi bi-sliders me-1"></i>Cài đặt
                    </button>
                </li>
            </ul>
            <div class="tab-content pt-3" id="warehouseContent">
                <div class="tab-pane fade show active" id="info" role="tabpanel">
                    <div class="row g-3">
                        <div class="col-sm-9">
                            <label asp-for="Name" class="form-label"></label>
                            <input asp-for="Name" class="form-control" placeholder="@Html.DisplayNameFor(m => m.Name)" autofocus />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>
                        <div class="col-sm-3">
                            <label asp-for="Code" class="form-label"></label>
                            <input asp-for="Code" class="form-control" placeholder="KH01" />
                            <span asp-validation-for="Code" class="text-danger small"></span>
                        </div>
                        <div class="col-md-8">
                            <label asp-for="Address" class="form-label"></label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-geo-alt text-muted"></i></span>
                                <input asp-for="Address" class="form-control" placeholder="@Html.DisplayNameFor(m => m.Address)" />
                            </div>
                            <span asp-validation-for="Address" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="PhoneNumber" class="form-label"></label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-telephone text-muted"></i></span>
                                <input asp-for="PhoneNumber" class="form-control" placeholder="@Html.DisplayNameFor(m => m.PhoneNumber)" />
                            </div>
                            <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="WarehouseType" class="form-label"></label>
                            <select asp-for="WarehouseType" class="form-select">
                                @if (Model.AvailableWarehouseTypes is not null)
                                {
                                    foreach (var warehouseType in Model.AvailableWarehouseTypes)
                                    {
                                        <option value="@warehouseType.Value" selected="@(warehouseType.Value == Model.WarehouseType.ToString())">
                                            @warehouseType.Text
                                        </option>
                                    }
                                }
                            </select>
                            <span asp-validation-for="WarehouseType" class="text-danger small"></span>
                        </div>
                    </div>
                </div>
                <div class="tab-pane fade" id="additional" role="tabpanel">
                    <div class="row g-3">
                        <div class="col-12">
                            <div class="form-check form-switch">
                                <input asp-for="IsActive" class="form-check-input" role="switch" />
                                <label class="form-check-label fw-medium" asp-for="IsActive">@Html.DisplayNameFor(m => m.IsActive)</label>
                            </div>
                            <span asp-validation-for="IsActive" class="text-danger small"></span>
                        </div>
                    </div>
                </div>
            </div>
            <div class="form-card-footer" style="margin: 0 -1.5rem -1.5rem; border-radius: 0 0 var(--card-radius) var(--card-radius);">
                <a asp-action="List" class="btn btn-outline-secondary">Hủy</a>
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-plus-lg me-1"></i>Thêm mới
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}