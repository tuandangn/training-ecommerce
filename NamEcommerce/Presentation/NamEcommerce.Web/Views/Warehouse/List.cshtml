@using System.Text.Encodings.Web
@inject UrlEncoder MyUrlEncoder
@model WarehouseListModel
@{
    ViewData[ViewConstants.PageTitle] = "Kho hàng";
    var successMessage = TempData[ViewConstants.WarehouseSuccessMessage] as string;
    var errorMessage = TempData[ViewConstants.WarehouseErrorMessage] as string;
    string? query = Model.Keywords;
}

<div class="page-header">
    <div>
        <h1 class="page-header-title">Kho hàng</h1>
        <p class="page-header-subtitle">Quản lý các vị trí lưu trữ hàng hóa</p>
    </div>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-lg me-1"></i>Thêm mới
    </a>
</div>

@if (!string.IsNullOrEmpty(successMessage))
{
    <div class="alert alert-success alert-dismissible fade show alert-global mb-3" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i>@successMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-warning alert-dismissible fade show alert-global mb-3" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-2"></i>@errorMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="content-card">
    <div class="action-toolbar">
        <partial name="_Search" model="@(new WarehouseListSearchModel { Keywords = Model.Keywords })" />
    </div>

    <div class="table-responsive">
        <table class="table data-table">
            <thead>
                <tr>
                    <th class="ps-4">Kho hàng</th>
                    <th><i class="bi bi-phone me-1"></i>Điện thoại</th>
                    <th class="d-none d-md-table-cell"><i class="bi bi-map me-1"></i>Địa chỉ</th>
                    <th class="text-center" style="width: 110px;">Trạng thái</th>
                    <th style="width: 100px;"></th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Data.Pagination.TotalCount > 0)
                {
                    @foreach (var item in Model.Data)
                    {
                        <tr>
                            <td class="ps-4">
                                <div class="fw-medium">@HighlighHelper.Highlight(item.Name, query)</div>
                                <div class="text-muted small">@item.Code</div>
                            </td>
                            <td>
                                @if (!string.IsNullOrEmpty(item.PhoneNumber))
                                {
                                    <a href="tel:@item.PhoneNumber" class="text-decoration-none text-muted">
                                        <i class="bi bi-telephone me-1"></i>@item.PhoneNumber
                                    </a>
                                }
                            </td>
                            <td class="d-none d-md-table-cell">
                                @if (!string.IsNullOrEmpty(item.Address))
                                {
                                    var encodedAddress = MyUrlEncoder.Encode(item.Address);
                                    <a href="https://www.google.com/maps/search/@encodedAddress" target="_blank"
                                       class="text-decoration-none text-muted small">
                                        <i class="bi bi-geo-alt me-1"></i>@HighlighHelper.Highlight(item.Address, query)
                                    </a>
                                }
                            </td>
                            <td class="text-center">
                                @if (item.IsActive)
                                {
                                    <span class="status-badge success"><i class="bi bi-check-circle"></i>Hoạt động</span>
                                }
                                else
                                {
                                    <span class="status-badge secondary"><i class="bi bi-dash-circle"></i>Ngừng</span>
                                }
                            </td>
                            <td class="text-end pe-3">
                                <a class="btn-table-action me-1" asp-action="Edit" asp-route-id="@item.Id" title="Chỉnh sửa">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <button type="button" class="btn-table-action danger btnDelete"
                                        data-id="@item.Id" data-name="@item.Name" title="Xóa">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="5">
                            <div class="empty-state">
                                <div class="empty-icon"><i class="bi bi-geo-alt"></i></div>
                                <h5>Chưa có kho hàng nào</h5>
                                <p>Tạo kho hàng để quản lý vị trí lưu trữ.</p>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (Model.Data.Pagination.TotalCount > 0)
    {
        <partial name="_Pager" model="Model.Data.Pagination" />
    }
</div>

@foreach (var item in Model.Data)
{
    <partial name="_DeleteForm" model="@item.Id" />
}

@section Scripts {
    <script type="module" defer>
        import { confirm } from "/modules/modals.js";
        (function () {
            $('.btnDelete').on('click', async function (e) {
                e.preventDefault();
                const name = $(this).data('name');
                $(this).prop('disabled', true);
                const confirmed = await confirm('Xóa kho hàng', `Bạn muốn xóa kho hàng <strong>${name}</strong>?`);
                if (!confirmed) { $(this).prop('disabled', false); return; }
                $(`#deleteForm${$(this).data('id')}`).submit();
            });
        })();
    </script>
}
