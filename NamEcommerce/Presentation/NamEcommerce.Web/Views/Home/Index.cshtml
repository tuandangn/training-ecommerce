@{
    ViewData["Title"] = "Trang chủ";
}
@section TitleSection {
    <h1 class="topbar-page-title">Dashboard</h1>
}
<div class="py-2">
    <div class="row g-3 mb-4">
        <div class="col-6 col-md-4 col-lg-3">
            <a asp-controller="Order" asp-action="List" class="content-card d-block text-decoration-none hover-lift p-3 text-center">
                <div class="mb-2" style="color: var(--primary); font-size: 2rem;"><i class="bi bi-receipt-cutoff"></i></div>
                <div class="fw-semibold" style="color: var(--gray-800);">Đơn hàng</div>
                <div class="text-muted small">Quản lý bán hàng</div>
            </a>
        </div>
        <div class="col-6 col-md-4 col-lg-3">
            <a asp-controller="PurchaseOrder" asp-action="List" class="content-card d-block text-decoration-none hover-lift p-3 text-center">
                <div class="mb-2" style="color: #0284c7; font-size: 2rem;"><i class="bi bi-truck"></i></div>
                <div class="fw-semibold" style="color: var(--gray-800);">Đơn nhập</div>
                <div class="text-muted small">Nhập hàng từ NCC</div>
            </a>
        </div>
        <div class="col-6 col-md-4 col-lg-3">
            <a asp-controller="Inventory" asp-action="StockList" class="content-card d-block text-decoration-none hover-lift p-3 text-center">
                <div class="mb-2" style="color: #059669; font-size: 2rem;"><i class="bi bi-boxes"></i></div>
                <div class="fw-semibold" style="color: var(--gray-800);">Tồn kho</div>
                <div class="text-muted small">Theo dõi kho hàng</div>
            </a>
        </div>
        <div class="col-6 col-md-4 col-lg-3">
            <a asp-controller="Product" asp-action="Index" class="content-card d-block text-decoration-none hover-lift p-3 text-center">
                <div class="mb-2" style="color: #d97706; font-size: 2rem;"><i class="bi bi-tags"></i></div>
                <div class="fw-semibold" style="color: var(--gray-800);">Hàng hóa</div>
                <div class="text-muted small">Danh mục sản phẩm</div>
            </a>
        </div>
        <div class="col-6 col-md-4 col-lg-3">
            <a asp-controller="Customer" asp-action="List" class="content-card d-block text-decoration-none hover-lift p-3 text-center">
                <div class="mb-2" style="color: #7c3aed; font-size: 2rem;"><i class="bi bi-people"></i></div>
                <div class="fw-semibold" style="color: var(--gray-800);">Khách hàng</div>
                <div class="text-muted small">CRM đơn giản</div>
            </a>
        </div>
        <div class="col-6 col-md-4 col-lg-3">
            <a asp-controller="Vendor" asp-action="Index" class="content-card d-block text-decoration-none hover-lift p-3 text-center">
                <div class="mb-2" style="color: #dc2626; font-size: 2rem;"><i class="bi bi-building"></i></div>
                <div class="fw-semibold" style="color: var(--gray-800);">Nhà cung cấp</div>
                <div class="text-muted small">Quản lý đối tác</div>
            </a>
        </div>
        <div class="col-6 col-md-4 col-lg-3">
            <a asp-controller="Warehouse" asp-action="Index" class="content-card d-block text-decoration-none hover-lift p-3 text-center">
                <div class="mb-2" style="color: #0891b2; font-size: 2rem;"><i class="bi bi-geo-alt"></i></div>
                <div class="fw-semibold" style="color: var(--gray-800);">Kho hàng</div>
                <div class="text-muted small">Vị trí lưu trữ</div>
            </a>
        </div>
        <div class="col-6 col-md-4 col-lg-3">
            <a asp-controller="Category" asp-action="Index" class="content-card d-block text-decoration-none hover-lift p-3 text-center">
                <div class="mb-2" style="color: #16a34a; font-size: 2rem;"><i class="bi bi-grid"></i></div>
                <div class="fw-semibold" style="color: var(--gray-800);">Danh mục</div>
                <div class="text-muted small">Phân loại hàng hóa</div>
            </a>
        </div>
    </div>
</div>
