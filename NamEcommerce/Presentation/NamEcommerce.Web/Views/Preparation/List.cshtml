@{
    ViewData[ViewConstants.PageTitle] = "Chuẩn bị hàng";
}

<div class="page-header">
    <div>
        <h1 class="page-header-title">Chuẩn bị hàng</h1>
        <p class="page-header-subtitle">Danh sách hàng hóa cần chuẩn bị từ đơn hàng chưa khóa</p>
    </div>
</div>

<div id="alertArea"></div>

@switch (Model)
{
    case ProductPreparationListModel:
        <partial name="List.Product" model="Model"/>
        break;
    case CustomerPreparationListModel:
        <partial name="List.Customer" model="Model"/>
        break;
}

<div class="modal fade" id="deliveryProofModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow rounded-4">
            <div class="modal-header border-bottom-0 pb-0">
                <h5 class="modal-title fw-bold">Xác nhận giao hàng</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body py-4">
                <div class="alert alert-info border-0 rounded-3 mb-4">
                    Vui lòng tải lên hình ảnh biên nhận hoặc hình ảnh đã giao hàng cho <strong id="proofProductName" class="text-dark"></strong>.
                </div>
                <form id="deliveryProofForm">
                    <input type="hidden" id="proofOrderId" name="orderId" />
                    <input type="hidden" id="proofOrderItemId" name="orderItemId" />
                    
                    <div class="mb-3">
                        <label class="form-label small fw-bold text-muted text-uppercase mb-2">Hình ảnh bằng chứng <span class="text-danger">*</span></label>
                        <input type="file" class="form-control form-control-lg rounded-3 fs-6" id="proofImage" name="proofImage" accept="image/*" capture="environment" required />
                        <div class="form-text mt-2">Bạn có thể chụp ảnh trực tiếp từ điện thoại.</div>
                    </div>
                    
                    <div class="text-center d-none" id="proofPreviewContainer">
                        <img id="proofPreview" src="#" alt="Bản xem trước" class="img-fluid rounded-4 shadow-sm mt-2 mb-0" style="max-height: 200px; object-fit: cover; width: 100%; border: 1px solid var(--bs-border-color);" />
                    </div>
                </form>
            </div>
            <div class="modal-footer border-top-0 pt-0 pb-4 px-4">
                <button type="button" class="btn btn-light px-4 rounded-3" data-bs-dismiss="modal">Hủy</button>
                <button type="button" class="btn btn-primary px-4 rounded-3 shadow-sm px-4" id="btnSubmitProof">
                    <i class="bi bi-check2-circle me-1"></i>Xác nhận đã giao
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script type="module" defer>
        import { confirm } from "/modules/modals.js";
        (function () {
            const deliveryProofModal = new bootstrap.Modal(document.getElementById('deliveryProofModal'));
            let currentBtn = null;

            // Handle file input change for preview
            $('#proofImage').on('change', function() {
                const file = this.files[0];
                if (file) {
                    const reader = new FileReader();
                    reader.onload = function(e) {
                        $('#proofPreview').attr('src', e.target.result);
                        $('#proofPreviewContainer').removeClass('d-none');
                    }
                    reader.readAsDataURL(file);
                } else {
                    $('#proofPreviewContainer').addClass('d-none');
                }
            });

            $(document).on('click', '.btnMarkDelivered', function (e) {
                e.preventDefault();
                currentBtn = $(this);
                
                // Populate modal
                $('#proofOrderId').val(currentBtn.data('order-id'));
                $('#proofOrderItemId').val(currentBtn.data('order-item-id'));
                $('#proofProductName').text(currentBtn.data('product-name'));
                
                // Reset form
                $('#deliveryProofForm')[0].reset();
                $('#proofPreviewContainer').addClass('d-none');
                
                deliveryProofModal.show();
            });

            $('#btnSubmitProof').on('click', async function () {
                const form = $('#deliveryProofForm')[0];
                if (!form.checkValidity()) {
                    form.reportValidity();
                    return;
                }

                const btn = $('#btnSubmitProof');
                const orderItemId = $('#proofOrderItemId').val();
                
                btn.prop('disabled', true);
                btn.html('<span class="spinner-border spinner-border-sm me-1"></span>Đang xử lý...');

                const formData = new FormData(form);

                try {
                    const response = await $.ajax({
                        url: '@Url.Action("MarkDelivered", "Preparation")',
                        type: 'POST',
                        data: formData,
                        processData: false,
                        contentType: false
                    });

                    if (response.success) {
                        deliveryProofModal.hide();
                        const row = $(`#row-${orderItemId}`);
                        row.addClass('table-success opacity-75');
                        // Update status badge
                        row.find('.status-cell').html(
                            '<span class="status-badge success"><i class="bi bi-check-circle-fill"></i>Đã giao</span>'
                        );
                        // Remove button
                        currentBtn.closest('td').html('');

                        // Show success
                        showAlert('success', response.message);
                    } else {
                        showAlert('danger', response.message || 'Có lỗi xảy ra.');
                    }
                } catch (err) {
                    showAlert('danger', 'Có lỗi xảy ra trong quá trình tải ảnh lên. Vui lòng thử lại.');
                } finally {
                    btn.prop('disabled', false);
                    btn.html('<i class="bi bi-check2-circle me-1"></i>Xác nhận đã giao');
                }
            });

            function showAlert(type, message) {
                const alertHtml = `
                    <div class="alert alert-${type} alert-dismissible fade show alert-global mb-3" role="alert">
                        <i class="bi bi-${type === 'success' ? 'check-circle-fill' : 'exclamation-triangle-fill'} me-2"></i>
                        ${message}
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>`;
                $('#alertArea').html(alertHtml);
                setTimeout(() => { $('#alertArea .alert').alert('close'); }, 5000);
            }
        })();
    </script>
}
