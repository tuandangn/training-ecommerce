@using NamEcommerce.Domain.Shared.Enums.DeliveryNotes
@model CustomerPreparationListModel

<div class="content-card mb-4 p-2">
    <div class="d-flex align-items-center justify-content-between">
        <div class="d-flex align-items-center gap-2 px-2">
            <span class="small text-muted text-uppercase fw-bold"><i class="bi bi-funnel me-1"></i>Chế độ hiển thị</span>
        </div>
        <div class="btn-group" role="group">
            <a asp-action="List" asp-route-grouped="false" class="btn btn-primary active">
                <i class="bi bi-person-lines-fill me-1"></i>
                Theo khách hàng
            </a>
            <a asp-action="List" asp-route-grouped="true" class="btn btn-outline-primary">
                <i class="bi bi-box-seam me-1"></i>
                Theo hàng hóa
            </a>
        </div>
    </div>
</div>

@{
    var hasRemainingQuantities = Model.Items.Any(item => item.RemainingQuantity > 0);
}
<div class="content-card">
    <div class="table-responsive">
        <table class="table data-table">
            <thead>
                <tr>
                    @if (hasRemainingQuantities)
                    {
                        <th style="width:40px;" class="text-center">
                            <input type="checkbox" class="select-all-customers" />
                        </th>
                    }
                    <th class="@(hasRemainingQuantities ? "" : "ps-3")">
                        Sản phẩm
                    </th>
                    <th class="text-end">Số lượng</th>
                    <th class="d-none d-md-table-cell">Khách hàng</th>
                    <th class="text-center d-none d-sm-table-cell">Ngày dự kiến</th>
                    <th>Mã đơn</th>
                    <th class="text-center">Trạng thái</th>
                    <th class="text-end pe-3"></th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Any())
                {
                    @foreach (var item in Model.Items)
                    {
                        var rowClass = item.IsDelivered ? "table-success opacity-75" : "";
                        var isOverdue = item.ExpectedShippingDate.HasValue && item.ExpectedShippingDate.Value.Date <= DateTime.Now.Date && !item.IsDelivered;
                        <tr class="@rowClass" id="row-@item.OrderItemId">
                            <td class="align-middle text-center" style="width:40px;">
                                @if (item.RemainingQuantity > 0)
                                {
                                    <input type="checkbox" class="select-prep-item"
                                           data-order-id="@item.OrderId"
                                           data-order-code="@item.OrderCode"
                                           data-order-item-id="@item.OrderItemId"
                                           data-quantity="@item.Quantity"
                                           data-delivered-quantity="@item.DeliveredQuantity"
                                           data-product-name="@item.ProductName"
                                           data-stock="@item.StockQuantityAvailable"
                                           data-unit-price="@item.UnitPrice" />
                                }
                            </td>
                            <td class="@(Model.Items.Any(item => !item.IsDelivered) ? "" : "ps-3")">
                                <span class="fw-bold text-dark">@item.ProductName</span>
                            </td>
                            <td class="text-end">
                                <div class="fw-bold fs-6">
                                    <span class="text-muted small">@item.DeliveredQuantity.DisplayQuantity() /</span> @item.Quantity.DisplayQuantity()
                                </div>
                                <div class="small text-muted" title="Tồn kho">
                                    <i class="bi bi-box-seam me-1"></i>@item.StockQuantityAvailable.DisplayQuantity()
                                </div>
                            </td>
                            <td class="d-none d-md-table-cell">
                                <div class="fw-bold">
                                    <i class="bi bi-person text-muted me-1"></i>@item.CustomerName
                                </div>
                                @if (!string.IsNullOrEmpty(item.CustomerPhone))
                                {
                                    <a href="tel:@item.CustomerPhone" class="text-muted small text-decoration-none">
                                        <i class="bi bi-telephone ms-1 me-1"></i>@item.CustomerPhone
                                    </a>
                                }
                            </td>
                            <td class="text-center d-none d-sm-table-cell">
                                @if (item.ExpectedShippingDate.HasValue)
                                {
                                    <span class="@(isOverdue ? "text-danger fw-bold" : "text-muted")">
                                        @if (isOverdue)
                                        {
                                            <i class="bi bi-exclamation-triangle-fill me-1"></i>
                                        }
                                        @item.ExpectedShippingDate.Value.ToString(ViewConstants.DefaultDateFormat)
                                    </span>
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }
                            </td>
                            <td>
                                <div class="d-flex flex-column gap-1">
                                    <a asp-controller="Order" asp-action="Details" asp-route-id="@item.OrderId"
                                           class="text-primary fw-bold text-decoration-none">
                                        @item.OrderCode
                                    </a>
                                    @if (item.DeliveryNoteLinks.Any())
                                    {
                                        <div class="dropdown">
                                            <button class="btn btn-xs btn-outline-info dropdown-toggle py-0 px-2 small" type="button" data-bs-toggle="dropdown" aria-expanded="false" style="font-size: 0.75rem;">
                                                <i class="bi bi-file-earmark-text me-1"></i>PXK (@item.DeliveryNoteLinks.Count)
                                            </button>
                                            <ul class="dropdown-menu shadow-sm border-0 py-1" style="min-width: 180px;">
                                                @foreach (var link in item.DeliveryNoteLinks)
                                                {
                                                    var statusTuple = (DeliveryNoteStatus)link.Status switch
                                                    {
                                                        DeliveryNoteStatus.Draft => ("secondary", "Bản nháp"),
                                                        DeliveryNoteStatus.Confirmed => ("info text-white", "Đã xác nhận"),
                                                        DeliveryNoteStatus.Delivering => ("warning", "Đang giao"),
                                                        DeliveryNoteStatus.Delivered => ("success", "Đã giao"),
                                                        DeliveryNoteStatus.Cancelled => ("danger", "Đã hủy"),
                                                        _ => ("secondary", "Không rõ")
                                                    };
                                                    <li>
                                                        <a class="dropdown-item d-flex align-items-center justify-content-between gap-2 py-1 px-3" asp-controller="DeliveryNote" asp-action="Details" asp-route-id="@link.Id">
                                                            <span class="small fw-medium">@link.Code</span>
                                                            <span class="badge bg-@statusTuple.Item1" style="font-size: 0.65rem;">@statusTuple.Item2</span>
                                                        </a>
                                                    </li>
                                                }
                                            </ul>
                                        </div>
                                    }
                                </div>
                            </td>
                            <td class="text-center status-cell">
                                @if (item.IsDelivered)
                                {
                                    <span class="status-badge success">
                                        <i class="bi bi-check-circle-fill"></i>Đã giao
                                    </span>
                                }
                                else
                                {
                                    <span class="status-badge warning">
                                        <i class="bi bi-clock"></i>Chờ giao
                                    </span>
                                }
                            </td>
                            <td class="text-end pe-3 align-middle">
                                @if (!item.IsDelivered)
                                {
                                    <div class="d-flex flex-column gap-1">
                                        <button class="btn btn-sm btn-outline-success btnMarkDelivered w-100"
                                                data-order-id="@item.OrderId"
                                                data-order-item-id="@item.OrderItemId"
                                                data-product-name="@item.ProductName"
                                                title="Đánh dấu đã giao">
                                            <i class="bi bi-check2-circle d-md-none"></i>
                                            <span class="d-none d-md-inline"><i class="bi bi-check-lg me-1"></i>Đã giao</span>
                                        </button>
                                        @if (item.StockQuantityAvailable < item.RemainingQuantity)
                                        {
                                            var itemShortage = item.RemainingQuantity - item.StockQuantityAvailable;
                                            <button class="btn btn-sm btn-warning btnQuickCreatePurchaseOrder w-100"
                                                    data-product-id="@item.ProductId"
                                                    data-product-name="@item.ProductName"
                                                    data-shortage-quantity="@itemShortage"
                                                    title="Tồn kho không đủ — tạo đơn nhập hàng nhanh">
                                                <i class="bi bi-cart-plus d-md-none"></i>
                                                <span class="d-none d-md-inline"><i class="bi bi-cart-plus me-1"></i>Nhập hàng</span>
                                            </button>
                                        }
                                    </div>
                                }
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="@(hasRemainingQuantities ? 7 : 6)">
                            <div class="empty-state">
                                <div class="empty-icon"><i class="bi bi-person-lines-fill"></i></div>
                                <h5>Không có dữ liệu</h5>
                                <p>Không tìm thấy hàng hóa nào cần chuẩn bị.</p>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    
    @if (Model.Items.Pagination.TotalCount > 0)
    {
        <partial name="_Pager" model="Model.Items.Pagination" />
    }
</div>