@model CustomerPreparationListModel
<div class="card border-0 shadow-sm rounded-4 mb-4">
    <div class="card-body p-3 d-flex align-items-center justify-content-end gap-3">
        <div class="d-flex align-items-center gap-2">
            @* <i class="bi bi-funnel text-muted"></i> *@
            <span class="small text-muted">Hiển thị</span>
        </div>
        <div class="btn-group" role="group">
            <a asp-action="List" asp-route-grouped="false"
                   class="btn btn-sm btn-primary rounded-start-3">
                <i class="bi bi-list-ul me-1"></i>
                Theo khách hàng
            </a>
            <a asp-action="List" asp-route-grouped="true"
                   class="btn btn-sm btn-outline-primary rounded-end-3">
                <i class="bi bi-collection me-1"></i>
                Theo hàng hóa
            </a>
        </div>
    </div>
</div>
<div class="card border-0 shadow-sm rounded-4 overflow-hidden">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light text-muted">
                    <tr>
                        <th class="ps-3">Sản phẩm</th>
                        <th class="text-end">Số lượng</th>
                        <th>Khách hàng</th>
                        <th class="text-center">Ngày giao</th>
                        <th>Đơn hàng</th>
                        <th class="text-center">Trạng thái</th>
                        <th class="text-end pe-3"></th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Any())
                    {
                        @foreach (var item in Model.Items)
                        {
                            var rowClass = item.IsDelivered ? "table-success opacity-75" : "";
                            var isOverdue = item.ExpectedShippingDate.HasValue && item.ExpectedShippingDate.Value.Date <= DateTime.Now.Date && !item.IsDelivered;
                            <tr class="@rowClass" id="row-@item.OrderItemId">
                                <td class="ps-3">
                                    <span class="fw-600">@item.ProductName</span>
                                </td>
                                <td class="text-end text-nowrap fw-600">
                                    @item.Quantity.ToString(ViewConstants.NumberCustomFormat)
                                </td>
                                <td>
                                    <div class="fw-600 text-nowrap">
                                        <i class="bi bi-person"></i>
                                        @item.CustomerName
                                    </div>
                                    @if (!string.IsNullOrEmpty(item.CustomerPhone))
                                    {
                                        <a href="tel:@item.CustomerPhone" class="text-muted small text-decoration-none text-nowrap">
                                            <i class="bi bi-telephone me-1"></i>@item.CustomerPhone
                                        </a>
                                    }
                                </td>
                                <td class="text-center text-nowrap">
                                    @if (item.ExpectedShippingDate.HasValue)
                                    {
                                        <span class="@(isOverdue ? "text-danger fw-bold" : "text-muted")">
                                            @if (isOverdue)
                                            {
                                                <i class="bi bi-exclamation-triangle-fill me-1"></i>
                                            }
                                            @item.ExpectedShippingDate.Value.ToString(ViewConstants.DefaultDateFormat)
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">—</span>
                                    }
                                </td>
                                <td>
                                    <a asp-controller="Order" asp-action="Details" asp-route-id="@item.OrderId"
                                           class="text-primary text-decoration-none text-nowrap">
                                        <i class="bi bi-receipt me-1"></i>@item.OrderCode
                                    </a>
                                </td>
                                <td class="text-center">
                                    @if (item.IsDelivered)
                                    {
                                        <span class="badge rounded-pill bg-success px-2 py-1 fw-normal">
                                            <i class="bi bi-check-circle me-1"></i>Đã giao
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge rounded-pill bg-warning text-dark px-2 py-1 fw-normal">
                                            <i class="bi bi-clock me-1"></i>Chờ giao
                                        </span>
                                    }
                                </td>
                                <td class="text-end pe-3">
                                    @if (!item.IsDelivered)
                                    {
                                        <button class="btn btn-sm btn-outline-success rounded-3 btnMarkDelivered"
                                                data-order-id="@item.OrderId"
                                                data-order-item-id="@item.OrderItemId"
                                                data-product-name="@item.ProductName"
                                                title="Đánh dấu đã giao">
                                            <i class="bi bi-check2-circle me-1"></i>
                                            <span class="d-none d-md-inline">Đã giao</span>
                                        </button>
                                    }
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="py-5 text-center text-muted">
                                <div class="mb-2"><i class="bi bi-box-seam fs-1 opacity-25"></i></div>
                                Không có hàng hóa nào cần chuẩn bị.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        @if (Model.Items.Pagination.TotalCount > 0)
        {
            <partial name="_Pager" model="Model.Items.Pagination" />
        }
    </div>
</div>
    