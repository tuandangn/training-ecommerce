@model CustomerPreparationListModel

<div class="content-card mb-4 p-2">
    <div class="d-flex align-items-center justify-content-between">
        <div class="d-flex align-items-center gap-2 px-2">
            <span class="small text-muted text-uppercase fw-bold"><i class="bi bi-funnel me-1"></i>Chế độ hiển thị</span>
        </div>
        <div class="btn-group" role="group">
            <a asp-action="List" asp-route-grouped="false" class="btn btn-primary active">
                <i class="bi bi-person-lines-fill me-1"></i>
                Theo khách hàng
            </a>
            <a asp-action="List" asp-route-grouped="true" class="btn btn-outline-primary">
                <i class="bi bi-box-seam me-1"></i>
                Theo hàng hóa
            </a>
        </div>
    </div>
</div>

<div class="content-card">
    <div class="table-responsive">
        <table class="table data-table">
            <thead>
                <tr>
                    <th class="ps-4">Sản phẩm</th>
                    <th class="text-end">Số lượng</th>
                    <th class="d-none d-md-table-cell">Khách hàng</th>
                    <th class="text-center d-none d-sm-table-cell">Ngày dự kiến</th>
                    <th>Mã đơn</th>
                    <th class="text-center" style="width: 140px;">Trạng thái</th>
                    <th class="text-end pe-4" style="width: 120px;"></th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Any())
                {
                    @foreach (var item in Model.Items)
                    {
                        var rowClass = item.IsDelivered ? "table-success opacity-75" : "";
                        var isOverdue = item.ExpectedShippingDate.HasValue && item.ExpectedShippingDate.Value.Date <= DateTime.Now.Date && !item.IsDelivered;
                        <tr class="@rowClass" id="row-@item.OrderItemId">
                            <td class="ps-4">
                                <span class="fw-bold text-dark">@item.ProductName</span>
                            </td>
                            <td class="text-end fw-bold fs-6">
                                @item.Quantity.ToString(ViewConstants.NumberCustomFormat)
                            </td>
                            <td class="d-none d-md-table-cell">
                                <div class="fw-bold">
                                    <i class="bi bi-person text-muted me-1"></i>@item.CustomerName
                                </div>
                                @if (!string.IsNullOrEmpty(item.CustomerPhone))
                                {
                                    <a href="tel:@item.CustomerPhone" class="text-muted small text-decoration-none">
                                        <i class="bi bi-telephone ms-1 me-1"></i>@item.CustomerPhone
                                    </a>
                                }
                            </td>
                            <td class="text-center d-none d-sm-table-cell">
                                @if (item.ExpectedShippingDate.HasValue)
                                {
                                    <span class="@(isOverdue ? "text-danger fw-bold" : "text-muted")">
                                        @if (isOverdue)
                                        {
                                            <i class="bi bi-exclamation-triangle-fill me-1"></i>
                                        }
                                        @item.ExpectedShippingDate.Value.ToString(ViewConstants.DefaultDateFormat)
                                    </span>
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }
                            </td>
                            <td>
                                <a asp-controller="Order" asp-action="Details" asp-route-id="@item.OrderId"
                                       class="text-primary fw-bold text-decoration-none">
                                    @item.OrderCode
                                </a>
                            </td>
                            <td class="text-center status-cell">
                                @if (item.IsDelivered)
                                {
                                    <span class="status-badge success">
                                        <i class="bi bi-check-circle-fill"></i>Đã giao
                                    </span>
                                }
                                else
                                {
                                    <span class="status-badge warning">
                                        <i class="bi bi-clock"></i>Chờ giao
                                    </span>
                                }
                            </td>
                            <td class="text-end pe-4 align-middle">
                                @if (!item.IsDelivered)
                                {
                                    <button class="btn btn-sm btn-outline-success btnMarkDelivered w-100"
                                            data-order-id="@item.OrderId"
                                            data-order-item-id="@item.OrderItemId"
                                            data-product-name="@item.ProductName"
                                            title="Đánh dấu đã giao">
                                        <i class="bi bi-check2-circle d-md-none"></i>
                                        <span class="d-none d-md-inline"><i class="bi bi-check-lg me-1"></i>Đã giao</span>
                                    </button>
                                }
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="7">
                            <div class="empty-state">
                                <div class="empty-icon"><i class="bi bi-person-lines-fill"></i></div>
                                <h5>Không có dữ liệu</h5>
                                <p>Không tìm thấy hàng hóa nào cần chuẩn bị.</p>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    
    @if (Model.Items.Pagination.TotalCount > 0)
    {
        <partial name="_Pager" model="Model.Items.Pagination" />
    }
</div>