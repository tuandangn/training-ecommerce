@using NamEcommerce.Domain.Shared.Enums.DeliveryNotes
@model ProductPreparationListModel

<div class="content-card mb-4 p-2">
    <div class="d-flex align-items-center justify-content-between">
        <div class="d-flex align-items-center gap-2 px-2">
            <span class="small text-muted text-uppercase fw-bold"><i class="bi bi-funnel me-1"></i>Chế độ hiển thị</span>
        </div>
        <div class="btn-group" role="group">
            <a asp-action="List" asp-route-grouped="false" class="btn btn-outline-primary">
                <i class="bi bi-person-lines-fill me-1"></i>
                Theo khách hàng
            </a>
            <a asp-action="List" asp-route-grouped="true" class="btn btn-primary active">
                <i class="bi bi-box-seam me-1"></i>
                Theo hàng hóa
            </a>
        </div>
    </div>
</div>

@if (Model.Any())
{
    @foreach (var preparationItem in Model)
    {
        <div class="content-card mb-4 overflow-hidden">
            <div class="card-header bg-light border-bottom-0 py-3 px-4 d-flex justify-content-between align-items-center">
                <h5 class="mb-0 fw-bold">
                    <i class="bi bi-box-seam me-2 text-primary"></i>@preparationItem.ProductName
                </h5>
                <div class="d-flex align-items-center gap-3">
                    <span class="badge bg-primary px-3 py-2 fs-6 rounded-pill">
                        Đã giao: @preparationItem.DeliveredQuantity.DisplayQuantity() / @preparationItem.TotalQuantity.DisplayQuantity()
                    </span>
                    <span class="badge bg-info px-3 py-2 fs-6 rounded-pill text-dark" title="Tồn kho khả dụng">
                        <i class="bi bi-box-seam me-1"></i> Tồn kho: @preparationItem.StockQuantityAvailable.DisplayQuantity()
                    </span>
                    @if (preparationItem.EarliestShippingDate.HasValue && preparationItem.EarliestShippingDate.Value != default)
                    {
                        var isGroupOverdue = preparationItem.EarliestShippingDate.Value.Date <= DateTime.UtcNow.Date;
                        <span class="small @(isGroupOverdue ? "text-danger fw-bold" : "text-muted")">
                            <i class="bi bi-calendar-event me-1"></i>Giao sớm nhất: @preparationItem.EarliestShippingDate.Value.ToLocalTime().ToString(ViewConstants.DefaultDateFormat)
                        </span>
                    }
                </div>
            </div>
            
            <div class="table-responsive">
                <table class="table data-table mb-0">
                    <thead>
                        <tr>
                            <th style="width:40px;" class="text-center"><input type="checkbox" class="select-all-prep-group" /></th>
                            <th class="ps-4">Khách hàng</th>
                            <th class="text-end">Số lượng</th>
                            <th class="text-center d-none d-sm-table-cell">Ngày dự kiến</th>
                            <th class="d-none d-md-table-cell">Mã đơn</th>
                            <th class="text-center" style="width: 140px;">Trạng thái</th>
                            <th class="text-end pe-4" style="width: 120px;"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var detail in preparationItem.CustomerDetails)
                        {
                            var detailRowClass = detail.IsDelivered ? "table-success opacity-75" : "";
                            var isDetailOverdue = detail.ExpectedShippingDate.HasValue && detail.ExpectedShippingDate.Value.Date <= DateTime.Now.Date && !detail.IsDelivered;
                            
                            <tr class="@detailRowClass" id="row-@detail.OrderItemId">
                                <td class="align-middle text-center" style="width:40px;">
                                    <input type="checkbox" class="select-prep-item" 
                                           data-order-id="@detail.OrderId" 
                                           data-order-code="@detail.OrderCode"
                                           data-order-item-id="@detail.OrderItemId"
                                           data-quantity="@detail.Quantity"
                                           data-delivered-quantity="@detail.DeliveredQuantity"
                                           data-product-name="@preparationItem.ProductName"
                                           data-stock="@preparationItem.StockQuantityAvailable"
                                           data-unit-price="@detail.UnitPrice" />
                                </td>
                                <td class="ps-4">
                                    <div class="fw-bold text-dark">
                                        <i class="bi bi-person text-muted me-1"></i>@detail.CustomerName
                                    </div>
                                    @if (!string.IsNullOrEmpty(detail.CustomerPhone))
                                    {
                                        <a href="tel:@detail.CustomerPhone" class="text-muted small text-decoration-none">
                                            <i class="bi bi-telephone ms-1 me-1"></i>@detail.CustomerPhone
                                        </a>
                                    }
                                </td>
                                <td class="text-end fw-bold fs-6">
                                    <span class="text-muted small">@detail.DeliveredQuantity.DisplayQuantity() /</span> @detail.Quantity.DisplayQuantity()
                                </td>
                                <td class="text-center d-none d-sm-table-cell">
                                    @if (detail.ExpectedShippingDate.HasValue)
                                    {
                                        <span class="@(isDetailOverdue ? "text-danger fw-bold" : "text-muted")">
                                            @if (isDetailOverdue)
                                            {
                                                <i class="bi bi-exclamation-triangle-fill me-1"></i>
                                            }
                                            @detail.ExpectedShippingDate.Value.ToString(ViewConstants.DefaultDateFormat)
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">—</span>
                                    }
                                </td>
                                <td class="d-none d-md-table-cell">
                                    <div class="d-flex flex-column gap-1">
                                        <a asp-controller="Order" asp-action="Details" asp-route-id="@detail.OrderId"
                                           class="text-primary fw-bold text-decoration-none">
                                            @detail.OrderCode
                                        </a>
                                        @if (detail.DeliveryNoteLinks.Any())
                                        {
                                            <div class="dropdown">
                                                <button class="btn btn-xs btn-outline-info dropdown-toggle py-0 px-2 small" type="button" data-bs-toggle="dropdown" aria-expanded="false" style="font-size: 0.75rem;">
                                                    <i class="bi bi-file-earmark-text me-1"></i>PXK (@detail.DeliveryNoteLinks.Count)
                                                </button>
                                                <ul class="dropdown-menu shadow-sm border-0 py-1" style="min-width: 180px;">
                                                    @foreach (var link in detail.DeliveryNoteLinks)
                                                    {
                                                        var statusTuple = (DeliveryNoteStatus) link.Status switch
                                                        {
                                                            DeliveryNoteStatus.Draft => ("secondary", "Bản nháp"),
                                                            DeliveryNoteStatus.Confirmed => ("info text-white", "Đã xác nhận"),
                                                            DeliveryNoteStatus.Delivering => ("warning", "Đang giao"),
                                                            DeliveryNoteStatus.Delivered => ("success", "Đã giao"),
                                                            DeliveryNoteStatus.Cancelled => ("danger", "Đã hủy"),
                                                            _ => ("secondary", "Không rõ")
                                                        };
                                                        <li>
                                                            <a class="dropdown-item d-flex align-items-center justify-content-between gap-2 py-2 px-3" asp-controller="DeliveryNote" asp-action="Details" asp-route-id="@link.Id">
                                                                <div class="flex-grow-1">
                                                                    <div class="small fw-medium">@link.Code</div>
                                                                    <div class="small text-muted" style="font-size: 0.75rem;">@link.CreatedOnUtc.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</div>
                                                                </div>
                                                                <span class="badge bg-@statusTuple.Item1" style="font-size: 0.65rem;">@statusTuple.Item2</span>
                                                            </a>
                                                        </li>
                                                    }
                                                </ul>
                                            </div>
                                        }
                                    </div>
                                </td>
                                <td class="text-center status-cell">
                                    @if (detail.IsDelivered)
                                    {
                                        <span class="status-badge success">
                                            <i class="bi bi-check-circle-fill"></i>Đã giao
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="status-badge warning">
                                            <i class="bi bi-clock"></i>Chờ giao
                                        </span>
                                    }
                                </td>
                                <td class="text-end pe-4 align-middle">
                                    @if (!detail.IsDelivered)
                                    {
                                        <button class="btn btn-sm btn-outline-success btnMarkDelivered w-100"
                                                data-order-id="@detail.OrderId"
                                                data-order-item-id="@detail.OrderItemId"
                                                data-product-name="@preparationItem.ProductName"
                                                title="Đánh dấu đã giao">
                                            <i class="bi bi-check2-circle d-md-none"></i>
                                            <span class="d-none d-md-inline"><i class="bi bi-check-lg me-1"></i>Đã giao</span>
                                        </button>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
    
    @if (Model.Items.Pagination.TotalCount > 0)
    {
        <div class="content-card">
            <partial name="_Pager" model="Model.Items.Pagination" />
        </div>
    }
}
else
{
    <div class="content-card p-5">
        <div class="empty-state">
            <div class="empty-icon"><i class="bi bi-box-seam"></i></div>
            <h5>Không có dữ liệu</h5>
            <p>Không tìm thấy hàng hóa nào cần chuẩn bị.</p>
        </div>
    </div>
}
