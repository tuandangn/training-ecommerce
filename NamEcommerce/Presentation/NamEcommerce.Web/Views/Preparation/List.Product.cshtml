@model ProductPreparationListModel

<div class="card border-0 shadow-sm rounded-4 mb-4">
    <div class="card-body p-3 d-flex align-items-center justify-content-end gap-3">
        <div class="d-flex align-items-center gap-2">
            @* <i class="bi bi-funnel text-muted"></i> *@
            <span class="small text-muted">Hiển thị</span>
        </div>
        <div class="btn-group" role="group">
            <a asp-action="List" asp-route-grouped="false"
                   class="btn btn-sm btn-outline-primary rounded-start-3">
                <i class="bi bi-list-ul me-1"></i>
                Theo khách hàng
            </a>
            <a asp-action="List" asp-route-grouped="true"
                   class="btn btn-sm btn-primary rounded-end-3">
                <i class="bi bi-collection me-1"></i>
                Theo hàng hóa
            </a>
        </div>
    </div>
</div>

@if (Model.Any())
{
    @foreach (var preparationItem in Model)
    {
        <div class="card border-0 shadow-sm rounded-4 mb-3">
            <div class="card-header bg-light rounded-top-4 border-0 py-3 px-4">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="mb-0 fw-bold">
                            <i class="bi bi-box-seam me-2 text-primary"></i>@preparationItem.ProductName
                        </h6>
                    </div>
                    <div class="d-flex align-items-center gap-3">
                        <span class="badge bg-primary rounded-pill px-3 py-2 fs-6">
                            Tổng: @preparationItem.TotalQuantity.ToString(ViewConstants.NumberCustomFormat)
                        </span>
                        @if (preparationItem.EarliestShippingDate.HasValue && preparationItem.EarliestShippingDate.Value != default)
                        {
                            var isGroupOverdue = preparationItem.EarliestShippingDate.Value.Date <= DateTime.UtcNow.Date;
                            <span class="small @(isGroupOverdue ? "text-danger fw-bold" : "text-muted")">
                                <i class="bi bi-calendar-event me-1"></i>Sớm nhất: @preparationItem.EarliestShippingDate.Value.ToLocalTime().ToString(ViewConstants.DefaultDateFormat)
                            </span>
                        }
                    </div>
                </div>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="text-muted">
                            <tr>
                                <th class="ps-4">Khách hàng</th>
                                <th class="text-end">Số lượng</th>
                                <th class="text-center">Ngày giao</th>
                                <th>Đơn hàng</th>
                                <th class="text-center">Trạng thái</th>
                                <th class="text-end pe-4"></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var detail in preparationItem.CustomerDetails)
                            {
                                var detailRowClass = detail.IsDelivered ? "table-success opacity-75" : "";
                                var isDetailOverdue = detail.ExpectedShippingDate.HasValue && detail.ExpectedShippingDate.Value.Date <= DateTime.Now.Date && !detail.IsDelivered;
                                <tr class="@detailRowClass" id="row-@detail.OrderItemId">
                                    <td class="ps-4">
                                        <div class="fw-600 text-nowrap">
                                            <i class="bi bi-person"></i>
                                            @detail.CustomerName
                                        </div>
                                        @if (!string.IsNullOrEmpty(detail.CustomerPhone))
                                        {
                                            <a href="tel:@detail.CustomerPhone" class="text-muted small text-decoration-none text-nowrap">
                                                <i class="bi bi-telephone me-1"></i>@detail.CustomerPhone
                                            </a>
                                        }
                                    </td>
                                    <td class="text-end text-nowrap fw-600">
                                        @detail.Quantity.ToString(ViewConstants.NumberCustomFormat)
                                    </td>
                                    <td class="text-center text-nowrap">
                                        @if (detail.ExpectedShippingDate.HasValue)
                                        {
                                            <span class="@(isDetailOverdue ? "text-danger fw-bold" : "text-muted")">
                                                @if (isDetailOverdue)
                                                {
                                                    <i class="bi bi-exclamation-triangle-fill me-1"></i>
                                                }
                                                @detail.ExpectedShippingDate.Value.ToString(ViewConstants.DefaultDateFormat)
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">—</span>
                                        }
                                    </td>
                                    <td>
                                        <a asp-controller="Order" asp-action="Details" asp-route-id="@detail.OrderId"
                                               class="text-primary text-decoration-none text-nowrap">
                                            <i class="bi bi-receipt me-1"></i>@detail.OrderCode
                                        </a>
                                    </td>
                                    <td class="text-center">
                                        @if (detail.IsDelivered)
                                        {
                                            <span class="badge rounded-pill bg-success px-2 py-1 fw-normal">
                                                <i class="bi bi-check-circle me-1"></i>Đã giao
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge rounded-pill bg-warning text-dark px-2 py-1 fw-normal">
                                                <i class="bi bi-clock me-1"></i>Chờ giao
                                            </span>
                                        }
                                    </td>
                                    <td class="text-end pe-4">
                                        @if (!detail.IsDelivered)
                                        {
                                            <button class="btn btn-sm btn-outline-success rounded-3 btnMarkDelivered"
                                                    data-order-id="@detail.OrderId"
                                                    data-order-item-id="@detail.OrderItemId"
                                                    data-product-name="@preparationItem.ProductName"
                                                    title="Đánh dấu đã giao">
                                                <i class="bi bi-check2-circle me-1"></i>
                                                <span class="d-none d-md-inline">Đã giao</span>
                                            </button>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
    @if (Model.Items.Pagination.TotalCount > 0)
    {
        <partial name="_Pager" model="Model.Items.Pagination" />
    }
}
else
{
    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body py-5 text-center text-muted">
            <div class="mb-2"><i class="bi bi-box-seam fs-1 opacity-25"></i></div>
            Không có hàng hóa nào cần chuẩn bị.
        </div>
    </div>
}
