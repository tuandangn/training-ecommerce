@model PurchaseOrderListModel
@{
    ViewData[ViewConstants.PageTitle] = "Đơn nhập hàng";
    var successMessage = TempData[ViewConstants.PurchaseOrderSuccessMessage] as string;
    var errorMessage = TempData[ViewConstants.PurchaseOrderErrorMessage] as string;
    var query = Model.Keywords;
}

<div class="page-header">
    <div>
        <h1 class="page-header-title">Đơn nhập hàng</h1>
        <p class="page-header-subtitle">Quản lý đơn nhập hàng</p>
    </div>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-lg me-1"></i> Thêm mới
    </a>
</div>

@if (!string.IsNullOrEmpty(successMessage))
{
    <div class="alert alert-success alert-global alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i>@successMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-warning alert-global alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-2"></i>@errorMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="content-card">
    <div class="action-toolbar">
        <partial name="_Search" model="@(new PurchaseOrderListSearchModel { Keywords = query })" />
    </div>

    <div class="table-responsive">
        <table class="table data-table">
            <thead>
                <tr>
                    <th class="ps-4">Mã đơn</th>
                    <th>
                        Nhà cung cấp
                    </th>
                    <th class="d-none d-md-table-cell">
                        Kho hàng
                    </th>
                    <th class="text-center">
                        Dự kiến giao
                    </th>
                    <th class="text-end">Tổng tiền</th>
                    <th class="text-center" style="width: 120px;">
                        Trạng thái
                    </th>
                    <th class="d-none d-md-table-cell text-center">
                        Ngày tạo
                    </th>
                    <th style="width: 80px;"></th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Data.Pagination.TotalCount > 0)
                {
                    @foreach (var purchaseOrder in Model.Data)
                    {
                        <tr>
                            <td class="ps-4">
                                <a asp-action="Details" asp-route-id="@purchaseOrder.Id" class="text-decoration-none fw-medium text-nowrap">
                                    @HighlighHelper.Highlight(purchaseOrder.Code, query)
                                </a>
                                <span class="text-muted small d-inline d-lg-none">@purchaseOrder.CreatedOn.ToString(ViewConstants.DefaultDateTimeFormat)</span>
                            </td>
                            <td>
                                <div class="position-relative">
                                    @if (!string.IsNullOrEmpty(purchaseOrder.VendorName))
                                    {
                                        @HighlighHelper.Highlight(purchaseOrder.VendorName, query)
                                    }
                                    @if (!string.IsNullOrEmpty(purchaseOrder.VendorPhone))
                                    {
                                        <div>
                                            <a href="tel:@purchaseOrder.VendorPhone" class="text-muted small text-decoration-none">
                                                <i class="bi bi-telephone me-1"></i> @HighlighHelper.Highlight(purchaseOrder.VendorPhone, Model.Keywords)
                                            </a>
                                        </div>
                                    }
                                </div>
                            </td>
                            <td class="d-none d-md-table-cell">
                                @if (!string.IsNullOrEmpty(purchaseOrder.WarehouseName))
                                {
                                    @HighlighHelper.Highlight(purchaseOrder.WarehouseName, query)
                                }
                            </td>
                            <td class="text-center text-muted">
                                @purchaseOrder.ExpectedDeliveryDate?.ToString(ViewConstants.DefaultDateFormat)
                            </td>
                            <td class="text-end fw-bold text-primary text-nowrap">
                                @purchaseOrder.TotalAmount.DisplayCurrency()
                            </td>
                            <td class="text-center">
                                @{
                                    var purchaseOrderStatus = (PurchaseOrderStatus)purchaseOrder.Status;
                                }
                                <span class="status-badge @purchaseOrderStatus.GetDisplayColor()">
                                    @purchaseOrderStatus.GetDisplayText()
                                </span>
                            </td>
                            <td class="d-none d-md-table-cell text-muted text-center">
                                @purchaseOrder.CreatedOn.ToString(ViewConstants.DefaultDateTimeFormat)
                            </td>
                            <td class="text-end pe-3">
                                <a class="btn-table-action" asp-action="Details" asp-route-id="@purchaseOrder.Id" title="Chi tiết">
                                    <i class="bi bi-chevron-right"></i>
                                    <span class="visually-hidden">Chi tiết</span>
                                </a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="7">
                            <div class="empty-state">
                                <div class="empty-icon"><i class="bi bi-inbox"></i></div>
                                <h5>Không tìm thấy đơn nhập hàng nào</h5>
                                <p>Thử thay đổi từ khóa tìm kiếm hoặc tạo đơn mới.</p>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (Model.Data.Pagination.TotalCount > 0)
    {
        <partial name="_Pager" model="Model.Data.Pagination" />
    }
</div>
