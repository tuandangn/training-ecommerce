@model PurchaseOrderListModel
@{
    ViewData[ViewConstants.PageTitle] = "Đơn nhập hàng";
    var successMsg = TempData[ViewConstants.PurchaseOrderSuccessMessage] as string;
    var errorMsg = TempData[ViewConstants.PurchaseOrderErrorMessage] as string;

    string? query = Model.Keywords;
}
<section class="content-title my-4 text-center">
    <h1>Đơn nhập hàng</h1>
</section>

<section class="content-data p-4 mb-5 shadow border rounded">
    <div class="mb-2 d-flex align-items-start">
        <div class="d-flex flex-lg-row flex-wrap align-items-center mb-2">
            <partial name="_Search" model="@(new PurchaseOrderListSearchModel { Keywords = Model.Keywords })" />
            @if (!string.IsNullOrEmpty(query))
            {
                <a asp-action="List" class="btn btn-sm btn-link text-decoration-none text-muted">
                    <i class="bi bi-x"></i>
                    Xóa tìm kiếm
                </a>
            }
        </div>
        <div class="text-end mb-2 flex-grow-1">
            <a asp-action="Create" class="btn btn-outline-primary">
                <i class="bi bi-plus"></i>
                Thêm mới
            </a>
        </div>
    </div>
    @if (!string.IsNullOrEmpty(successMsg))
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @successMsg
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (!string.IsNullOrEmpty(errorMsg))
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @errorMsg
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    <div class="table-responsive">
        <table class="table table-striped">
            <thead>
                <tr>
                    <th class="ps-3">
                        <span class="d-none d-lg-inline">Mã đơn</span>
                        <span class="d-inline d-lg-none">Đơn hàng</span>
                    </th>
                    <th class="text-end pe-3">Tổng tiền</th>
                    <th>Nhà cung cấp</th>
                    <th>Kho nhập</th>
                    <th class="d-none d-lg-table-cell text-center">Ngày dự kiến</th>
                    <th class="d-none d-lg-table-cell">Trạng thái</th>
                    <th>Ngày tạo</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Data.Pagination.TotalCount > 0)
                {
                    @foreach (var item in Model.Data)
                    {
                        var (badgeClass, label) = (PurchaseOrderStatus)item.Status switch
                        {
                            PurchaseOrderStatus.Draft => ("secondary", "Nháp"),
                            PurchaseOrderStatus.Submitted => ("primary", "Đã gửi"),
                            PurchaseOrderStatus.Approved => ("info", "Đã duyệt"),
                            PurchaseOrderStatus.Receiving => ("warning text-dark", "Đang nhận hàng"),
                            PurchaseOrderStatus.Completed => ("success", "Hoàn tất"),
                            PurchaseOrderStatus.Cancelled => ("danger", "Đã hủy"),
                            _ => ("light", "?")
                        };
                        <tr>
                            <td class="ps-3">
                                <span class="text-nowrap d-block">
                                    @HighlighHelper.Highlight(item.Code, query)
                                </span>
                                <span class="d-inline d-lg-none">
                                    <span class="badge bg-@badgeClass">@label</span>
                                </span>
                            </td>
                            <td class="text-end pe-3">
                                @if ((PurchaseOrderStatus)item.Status == PurchaseOrderStatus.Draft)
                                {
                                    if (item.TotalAmount == 0)
                                    {
                                        <span class="text-muted">Chưa tính</span>
                                    }
                                    else
                                    {
                                        @item.TotalAmount.ToString(ViewConstants.NumberCustomFormat) @ViewConstants.DefaultCurrencySymbol
                                        <span class="text-muted">(*)</span>
                                    }
                                }
                                else
                                {
                                    <span style="font-weight:600">
                                        @item.TotalAmount.ToString(ViewConstants.NumberCustomFormat) @ViewConstants.DefaultCurrencySymbol
                                    </span>
                                }
                            </td>
                            <td>
                                @if (!string.IsNullOrEmpty(item.VendorName))
                                {
                                    @HighlighHelper.Highlight(item.VendorName, query)
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            </td>
                            <td>
                                @if (!string.IsNullOrEmpty(item.WarehouseName))
                                {
                                    <span class="text-nowrap">
                                        @HighlighHelper.Highlight(item.WarehouseName, query)
                                    </span>
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            </td>
                            <td class="d-none d-lg-table-cell text-center text-muted">
                                @(item.ExpectedDeliveryDate?.ToString("dd/MM/yyyy") ?? "-")
                            </td>
                            <td class="d-none d-lg-table-cell">
                                <span class="badge bg-@badgeClass">@label</span>
                            </td>
                            <td class="text-muted">@item.CreatedOn.ToString("g")</td>
                            <td class="text-center">
                                @if (item.Status == (int)PurchaseOrderStatus.Draft || item.Status == (int)PurchaseOrderStatus.Receiving 
                                || item.Status == (int)PurchaseOrderStatus.Submitted || item.Status == (int)PurchaseOrderStatus.Approved)
                                {
                                    <a class="btn btn-secondary btn-sm" asp-action="Details" asp-route-id="@item.Id">
                                        <i class="bi bi-arrow-right"></i>
                                        <span class="d-none d-lg-inline visually-hidden">
                                            Chỉnh sửa
                                        </span>
                                    </a>
                                }
                                else
                                {
                                    <a class="btn btn-link" asp-action="Details" asp-route-id="@item.Id">
                                        <i class="bi bi-eye"></i>
                                        <span class="d-none d-lg-inline visually-hidden">
                                            Chi tiết
                                        </span>
                                    </a>
                                }
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="8">
                            <p class="my-2 ps-2">
                                <span class="text-muted">Chưa có đơn nhập hàng nào.</span>
                            </p>
                        </td>
                    </tr>
                }
            </tbody>
            @if (Model.Data.Pagination.TotalCount > 0)
            {
                <tfoot>
                    <tr>
                        <td colspan="8" class="ps-0">
                            <partial name="_Pager" model="Model.Data.Pagination" />
                        </td>
                    </tr>
                </tfoot>
            }
        </table>
    </div>
</section>
