@model PurchaseOrderListModel
@{
    ViewData[ViewConstants.PageTitle] = "Đơn nhập hàng";
    var successMsg = TempData[ViewConstants.WarehouseSuccessMessage] as string;
    var errorMsg = TempData[ViewConstants.WarehouseErrorMessage] as string;
}

<section class="content-title my-4 d-flex align-items-center justify-content-between">
    <h1>Đơn nhập hàng</h1>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-lg"></i> Tạo đơn nhập
    </a>
</section>

<section class="content-data p-4 mb-5 shadow">
    @if (!string.IsNullOrEmpty(successMsg))
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @successMsg
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (!string.IsNullOrEmpty(errorMsg))
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @errorMsg
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <form method="get" asp-action="List" class="d-flex mb-3">
        <input type="text" name="keywords" value="@Model.Keywords" class="form-control form-control-sm me-2" placeholder="Tìm theo mã, nhà cung cấp..." />
        <button type="submit" class="btn btn-sm btn-primary">Tìm</button>
        @if (!string.IsNullOrEmpty(Model.Keywords))
        {
            <a asp-action="List" class="btn btn-sm btn-link ms-1">Xóa</a>
        }
    </form>

    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead>
                <tr>
                    <th class="ps-3">Mã đơn nhập</th>
                    <th>Nhà cung cấp</th>
                    <th>Kho nhập</th>
                    <th>Trạng thái</th>
                    <th class="text-end">Tổng tiền</th>
                    <th>Ngày giao dự kiến</th>
                    <th>Ngày tạo</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Data.Pagination.TotalCount > 0)
                {
                    @foreach (var item in Model.Data)
                    {
                        <tr>
                            <td class="ps-3 fw-bold">@item.Code</td>
                            <td>@item.VendorName</td>
                            <td>@item.WarehouseName</td>
                            <td>
                                @{
                                    var (badgeClass, label) = (PurchaseOrderStatus)item.Status switch
                                    {
                                        PurchaseOrderStatus.Draft => ("secondary", "Nháp"),
                                        PurchaseOrderStatus.Submitted => ("primary", "Đã gửi"),
                                        PurchaseOrderStatus.Approved => ("info", "Đã duyệt"),
                                        PurchaseOrderStatus.Receiving => ("warning text-dark", "Đang nhận hàng"),
                                        PurchaseOrderStatus.Completed => ("success", "Hoàn tất"),
                                        PurchaseOrderStatus.Cancelled => ("danger", "Đã hủy"),
                                        _ => ("light", "?")
                                    };
                                }
                                <span class="badge bg-@badgeClass">@label</span>
                            </td>
                            <td class="text-end">@item.TotalAmount.ToString("N0") đ</td>
                            <td>@(item.ExpectedDeliveryDate?.ToString("d") ?? "-")</td>
                            <td class="text-muted">@item.CreatedOn.ToString("g")</td>
                            <td class="text-end pe-3">
                                <a class="btn btn-sm btn-outline-primary" asp-action="Details" asp-route-id="@item.Id">
                                    Chi tiết
                                </a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="8" class="text-center text-muted py-4">Chưa có đơn nhập hàng nào.</td>
                    </tr>
                }
            </tbody>
            @if (Model.Data.Pagination.TotalCount > 0)
            {
                <tfoot>
                    <tr>
                        <td colspan="8">
                            <partial name="_Pager" model="Model.Data.Pagination" />
                        </td>
                    </tr>
                </tfoot>
            }
        </table>
    </div>
</section>
