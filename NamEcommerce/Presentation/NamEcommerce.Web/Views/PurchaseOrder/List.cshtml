@model PurchaseOrderListModel
@{
    ViewData[ViewConstants.PageTitle] = "Đơn nhập hàng";
    var successMessage = TempData[ViewConstants.PurchaseOrderSuccessMessage] as string;
    var errorMessage = TempData[ViewConstants.PurchaseOrderErrorMessage] as string;
    var query = Model.Keywords;
}

<div class="page-header">
    <div>
        <h1 class="page-header-title">Đơn nhập hàng</h1>
        <p class="page-header-subtitle">Quản lý các lô hàng nhập từ Nhà cung cấp</p>
    </div>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-lg me-1"></i>Tạo đơn nhập mới
    </a>
</div>

@if (!string.IsNullOrEmpty(successMessage))
{
    <div class="alert alert-success alert-dismissible fade show alert-global mb-3" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i>@successMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-warning alert-dismissible fade show alert-global mb-3" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-2"></i>@errorMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="content-card">
    <div class="action-toolbar">
        <partial name="_Search" model="@(new PurchaseOrderListSearchModel { Keywords = query })" />
    </div>

    <div class="table-responsive">
        <table class="table data-table">
            <thead>
                <tr>
                    <th class="ps-4">Mã đơn</th>
                    <th><i class="bi bi-building me-1"></i>Nhà cung cấp</th>
                    <th class="d-none d-md-table-cell"><i class="bi bi-geo-alt me-1"></i>Kho hàng</th>
                    <th class="d-none d-md-table-cell"><i class="bi bi-calendar me-1"></i>Ngày tạo</th>
                    <th class="text-end">Tổng tiền</th>
                    <th class="text-center" style="width: 120px;">Trạng thái</th>
                    <th style="width: 80px;"></th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Data.Pagination.TotalCount > 0)
                {
                    @foreach (var item in Model.Data)
                    {
                        var (badgeClass, label, icon) = (PurchaseOrderStatus)item.Status switch
                        {
                            PurchaseOrderStatus.Draft => ("secondary", "Bản nháp", "bi-pencil"),
                            PurchaseOrderStatus.Submitted => ("primary", "Đã gửi", "bi-send"),
                            PurchaseOrderStatus.Approved => ("info", "Đã duyệt", "bi-check-all"),
                            PurchaseOrderStatus.Receiving => ("warning text-dark", "Đang nhận", "bi-box-arrow-in-down"),
                            PurchaseOrderStatus.Completed => ("success", "Hoàn tất", "bi-check-circle-fill"),
                            PurchaseOrderStatus.Cancelled => ("danger", "Đã hủy", "bi-x-circle"),
                            _ => ("light", "Không rõ", "bi-question-circle")
                        };

                        <tr>
                            <td class="ps-4 fw-medium">
                                <a asp-action="Details" asp-route-id="@item.Id" class="text-decoration-none">
                                    @HighlighHelper.Highlight(item.Code, query)
                                </a>
                            </td>
                            <td>
                                @if(!string.IsNullOrEmpty(item.VendorName)) 
                                {
                                    @HighlighHelper.Highlight(item.VendorName, query)
                                }
                                else 
                                {
                                    <span class="text-muted small">N/A</span>
                                }
                            </td>
                            <td class="d-none d-md-table-cell">
                                @if(!string.IsNullOrEmpty(item.WarehouseName)) 
                                {
                                    @HighlighHelper.Highlight(item.WarehouseName, query)
                                }
                                else 
                                {
                                    <span class="text-muted small">N/A</span>
                                }
                            </td>
                            <td class="d-none d-md-table-cell text-muted">@item.CreatedOn.ToString("dd/MM/yyyy")</td>
                            <td class="text-end fw-bold text-primary">@item.TotalAmount.ToString("N0") <span class="small">đ</span></td>
                            <td class="text-center">
                                <span class="status-badge @badgeClass"><i class="bi @icon"></i>@label</span>
                            </td>
                            <td class="text-end pe-3">
                                <a class="btn-table-action" asp-action="Details" asp-route-id="@item.Id" title="Chi tiết">
                                    <i class="bi bi-chevron-right"></i>
                                </a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="7">
                            <div class="empty-state">
                                <div class="empty-icon"><i class="bi bi-inbox"></i></div>
                                <h5>Không tìm thấy đơn nhập hàng nào</h5>
                                <p>Thử thay đổi từ khóa tìm kiếm hoặc tạo đơn mới.</p>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (Model.Data.Pagination.TotalCount > 0)
    {
        <partial name="_Pager" model="Model.Data.Pagination" />
    }
</div>
