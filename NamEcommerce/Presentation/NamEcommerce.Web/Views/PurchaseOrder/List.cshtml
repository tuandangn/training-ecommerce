@model PurchaseOrderListModel
@{
    ViewData["Title"] = "Đơn nhập hàng";
    var query = Model.Keywords;
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-1 fw-bold">Danh sách Đơn nhập hàng</h1>
            <p class="text-muted small mb-0">Quản lý các lô hàng nhập từ Nhà cung cấp</p>
        </div>
        <a asp-action="Create" class="btn btn-primary px-4 rounded-3 shadow-sm">
            <i class="bi bi-plus-lg me-1"></i> Tạo đơn nhập mới
        </a>
    </div>

    <!-- Search & Filter Card -->
    <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-body p-4">
            <form asp-action="List" method="get" class="row g-3">
                <div class="col-md-8">
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0"><i class="bi bi-search text-muted"></i></span>
                        <input type="text" name="Keywords" class="form-control border-start-0 ps-0" 
                               placeholder="Tìm theo mã đơn, nhà cung cấp hoặc kho..." value="@query">
                    </div>
                </div>
                <div class="col-md-3">
                    <select name="status" class="form-select border-0 bg-light rounded-3">
                        <option value="">-- Tất cả trạng thái --</option>
                        @foreach (var status in Enum.GetValues<PurchaseOrderStatus>())
                        {
                            <option value="@((int)status)">@status.ToString()</option>
                        }
                    </select>
                </div>
                <div class="col-md-1">
                    <button type="submit" class="btn btn-dark w-100 rounded-3">Lọc</button>
                </div>
            </form>
        </div>
    </div>

    @if (Model.Data.Pagination.TotalCount > 0)
    {
        <div class="row g-4">
            @foreach (var item in Model.Data)
            {
                var (badgeClass, label, icon) = (PurchaseOrderStatus)item.Status switch
                {
                    PurchaseOrderStatus.Draft => ("secondary", "Bản nháp", "bi-pencil"),
                    PurchaseOrderStatus.Submitted => ("primary", "Đã gửi", "bi-send"),
                    PurchaseOrderStatus.Approved => ("info", "Đã duyệt", "bi-check-all"),
                    PurchaseOrderStatus.Receiving => ("warning text-dark", "Đang nhận", "bi-box-arrow-in-down"),
                    PurchaseOrderStatus.Completed => ("success", "Hoàn tất", "bi-check-circle-fill"),
                    PurchaseOrderStatus.Cancelled => ("danger", "Đã hủy", "bi-x-circle"),
                    _ => ("light", "Không rõ", "bi-question-circle")
                };

                <div class="col-md-6 col-xl-4">
                    <div class="card border-0 shadow-sm rounded-4 h-100 hover-shadow transition">
                        <div class="card-body p-4">
                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <div>
                                    <span class="badge bg-@badgeClass rounded-pill mb-2">
                                        <i class="bi @icon me-1"></i> @label
                                    </span>
                                    <h5 class="fw-bold mb-0">@item.Code</h5>
                                </div>
                                <div class="text-end">
                                    <div class="fw-bold text-primary fs-5">
                                        @item.TotalAmount.ToString("N0") <span class="small">đ</span>
                                    </div>
                                    <div class="text-muted small">@item.CreatedOn.ToString("dd/MM/yyyy")</div>
                                </div>
                            </div>

                            <div class="mb-4">
                                <div class="d-flex align-items-center mb-2">
                                    <div class="icon-box bg-light rounded-circle me-2 d-flex align-items-center justify-content-center" style="width: 32px; height: 32px;">
                                        <i class="bi bi-truck text-muted small"></i>
                                    </div>
                                    <span class="text-dark small">@(item.VendorName ?? "N/A")</span>
                                </div>
                                <div class="d-flex align-items-center">
                                    <div class="icon-box bg-light rounded-circle me-2 d-flex align-items-center justify-content-center" style="width: 32px; height: 32px;">
                                        <i class="bi bi-geo-alt text-muted small"></i>
                                    </div>
                                    <span class="text-dark small">@(item.WarehouseName ?? "N/A")</span>
                                </div>
                            </div>

                            <hr class="border-light">

                            <div class="d-flex justify-content-between align-items-center">
                                <div class="text-muted small italic">
                                    <i class="bi bi-calendar-event me-1"></i>
                                    @(item.ExpectedDeliveryDate?.ToString("dd/MM/yyyy") ?? "Chưa rõ ngày giao")
                                </div>
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-dark btn-sm rounded-pill px-3">
                                    Chi tiết <i class="bi bi-arrow-right ms-1"></i>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

        <div class="mt-5 d-flex justify-content-center">
            <partial name="_Pager" model="Model.Data.Pagination" />
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <div class="mb-3">
                <i class="bi bi-inbox text-muted display-1 opacity-25"></i>
            </div>
            <h4 class="text-muted">Không tìm thấy đơn nhập hàng nào</h4>
            <p class="text-muted small">Thử thay đổi từ khóa tìm kiếm hoặc tạo đơn mới.</p>
        </div>
    }
</div>

<style>
    .hover-shadow:hover { 
        transform: translateY(-5px);
        box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.15) !important;
    }
    .transition { transition: all 0.3s ease; }
    .italic { font-style: italic; }
</style>
