@model PurchaseOrderListModel
@{
    ViewData[ViewConstants.PageTitle] = "Đơn nhập hàng";
    var query = Model.Keywords;
}
@section TitleSection {
    <h1 class="topbar-page-title">Đơn nhập</h1>
    <div class="topbar-page-subtitle">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a asp-action="Index" asp-controller="Home" class="text-decoration-none">Trang chủ</a></li>
                <li class="breadcrumb-item active" aria-current="page">Đơn nhập</li>
            </ol>
        </nav>
    </div>
}
<div class="content-card">
    <div class="action-toolbar">
        <partial name="_Search" model="@(new PurchaseOrderListSearchModel { Keywords = Model.Keywords, Status = (PurchaseOrderStatus?)Model.Status })" />
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-lg me-1"></i> Tạo đơn
        </a>
    </div>
    <ul class="nav nav-tabs">
        <li class="nav-item">
            <a asp-route-keywords="@(string.IsNullOrEmpty(Model.Keywords) ? "" : Model.Keywords)" asp-route-status=""
               class="nav-link @(Model.Status.HasValue ? "" : "active")">Tất cả</a>
        </li>
        @foreach (var statusOption in PurchaseOrderStatus.GetOptions())
        {
            <li class="nav-item">
                <a asp-route-keywords="@(string.IsNullOrEmpty(Model.Keywords) ? "" : Model.Keywords)" asp-route-status="@statusOption.value"
                   class="nav-link @(statusOption.value == Model.Status ? "active" : "")" aria-current="page">@statusOption.text</a>
            </li>
        }
    </ul>
    <div class="content-card-body-flush">
        <div class="table-responsive">
            <table class="table data-table">
                <thead>
                    <tr>
                        <th class="ps-4">Mã đơn</th>
                        <th class="d-none d-lg-table-cell text-center">
                            Ngày đặt
                        </th>
                        <th>
                            Nhà cung cấp
                        </th>
                        <th class="text-end">Tổng tiền</th>
                        <th class="text-center" style="width: 120px;">
                            Trạng thái
                        </th>
                        <th class="d-none d-xl-table-cell text-center">
                            Ngày tạo
                        </th>
                        <th style="width: 80px;"></th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Data.Pagination.TotalCount > 0)
                    {
                        @foreach (var purchaseOrder in Model.Data)
                        {
                            <tr>
                                <td class="ps-4">
                                    <a asp-action="Details" asp-route-id="@purchaseOrder.Id" class="text-decoration-none d-block fw-medium text-nowrap" data-bs-toggle="tooltip" title="Xem chi tiết">
                                        @HighlighHelper.Highlight(purchaseOrder.Code, query)
                                    </a>
                                    <span class="text-muted small d-inline d-lg-none">
                                        @purchaseOrder.PlacedOn.ToString(ViewConstants.DefaultDateTimeFormat)
                                    </span>
                                </td>
                                <td class="d-none d-lg-table-cell text-center">
                                    @purchaseOrder.PlacedOn.ToString(ViewConstants.DefaultDateTimeFormat)
                                </td>
                                <td>
                                    <div class="position-relative">
                                        <a asp-action="Details" asp-controller="VendorDebt" asp-route-vendorid="@purchaseOrder.VendorId" class="stretched-link fw-medium text-dark text-decoration-none text-nowrap" data-bs-toggle="tooltip" title="Xem công nợ">
                                            @HighlighHelper.Highlight(purchaseOrder.VendorName, query)
                                        </a>
                                        @if (!string.IsNullOrEmpty(purchaseOrder.VendorPhone))
                                        {
                                            <div>
                                                <span class="text-muted small">
                                                     @HighlighHelper.Highlight(purchaseOrder.VendorPhone, Model.Keywords)
                                                </span>
                                            </div>
                                        }
                                    </div>
                                </td>
                                <td class="text-end fw-bold text-primary text-nowrap">
                                    @purchaseOrder.TotalAmount.DisplayCurrency()
                                </td>
                                <td class="text-center">
                                    @{
                                        var purchaseOrderStatus = (PurchaseOrderStatus)purchaseOrder.Status;
                                    }
                                    <span class="status-badge @purchaseOrderStatus.GetDisplayColor()">
                                        @purchaseOrderStatus.GetDisplayText()
                                    </span>
                                </td>
                                <td class="d-none d-xl-table-cell text-muted text-center">
                                    @purchaseOrder.CreatedOn.ToString(ViewConstants.DefaultDateTimeFormat)
                                </td>
                                <td class="text-end pe-3">
                                    <a class="btn btn-sm btn-light text-decoration-none text-primary" asp-action="Details" asp-route-id="@purchaseOrder.Id" data-bs-toggle="tooltip" title="Xem chi tiết">
                                        <span>Xem</span>
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7">
                                <div class="empty-state">
                                    <div class="empty-icon"><i class="bi bi-inbox"></i></div>
                                    <h5>Không tìm thấy đơn nhập hàng nào</h5>
                                    <p>Thử thay đổi từ khóa tìm kiếm hoặc tạo đơn mới.</p>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        @if (Model.Data.Pagination.TotalCount > 0)
        {
            <partial name="_Pager" model="Model.Data.Pagination" />
        }
    </div>
</div>
@section Scripts {
    <script type="module">
        const txtKeywords = document.getElementById('@Html.IdFor(m => m.Keywords)');
        const form = txtKeywords.closest('form');
        const onSearchChanged = debounce(function () {
        form.submit();
        }, 700);
        txtKeywords.addEventListener('input', onSearchChanged);

        if(txtKeywords.value){
        focusEnd(txtKeywords);
        }
        @if (!string.IsNullOrEmpty(Model.Keywords))
        {
            <text>
                focusEnd(txtKeywords);
            </text>
        }
    </script>
}
