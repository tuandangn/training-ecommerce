@model PurchaseOrderModel
<div class="row mb-3">
    <div class="col-md-6">
        <table class="table table-sm">
            <tbody>
                <tr>
                    <td class="fw-bold">Nhà cung cấp</td>
                    <td>@(Model.VendorName ?? "-")</td>
                </tr>
                <tr>
                    <td class="fw-bold">Ngày giao dự kiến</td>
                    <td>@(Model.ExpectedDeliveryDate?.ToString("d") ?? "-")</td>
                </tr>
                <tr>
                    <td class="fw-bold">Ghi chú</td>
                    <td>@(string.IsNullOrEmpty(Model.Note) ? "-" : Model.Note)</td>
                </tr>
            </tbody>
        </table>
    </div>
    <div class="col-md-6 text-lg-end order-0 order-lg-1">
        <div class="row mb-3">
            <div class="col-6 col-md-6">
                <div class="d-flex flex-column border rounded p-2">
                    <label asp-for="ShippingAmount" class="form-label fw-bold"></label>
                    <span>@Model.ShippingAmount.ToString(ViewConstants.NumberCustomFormat) đ</span>
                </div>
            </div>
            <div class="col-6 col-md-6">
                <div class="d-flex flex-column border rounded p-2">
                    <label asp-for="TaxAmount" class="form-label fw-bold"></label>
                    <span>@Model.TaxAmount.ToString(ViewConstants.NumberCustomFormat) đ</span>
                </div>
            </div>
        </div>
        <p class="fs-5 fw-bold mb-1">
            Tổng đơn: <span class="text-primary">@Model.TotalAmount.ToString(ViewConstants.NumberCustomFormat) đ</span>
        </p>
        <p class="text-muted">
            Ngày tạo: @Model.CreatedOn.ToString("g")
        </p>
    </div>
</div>
