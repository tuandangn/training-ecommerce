@model PurchaseOrderListSearchModel
<form method="get" class="d-flex flex-wrap align-items-center gap-2">
    <input type="hidden" asp-for="Status" />
    <div class="search-input-group flex-grow-1">
        <div class="input-group">
            <span class="input-group-text bg-white border-end-0">
                <i class="bi bi-search text-muted"></i>
            </span>
            <input asp-for="Keywords" class="form-control border-start-0 ps-0" placeholder="Tìm theo mã đơn, NCC" />
            @if (!string.IsNullOrEmpty(Model.Keywords))
            {
                <a asp-action="List" asp-route-status="@Model.Status" class="btn btn-outline-secondary" title="Bỏ lọc">
                    <i class="bi bi-x-lg"></i>
                </a>
            }
        </div>
    </div>
</form>