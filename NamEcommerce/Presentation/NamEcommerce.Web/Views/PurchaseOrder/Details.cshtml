@model PurchaseOrderDetailsModel
@{
    ViewData[ViewConstants.PageTitle] = $"Đơn nhập hàng - {Model.Info.Code}";

    var successMsg = TempData[ViewConstants.PurchaseOrderSuccessMessage] as string;
    var errorMsg = TempData[ViewConstants.PurchaseOrderErrorMessage] as string;

    var (badgeClass, statusLabel) = (PurchaseOrderStatus)Model.Info.Status switch
    {
        PurchaseOrderStatus.Draft => ("secondary", "Nháp"),
        PurchaseOrderStatus.Submitted => ("primary", "Đã gửi"),
        PurchaseOrderStatus.Approved => ("info", "Đã duyệt"),
        PurchaseOrderStatus.Receiving => ("warning text-dark", "Đang nhận hàng"),
        PurchaseOrderStatus.Completed => ("success", "Hoàn tất"),
        PurchaseOrderStatus.Cancelled => ("danger", "Đã hủy"),
        _ => ("light", "?")
    };

    ViewData["AvailableWarehouses"] = Model.AvailableWarehouses;
    ViewData["ReceiveItemModels"] = Model.ReceiveItemModels;
}
<section class="content-title px-3 my-4 d-flex align-items-center justify-content-between">
    <div>
        <h1>
            @Model.Info.Code
        </h1>
        <span class="badge bg-@badgeClass fs-6">@statusLabel</span>
    </div>
    <div class="d-flex flex-column gap-2 align-items-end">
        <partial name="Details.ChangeStatus" model="Model.Info" />
        <a asp-action="List" class="text-muted small text-decoration-none">
            <i class="bi bi-arrow-90deg-left"></i>
            Trở lại
        </a>
    </div>
</section>
<section class="content-data p-4 mb-4 shadow border rounded">
    @if (!string.IsNullOrEmpty(successMsg))
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @successMsg <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (!string.IsNullOrEmpty(errorMsg))
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @errorMsg <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    <section>
        @if (Model.CanModifyInfo)
        {
            <partial name="Details.InfoModify" model="Model.ModifyInfo" />
        }
        else
        {
            <partial name="Details.Info" model="Model.Info" />
        }
        <partial name="Details.Items" model="Model.Info" view-data="ViewData" />
    </section>
</section>
@if (Model.Info.CanAddItems)
{
    <section class="content-data p-4 mb-5 shadow border rounded">
        <partial name="Details.AddItem" model="Model.AddItemModel" />
    </section>
}
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
