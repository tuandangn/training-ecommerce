@model PurchaseOrderDetailsModel
@{
    ViewData[ViewConstants.PageTitle] = $"Đơn nhập hàng - {Model.Info.Code}";
    
    var successMessage = TempData[ViewConstants.PurchaseOrderSuccessMessage] as string;
    var errorMessage = TempData[ViewConstants.PurchaseOrderErrorMessage] as string;
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-action="Index" asp-controller="Home" class="text-decoration-none">Trang chủ</a></li>
        <li class="breadcrumb-item"><a asp-action="List" class="text-decoration-none">Đơn nhập</a></li>
        <li class="breadcrumb-item active" aria-current="page">
            @if (Model.CanModifyInfo)
            {
                @:Chỉnh sửa
            }
            else
            {
                @:Xem chi tiết
            }
        </li>
    </ol>
</nav>
<div class="content-card mb-3">
    <div class="content-card-header">
        <div>
            <h1 class="page-header-title">
                @if (Model.CanModifyInfo)
                {
                    @:Chỉnh sửa đơn
                }
                else
                {
                    @:Xem chi tiết
                }
                @{
                    var status = (PurchaseOrderStatus)Model.Info.Status;
                }
                <span class="text-primary small">@Model.Info.Code</span>
                <span class="text-muted small">
                    <span class="status-badge @status.GetDisplayColor()">
                        @status.GetDisplayText()
                    </span>
                </span>
            </h1>
            <p class="page-header-subtitle">
                <span>Ngày tạo @Model.Info.CreatedOn.ToString(ViewConstants.DefaultDateTimeFormat)</span>
            </p>
        </div>
        <div class="d-flex gap-2 flex-grow-1 flex-lg-grow-0 justify-content-between justify-content-lg-center">
            @if (Model.Info.Status != (int)PurchaseOrderStatus.Completed && Model.Info.Status != (int)PurchaseOrderStatus.Cancelled)
            {
                <form asp-action="CancelPurchaseOrder" asp-route-id="@Model.Info.Id" method="post" class="d-inline">
                    <button type="submit" class="btn btn-outline-danger">
                        <i class="bi bi-x-circle me-1"></i> Hủy đơn
                    </button>
                </form>
            }
            @if (Model.Info.Status == (int)PurchaseOrderStatus.Draft)
            {
                <form asp-action="SubmitsPurchaseOrder" asp-route-id="@Model.Info.Id" method="post" class="d-inline">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-send me-1"></i> Gửi đơn
                    </button>
                </form>
            }
            else if (Model.Info.Status == (int)PurchaseOrderStatus.Submitted)
            {
                <form asp-action="ChangeStatus" asp-route-id="@Model.Info.Id" asp-route-status="@((int)PurchaseOrderStatus.Approved)" method="post" class="d-inline">
                    <button type="submit" class="btn btn-info text-white">
                        <i class="bi bi-check-all me-1"></i> Duyệt đơn
                    </button>
                </form>
            }
        </div>
    </div>
</div>
@if (!string.IsNullOrEmpty(successMessage))
{
    <div class="alert alert-success alert-dismissible fade show alert-global mb-3" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i>@successMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger alert-dismissible fade show alert-global mb-3" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-2"></i>@errorMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="row g-3">
    <div class="col-lg-8">
        <div class="content-card mb-3">
            <div class="content-card-header">
                <h5>
                    <i class="bi bi-box-seam me-2 text-primary"></i>
                    Danh sách hàng hóa
                </h5>
                @if (Model.Info.CanAddItems)
                {
                    <button type="button" class="btn btn-sm btn-outline-secondary" data-bs-toggle="modal" data-bs-target="#addProductModal">
                        <i class="bi bi-plus-lg me-1"></i>
                        <span class="d-none d-lg-inline">Thêm hàng hóa</span>
                        <span class="d-lg-none">Thêm</span>
                    </button>
                }
            </div>
            <div class="table-responsive">
                <table class="table data-table mb-0">
                    <thead>
                        <tr>
                            <th class="ps-3">Hàng hóa</th>
                            <th class="text-end">Số lượng</th>
                            <th class="text-end">Đã Nhận</th>
                            <th class="text-end">Đơn giá</th>
                            <th class="text-end d-none d-md-table-cell @(Model.Info.CanAddItems ? "" : "pe-3")">Thành tiền</th>
                            @if (Model.Info.CanAddItems || Model.Info.CanReceiveGoods)
                            {
                                <th class="text-end pe-2"></th>
                            }
                        </tr>
                    </thead>
                    <tbody id="itemsTableBody">
                        @if (Model.Info.Items.Count > 0)
                        {
                            @for (var i = 0; i < Model.Info.Items.Count; i++)
                            {
                                var item = Model.Info.Items[i];
                                <tr id="row-@i" data-item-id="@item.Id">
                                    <td class="ps-3">
                                        <div class="d-flex align-items-center gap-2">
                                            @if (!string.IsNullOrEmpty(item.ProductPicture))
                                            {
                                                <img src="@item.ProductPicture" class="rounded d-none d-lg-block"
                                                     style="width: 40px; height: 40px; object-fit: cover;" alt="@item.ProductName" />
                                            }
                                            else
                                            {
                                                <div class="d-flex align-items-center justify-content-center rounded bg-light"
                                                     style="width: 40px; height: 40px;">
                                                    <i class="bi bi-image text-muted"></i>
                                                </div>
                                            }
                                            <span class="fw-medium product-name">@item.ProductName</span>
                                        </div>
                                        <input type="hidden" class="product-id" value="@item.ProductId"/>
                                    </td>
                                    <td class="text-end">
                                        <span class="quantity-text">@item.QuantityOrdered.DisplayQuantity()</span>
                                        <input type="hidden" class="row-qty" value="@item.QuantityOrdered" />
                                    </td>
                                    <td class="text-end">
                                        @if (item.QuantityReceived >= item.QuantityOrdered)
                                        {
                                            <span class="status-badge success py-1 px-2">
                                                <i class="bi bi-check-circle-fill"></i> @item.QuantityReceived.DisplayQuantity()
                                            </span>
                                        }
                                        else if (item.QuantityReceived > 0)
                                        {
                                            <span class="status-badge warning py-1 px-2">
                                                @item.QuantityReceived.DisplayQuantity()
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="text-muted fst-italic small">Chưa nhận</span>
                                        }
                                    </td>
                                    <td class="text-end text-muted">
                                        <span class="unit-price-text text-nowrap">
                                            @item.UnitCost.DisplayCurrency()
                                        </span>
                                    </td>
                                    <td class="text-end fw-600 text-primary d-none d-md-table-cell @(Model.Info.CanAddItems ? "" : "pe-4")">
                                        <span class="total-price-text">
                                            @item.TotalCost.DisplayCurrency()
                                        </span>
                                    </td>
                                    @if (Model.Info.CanAddItems || (Model.Info.CanReceiveGoods && item.RemainingQuantity > 0))
                                    {
                                        <td class="text-end pe-4">
                                            <div class="dropdown">
                                                <button class="btn-table-action" type="button" data-bs-toggle="dropdown">
                                                    <i class="bi bi-three-dots-vertical"></i>
                                                </button>
                                                <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0">
                                                    @if (Model.Info.CanReceiveGoods && item.RemainingQuantity > 0)
                                                    {
                                                        <li>
                                                            <button class="dropdown-item" data-bs-toggle="modal" data-bs-target="#receiveItemModal"
                                                                    data-item-id="@item.Id" data-item-name="@item.ProductName" data-item-remaining="@item.RemainingQuantity">
                                                                <i class="bi bi-truck"></i>
                                                                Nhận hàng
                                                            </button>
                                                        </li>
                                                    }
                                                    @if (Model.Info.CanAddItems)
                                                    {
                                                        <li>
                                                            <button class="dropdown-item btnRemoveItem" data-id="@item.Id"
                                                                    disabled="@(Model.Info.Items.Count <= 1)"
                                                                    data-purchaseorder="@Model.Info.Id" data-name="@item.ProductName">
                                                                <i class="bi bi-trash me-2 text-danger"></i>
                                                                Xóa bỏ
                                                            </button>
                                                        </li>
                                                    }
                                                </ul>
                                            </div>
                                        </td>
                                    }

                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="@(Model.Info.CanAddItems ? 6 : 5)">
                                    <div class="py-4 text-center text-muted">
                                        <i class="bi bi-box-seam me-1"></i> Chưa có sản phẩm nào.
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="@(Model.Info.Items.Count > 0 ? "" : "d-none") order-summary" id="tableFooter">
                <div class="order-summary-row">
                    <span class="label">Tạm tính</span>
                    <span class="value" id="subTotal">
                        @((Model.Info.TotalAmount - Model.Info.TaxAmount - Model.Info.ShippingAmount).ToString(ViewConstants.CurrencyDisplayFormat))
                    </span>
                </div>
                @if (Model.Info.ShippingAmount > 0)
                {
                    <div class="order-summary-row">
                        <span class="label">Phí vận chuyển</span>
                        <span class="value text-muted">
                            @Model.Info.ShippingAmount.ToString(ViewConstants.CurrencyDisplayFormat)
                        </span>
                    </div>
                }
                @if (Model.Info.TaxAmount > 0)
                {
                    <div class="order-summary-row">
                        <span class="label">Thuế VAT</span>
                        <span class="value text-muted">
                            + @Model.Info.TaxAmount.ToString(ViewConstants.CurrencyDisplayFormat)
                        </span>
                    </div>
                }
                <div class="order-summary-row total">
                    <span class="label">Tổng cộng</span>
                    <span class="value" id="grandTotal">
                        @Model.Info.TotalAmount.ToString(ViewConstants.CurrencyDisplayFormat)
                    </span>
                </div>
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        @if (Model.CanModifyInfo && Model.ModifyInfo != null)
        {
            <div class="content-card mb-3">
                <div class="content-card-header">
                    <h5>
                        <i class="bi bi-pencil-square me-2 text-primary"></i>
                        Thông tin đơn nhập
                    </h5>
                </div>
                <div class="content-card-body">
                    <partial name="Details.InfoModify" model="Model.ModifyInfo" />
                </div>
            </div>
        }
        else
        {
            <partial name="Details.Info" model="Model" />
        }
    </div>
</div>

@if (Model.Info.CanAddItems)
{
    <div class="modal fade" id="addProductModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow rounded-4">
                <div class="modal-header border-0 pb-0">
                    <h5 class="modal-title fw-bold">Thêm sản phẩm</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <form asp-action="AddPurchaseOrderItem" method="post" id="addProductForm">
                    <input type="hidden" name="purchaseOrderId" value="@Model.Info.Id" />
                    <div class="modal-body py-3">
                        <div class="mb-3">
                            <div id="productPicker"></div>
                            <input type="text" class="visually-hidden" id="itemProductId" name="ProductId" value=""
                                data-val="true" data-val-required="Vui lòng chọn hàng hóa"/>
                            <span class="small text-danger field-validation-valid"
                                  data-valmsg-for="ProductId" data-valmsg-replace="true"></span>
                        </div>
                        <div id="modalProductInfo" class="d-none">
                            <div class="row g-2">
                                <div class="col-6">
                                    <label class="form-label small fw-medium text-muted" for="itemQuantity">Số lượng</label>
                                    <input id="itemQuantity" name="quantity" class="form-control no-additional-element"
                                           data-decimal="quantity" value="1"
                                           data-val="true" data-val-required="Vui lòng nhập số lượng"
                                           data-val-range="Số lượng phải lớn hơn 0" data-val-range-min="0.0001"
                                           data-val-number="Số lượng phải là số" />
                                    <span class="small text-danger field-validation-valid"
                                          data-valmsg-for="quantity" data-valmsg-replace="true"></span>
                                </div>
                                <div class="col-6">
                                    <label class="form-label small fw-medium text-muted" for="itemUnitPrice">Đơn giá</label>
                                    <input id="itemUnitPrice" name="unitCost" class="form-control no-additional-element"
                                           data-decimal="currency"
                                           data-val="true" data-val-required="Vui lòng nhập đơn giá."
                                           data-val-number="Đơn giá phải là số" />
                                    <span class="small text-danger field-validation-valid"
                                          data-valmsg-for="unitCost" data-valmsg-replace="true"></span>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer border-0 pt-0 pb-3">
                        <button type="button" class="btn btn-light" data-bs-dismiss="modal">Hủy</button>
                        <button type="submit" id="btnAddItem" class="btn btn-success d-none">
                            <i class="bi bi-plus-lg me-1"></i>Thêm vào
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}

@if (Model.Info.CanReceiveGoods)
{
    <div class="modal fade" id="receiveItemModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow rounded-4">
                <div class="modal-header border-0 pb-0">
                    <h5 class="modal-title fw-bold">Nhập hàng</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <form asp-action="Receive" method="post">
                    <div class="modal-body py-4">
                        <input type="hidden" name="PurchaseOrderId" value="@Model.Info.Id" />
                        <input type="hidden" name="PurchaseOrderItemId" id="modalItemId" />
                        
                        <div class="alert alert-info border-0 mb-4">
                            <div class="small fw-bold">
                                Sản phẩm:
                                <span id="modalItemName" class="fs-6 fw-bold text-dark">Tên sản phẩm</span>
                            </div>
                            <div class="small mt-1 mt-1 fst-italic">
                                Còn lại cần nhập:
                                <span id="modalItemRemaining" class="fw-bold">0</span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label small fw-bold text-muted text-uppercase">Số lượng nhận</label>
                            <input name="ReceivedQuantity" id="modalReceivedQty" class="form-control no-additional-element no-hint" data-decimal="quantity" value="0" required />
                        </div>

                        <div class="mb-3">
                            <label class="form-label small fw-bold text-muted text-uppercase">Kho nhập hàng</label>
                            <select name="WarehouseId" class="form-select" required>
                                @foreach (var option in Model.AvailableWarehouses.Options)
                                {
                                    <option value="@option.Id" selected="@(Model.Info.WarehouseId == option.Id)">@option.Name</option>
                                }
                            </select>
                        </div>
                    </div>
                    <div class="modal-footer border-0 pt-0 pb-4">
                        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Đóng</button>
                        <button type="submit" class="btn btn-success">
                            Xác nhận nhập kho
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    
    <script type="module">
        import ProductPicker from '/modules/ProductPicker.js';

        let productPickerInstance = null;

        document.addEventListener('DOMContentLoaded', function() {
        // Initialize Product Picker for Add Product Modal
        const addProductModal = document.getElementById('addProductModal');
        if (addProductModal) {
        initializeProductPicker();

        addProductModal.addEventListener('hidden.bs.modal', function() {
        // Reset form when modal closes
        resetAddProductForm();
        });
        }

        // Handle Add Product Form Submission
        const addProductForm = document.getElementById('addProductForm');
        if (addProductForm) {
        addProductForm.addEventListener('submit', async function(e) {
        e.preventDefault();
        if(!$(this).valid())
        return;
        await submitAddProductForm();
        });
        }

        // Initialize Receive Item Modal
        const receiveItemModal = document.getElementById('receiveItemModal');
        if (receiveItemModal) {
        receiveItemModal.addEventListener('show.bs.modal', function(event) {
        const button = event.relatedTarget;
        const itemId = button.getAttribute('data-item-id');
        const itemName = button.getAttribute('data-item-name');
        const remainingRaw = button.getAttribute('data-item-remaining');
        const remaining = DecimalFields.formatQuantity(remainingRaw);

        document.getElementById('modalItemId').value = itemId;
        document.getElementById('modalItemName').innerText = itemName;
        document.getElementById('modalItemRemaining').innerText = remaining;
        document.getElementById('modalReceivedQty').value = remaining;
        document.getElementById('modalReceivedQty').max = remainingRaw;
        });
        }

        // Handle Remove Item Button
        document.querySelectorAll('.btnRemoveItem').forEach(btn => {
        btn.addEventListener('click', async function(e) {
        e.preventDefault();
        const itemId = this.getAttribute('data-id');
        const purchaseOrderId = this.getAttribute('data-purchaseorder');
        const itemName = this.getAttribute('data-name');

        if (confirm(`Bạn có chắc chắn muốn xóa "${itemName}" khỏi đơn hàng?`)) {
        await removeItem(itemId, purchaseOrderId);
        }
        });
        });
        });

        function initializeProductPicker() {
        const container = document.getElementById('productPicker');
        if (container && !productPickerInstance) {
        productPickerInstance = new ProductPicker(container);
        container.addEventListener('select', (e) => {
        onProductSelected(e.detail.product);
        });
        container.addEventListener('remove', onProductRemove);
        }
        }

        function onProductSelected(product) {
        const modalProductInfo = document.getElementById('modalProductInfo');
        const itemUnitPrice = document.getElementById('itemUnitPrice');
        const itemProductId = document.getElementById('itemProductId');
        const btnAddProduct = document.getElementById('btnAddItem');

        modalProductInfo.classList.remove('d-none');
        itemUnitPrice.value = 0;
        itemProductId.value = product.id;
        btnAddProduct.classList.remove('d-none');
        }
        function onProductRemove() {
        const modalProductInfo = document.getElementById('modalProductInfo');
        const itemUnitPrice = document.getElementById('itemUnitPrice');
        const itemProductId = document.getElementById('itemProductId');
        const btnAddProduct = document.getElementById('btnAddItem');

        modalProductInfo.classList.add('d-none');
        itemUnitPrice.value = 0;
        itemProductId.value = '';
        btnAddProduct.classList.add('d-none');
        }

        async function submitAddProductForm() {
        const form = document.getElementById('addProductForm');

        try {
        const response = await fetch('@Url.Action("AddPurchaseOrderItem")', {
        method: 'POST',
        headers: {
        'Content-Type': 'application/x-www-form-urlencoded',
        },
        body: $(form).serialize()
        });

        const data = await response.json();

        if (data.success) {
        // Close modal and refresh page
        bootstrap.Modal.getInstance(document.getElementById('addProductModal'))?.hide();
        setTimeout(() => location.reload(), 300);
        } else {
        alert('Lỗi: ' + (data.errorMessage || 'Không thể thêm sản phẩm'));
        }
        } catch (error) {
        console.error('Error:', error);
        alert('Có lỗi xảy ra khi thêm sản phẩm');
        }
        }

        function resetAddProductForm() {
        document.getElementById('itemQuantity').value = '1';
        document.getElementById('itemUnitPrice').value = '';
        document.getElementById('modalProductInfo').classList.add('d-none');

        if (productPickerInstance) {
        productPickerInstance.clear();
        }
        }

        async function removeItem(itemId, purchaseOrderId) {
        try {
        const response = await fetch('@Url.Action("RemovePurchaseOrderItem")', {
        method: 'POST',
        headers: {
        'Content-Type': 'application/json',
        'RequestVerificationToken': document.querySelector('[name="__RequestVerificationToken"]')?.value || ''
        },
        body: JSON.stringify({
        purchaseOrderItemId: itemId,
        purchaseOrderId: purchaseOrderId
        })
        });

        const data = await response.json();

        if (data.success) {
        // Remove row from table
        document.querySelector(`tr[data-item-id="${itemId}"]`)?.remove();

        // Refresh page after short delay
        setTimeout(() => location.reload(), 300);
        } else {
        alert('Lỗi: ' + (data.errorMessage || 'Không thể xóa sản phẩm'));
        }
        } catch (error) {
        console.error('Error:', error);
        alert('Có lỗi xảy ra khi xóa sản phẩm');
        }
        }

    </script>
    <script type="module">
        import {Vendor, default as VendorPicker} from '/modules/VendorPicker.js';

        (() => {
            const elementVendorPicker = document.getElementById('vendorPicker');
            if (!elementVendorPicker)
                return;

            let editPurchaseOrderState = {

            };
            function setState(patch){
                const newState = Object.assign({}, editPurchaseOrderState, patch);
                editPurchaseOrderState = newState;
                renderState();
            }
            function renderState() {
                getEl('VendorId').value = editPurchaseOrderState.vendor?.id ?? '';
            }

            const {vendorPicker, vendor} = bindVendorPicker();

            setState({ vendor });

            function bindVendorPicker() {
                const vendorPicker = new VendorPicker(elementVendorPicker);

                elementVendorPicker.addEventListener('select', (e) => {
                    setState({ vendor: e.detail?.vendor ? new Vendor(e.detail.vendor) : null });
                });
                elementVendorPicker.addEventListener('remove', () => {
                     setState({ vendor: null });
                });

                const initialVendor = elementVendorPicker.dataset;
                if (initialVendor.id) {
                    var vendor = new Vendor(initialVendor);
                    vendorPicker.displayVendor(vendor);
                    return {vendorPicker, vendor: initialVendor};
                }
                return {vendorPicker, vendor: null};
            }
        })();
    </script>
}
