@model AddPurchaseOrderItemModel
@{
    var errorMsg = TempData[ViewConstants.PurchaseOrderAddItemErrorMessage] as string;
}
<h6 class="text-muted">Thêm hàng hóa vào đơn</h6>
@if (!string.IsNullOrEmpty(errorMsg))
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @errorMsg <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
<form asp-action="AddPurchaseOrderItem" method="post" class="row g-2 align-items-start" asp-antiforgery="true" novalidate>
    <input type="hidden" asp-for="PurchaseOrderId" id="addItemPurchaseOrderId" />
    <div class="col-lg-4 col-md-6 col-6">
        <div class="form-floating">
            <select name="ProductId" class="form-select form-select-sm" data-val="true" data-val-required="Vui lòng chọn hàng hóa">
                <option value="">(Không chọn)</option>
                @foreach (var product in Model.AvailableProducts)
                {
                    <option value="@product.Id" selected="@(Model.ProductId == product.Id)">@product.Name</option>
                }
            </select>
            <label asp-for="ProductId" class="form-label" style="font-weight:600;"></label>
        </div>
        <span asp-validation-for="ProductId" class="text-danger small"></span>
    </div>
    <div class="col-lg-2 col-md-3 col-6">
        <div class="form-floating">
            <input type="number" asp-for="Quantity" class="form-control form-control-sm" min="0" step="any" value="@(Model.Quantity ?? 0)"
                   data-val-range="Số lượng phải lớn hơn 0." data-val-range-min="0.000000000000000001"
                   data-val-number="Số lượng không đúng." />
            <label asp-for="Quantity" class="form-label" style="font-weight:600;"></label>
        </div>
        <span asp-validation-for="Quantity" class="text-danger small"></span>
    </div>
    <div class="col-lg-2 col-md-3 col-6">
        <div class="form-floating">
            <input type="number" asp-for="UnitCost" class="form-control form-control-sm" min="0" value="@(Model.UnitCost ?? 0)"
                   data-val-range="Đơn giá phải lớn hơn 0." data-val-range-min="0"
                   data-val-number="Đơn giá không đúng." />
            <label asp-for="UnitCost" class="form-label" style="font-weight:600;"></label>
        </div>
        <span asp-validation-for="UnitCost" class="text-danger small"></span>
    </div>
    <div class="col-lg-4 col-md-12 col-6">
        <div class="form-floating">
            <input type="text" asp-for="Note" class="form-control form-control-sm" />
            <label asp-for="Note" class="form-label" style="font-weight:600;"></label>
        </div>
        <span asp-validation-for="Note" class="text-danger small"></span>
    </div>
    <div class="col-12">
        <button type="submit" class="btn btn-secondary">
            <i class="bi bi-plus"></i>
            Thêm hàng hóa
        </button>
    </div>
</form>
