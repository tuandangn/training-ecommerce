@model CreatePurchaseOrderModel
@using System.Text.Json
@{
    ViewData["Title"] = "Thêm đơn nhập";
}
<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-action="Index" asp-controller="Home" class="text-decoration-none">Trang chủ</a></li>
        <li class="breadcrumb-item"><a asp-action="List" class="text-decoration-none">Đơn nhập</a></li>
        <li class="breadcrumb-item active" aria-current="page">Thêm mới</li>
    </ol>
</nav>
<div class="content-card mb-3">
    <div class="content-card-header">
        <div>
            <h1 class="page-header-title">Thêm đơn nhập</h1>
            <p class="page-header-subtitle">Thêm mới đơn nhập hàng</p>
        </div>
    </div>
</div>
<div>
    <div asp-validation-summary="ModelOnly" class="alert alert-warning alert-global alert-dismissible"></div>
    <form method="post" id="createPurchaseOrderForm" asp-antiforgery="true">
        <div class="row g-3">
            <div class="col-lg-8">
                <div class="content-card">
                    <div class="content-card-header">
                        <h5>
                            <i class="bi bi-box-seam me-2 text-primary"></i>
                            Danh sách hàng hóa
                        </h5>
                        <button type="button" class="btn btn-sm btn-outline-secondary" data-bs-toggle="modal"
                                data-bs-target="#addProductModal">
                            <i class="bi bi-plus-lg me-1"></i>
                            <span class="d-none d-lg-inline">Thêm hàng hóa</span>
                            <span class="d-lg-none">Thêm</span>
                        </button>
                    </div>
                    <div>
                        <div class="table-responsive">
                            <table class="table data-table mb-0" id="purchaseOrderItemsTable">
                                <thead>
                                    <tr>
                                        <th class="ps-3">Sản phẩm</th>
                                        <th class="text-center">Số lượng</th>
                                        <th class="text-end">Đơn giá</th>
                                        <th class="text-end d-none d-lg-table-cell">Thành tiền</th>
                                        <th></th>
                                    </tr>
                                </thead>
                                <tbody id="itemsTableBody">
                                    @for (var i = 0; i < Model.Items.Count; i++)
                                    {
                                        var item = Model.Items[i];
                                        <tr id="row-@i">
                                            <td class="ps-3">
                                                <div class="d-flex align-items-center gap-2">
                                                    @if (!string.IsNullOrEmpty(item.ProductDisplayPicture))
                                                    {
                                                        <img src="@item.ProductDisplayPicture" class="rounded product-picture"
                                                             style="width:40px; height:40px; object-fit:cover;" alt="@item.ProductDisplayName"/>
                                                    }
                                                    else
                                                    {
                                                        <div class="d-flex align-items-center justify-content-center rounded bg-light"
                                                             style="width: 40px; height: 40px;">
                                                            <i class="bi bi-image text-muted"></i>
                                                        </div>
                                                    }
                                                    <div class="fw-medium product-name">@item.ProductDisplayName</div>
                                                </div>
                                                <input type="text" class="visually-hidden product-id"
                                                       name="Items[@i].ProductId" value="@item.ProductId" data-val="true"
                                                       data-val-required="Vui lòng chọn hàng hóa." />
                                                <span class="small text-danger field-validation-valid"
                                                      data-valmsg-for="Items[@i].ProductId" data-valmsg-replace="true"></span>
                                            </td>
                                            <td class="text-center">
                                                <input type="number" asp-for="Items[@i].Quantity" data-decimal="quantity"
                                                       class="form-control form-control-sm text-center row-qty" />
                                                <span class="small text-danger field-validation-valid"
                                                      data-valmsg-for="Items[@i].Quantity" data-valmsg-replace="true"></span>
                                            </td>
                                            <td class="text-end">
                                                <input type="number" asp-for="Items[@i].UnitCost" data-decimal="currency"
                                                       class="form-control form-control-sm text-end row-price no-additional-element" min="0"
                                                       data-val="true" data-val-required="Vui lòng nhập đơn giá."
                                                       placeholder="0" />
                                                <span class="small text-danger field-validation-valid"
                                                      data-valmsg-for="Items[@i].UnitCost" data-valmsg-replace="true"></span>
                                            </td>
                                            <td class="text-end fw-bold text-danger row-total text-nowrap d-none d-lg-table-cell">
                                                @item.ItemSubTotal.DisplayCurrency()
                                            </td>
                                            <td class="text-end pe-3">
                                                <button type="button"
                                                        class="btn-table-action danger border-0 bg-transparent shadow-none">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                        <div class="@(Model.Items.Count > 0 ? "" : "d-none") order-summary" id="tableFooter">
                            <div class="order-summary-row">
                                <span class="label">Tạm tính</span>
                                <span class="value" id="subTotal">@Model.OrderSubTotal.DisplayCurrency()</span>
                            </div>
                            <div class="order-summary-row total">
                                <span class="label">Tổng cộng</span>
                                <span class="value" id="grandTotal">
                                    @Model.OrderTotal.DisplayCurrency()
                                </span>
                            </div>
                        </div>
                        <div id="noItemsMessage" class="py-4 text-center text-muted" style="@(Model.Items.Count == 0 ? "display:block" : "display:none")">
                            Chưa có hàng hóa nào
                            <div class="mt-1">
                                <span asp-validation-for="Items" class="text-danger small"></span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-lg-4">
                <div class="content-card mb-2">
                    <div class="content-card-header">
                        <h5>
                            <i class="bi bi-pencil-square me-2 text-primary"></i>
                            Thông tin đơn nhập
                        </h5>
                    </div>
                    <div class="content-card-body">
                        <div class="mb-3">
                            <div class="row g-3">
                                <div class="col-12">
                                    <label for="vendorSearch" class="form-label small fw-bold text-muted text-uppercase d-block">Nhà cung cấp</label>
                                    <div>
                                        <div id="vendorPicker" data-id="@Model.VendorId" data-name="@Model.VendorName" data-phone="@Model.VendorPhone" data-address="@Model.VendorAddress"></div>
                                        <input type="text" class="visually-hidden" asp-for="VendorId" />
                                        <span asp-validation-for="VendorId" class="small text-danger"></span>
                                    </div>
                                </div>
                                <div class="col-12">
                                    <label asp-for="WarehouseId" class="form-label small fw-bold text-muted text-uppercase d-block"></label>
                                    <select asp-for="WarehouseId" class="form-select">
                                        <option value="" selected="@(!Model.WarehouseId.HasValue)">(Không chọn)</option>
                                        @foreach (var warehouse in Model.AvailableWarehouses)
                                        {
                                            <option value="@warehouse.Id" selected="@(Model.WarehouseId == warehouse.Id)">@warehouse.Name</option>
                                        }
                                    </select>
                                    <span asp-validation-for="WarehouseId" class="small text-danger"></span>
                                </div>
                                <div class="col-12">
                                    <label asp-for="ExpectedDeliveryDate" class="form-label small fw-bold text-muted text-uppercase d-block"></label>
                                    <input asp-for="ExpectedDeliveryDate" class="form-control" type="date" />
                                    <span asp-validation-for="ExpectedDeliveryDate" class="text-danger small"></span>
                                </div>
                            </div>
                        </div>
                        <div class="mb-3">
                            <label asp-for="Note" class="form-label small fw-bold text-muted text-uppercase d-block"></label>
                            <textarea asp-for="Note" class="form-control" rows="2" placeholder="Nhập ghi chú về đơn nhập..."></textarea>
                            <span asp-validation-for="Note" class="text-danger small"></span>
                        </div>
                        <div class="d-grid">
                            <button type="submit" class="btn btn-primary" disabled id="btnSubmitPurchaseOrder">
                                <i class="bi bi-check2 me-1"></i>Tạo đơn
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

<div class="modal fade" id="addProductModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow rounded-4">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold">Thêm sản phẩm</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form action="#" method="post" id="addProductForm">
                <div class="modal-body py-3">
                    <div class="mb-3">
                        <div id="productPicker"></div>
                    </div>
                    <div id="modalProductInfo" class="d-none">
                        <div class="row g-2">
                            <div class="col-6">
                                <label class="form-label small fw-medium text-muted" for="itemQuantity">Số lượng</label>
                                <input id="itemQuantity" name="itemProductQuantity" class="form-control no-additional-element"
                                       data-decimal="quantity" value="1"
                                       data-val="true" data-val-required="Vui lòng nhập số lượng"
                                       data-val-range="Số lượng phải lớn hơn 0" data-val-range-min="0.0001"
                                       data-val-number="Số lượng phải là số" />
                                <span class="small text-danger field-validation-valid"
                                      data-valmsg-for="itemProductQuantity" data-valmsg-replace="true"></span>
                            </div>
                            <div class="col-6">
                                <label class="form-label small fw-medium text-muted" for="itemUnitPrice">
                                    Đơn giá
                                </label>
                                <input id="itemUnitPrice" name="itemUnitPrice" class="form-control no-additional-element"
                                       data-decimal="currency"
                                       data-val="true" data-val-required="Vui lòng nhập đơn giá."
                                       data-val-number="Đơn giá phải là số" />
                                <span class="small text-danger field-validation-valid"
                                      data-valmsg-for="itemUnitPrice" data-valmsg-replace="true"></span>
                            </div>
                        </div>
                        <div id="recentPricesHint" class="mt-2 d-none">
                            <div id="recentPricesAutoFillInfo" class="d-none small text-success mb-1">
                                <i class="bi bi-check-circle-fill me-1"></i>
                                <span id="recentPricesAutoFillText"></span>
                            </div>
                            <div class="border rounded-3 bg-light p-2 mt-1">
                                <div class="small fw-semibold text-muted mb-1">
                                    <i class="bi bi-clock-history me-1"></i> Giá nhập gần nhất theo nhà cung cấp
                                </div>
                                <div id="recentPricesTableWrapper">
                                    <table class="table table-sm table-borderless mb-0 small" id="recentPricesTable">
                                        <thead class="text-muted">
                                            <tr>
                                                <th class="ps-0 py-1">Nhà cung cấp</th>
                                                <th class="text-end py-1">Giá nhập</th>
                                                <th class="text-end py-1 text-nowrap">Ngày</th>
                                            </tr>
                                        </thead>
                                        <tbody id="recentPricesTbody"></tbody>
                                    </table>
                                </div>
                                <div id="recentPricesEmpty" class="text-muted fst-italic small d-none py-1">
                                    Chưa có lịch sử nhập hàng cho sản phẩm này.
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-0 pt-0 pb-3">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" id="addItemToTable" class="btn btn-success d-none">
                        <i class="bi bi-plus-lg me-1"></i>Thêm vào
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script type="module">
        import CreatePurchaseOrderController from "/modules/CreatePurchaseOrderController.js";

        new CreatePurchaseOrderController();

        const addProductContainer = document.getElementById('addProductModal');
        const addProductModal = bootstrap.Modal.getOrCreateInstance(addProductContainer);
        addProductContainer.addEventListener('hidden.bs.modal', () => {
            const searchInput = addProductContainer.querySelector('.productSearch');
            if (searchInput)
                searchInput.value = '';
        });
        document.addEventListener('purchaseOrder:itemAdded', () => {
            addProductModal.hide();
        });
    </script>
}
