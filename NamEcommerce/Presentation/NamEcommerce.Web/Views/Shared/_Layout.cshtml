@inject IWebHelper WebHelper
@{
    var errorMessage = TempData[ViewConstants.GlobalErrorMessage] as string;
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData[ViewConstants.PageTitle] - @Information.Name</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/lib/bootstrap-icons-1.13.1/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/NamEcommerce.Web.styles.css" asp-append-version="true" />

    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="vh-100">
    <div class="d-flex flex-column h-100">
        <header>
            <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
                <div class="container-fluid">
                    <a class="navbar-brand" asp-controller="Home" asp-action="Index">@Information.Name</a>
                    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                            aria-expanded="false" aria-label="Toggle navigation">
                        <span class="navbar-toggler-icon"></span>
                    </button>
                    <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                        <ul class="navbar-nav flex-grow-1">
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Home" asp-action="Index">Trang chủ</a>
                            </li>
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle @(WebHelper.IsHasController("Category", "Product") ? "active" : "")" href="#" id="catalogMenuItemsDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    Hàng hóa
                                </a>
                                <ul class="dropdown-menu" aria-labelledby="navbarDropdown">
                                    <li><a class="dropdown-item @(WebHelper.IsMatchRouteInfo("Product") ? "active" : "")" asp-controller="Product" asp-action="Index">Hàng hóa</a></li>
                                    <li><a class="dropdown-item @(WebHelper.IsMatchRouteInfo("Category") ? "active" : "")" asp-controller="Category" asp-action="Index">Danh mục</a></li>
                                </ul>
                            </li>
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle @(WebHelper.IsHasController("Vendor", "UnitMeasurement") ? "active": "")" href="#" id="otherMenuItemsDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    Khác
                                </a>
                                <ul class="dropdown-menu" aria-labelledby="navbarDropdown">
                                    <li><a class="dropdown-item @(WebHelper.IsMatchRouteInfo("Vendor") ? "active" : "")" asp-controller="Vendor" asp-action="Index">Nhà cung cấp</a></li>
                                    <li><a class="dropdown-item @(WebHelper.IsMatchRouteInfo("UnitMeasurement") ? "active" : "")" asp-controller="UnitMeasurement" asp-action="Index">Đơn vị tính</a></li>
                                </ul>
                            </li>
                        </ul>
                        @await Component.InvokeAsync("UserHeaderLinksComponent")
                    </div>
                </div>
            </nav>
        </header>

        <div class="container flex-grow-1 pb-5">
            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert alert-warning alert-dismissible fade show" role="alert">
                    @errorMessage
                </div>
            }
            <main role="main">
                @RenderBody()
            </main>
        </div>

        <footer class="border-top footer text-muted py-2">
            <div class="container">
                &copy; 2026 - @Information.Name
            </div>
        </footer>
    </div>
    <partial name="_ReusedModals" />

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js" defer></script>
    <script src="~/js/site.js" asp-append-version="true" defer></script>
    <script src="~/modules/common.js" type="module" defer asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
