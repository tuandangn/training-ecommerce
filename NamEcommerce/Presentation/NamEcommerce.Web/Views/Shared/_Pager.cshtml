@model PaginationModel
@if (Model.TotalCount <= 0)
{
    return;
}
@if (Model.TotalPages < Model.PageNumber)
{
    <div class="pager-wrapper">
        <div class="alert alert-info mb-0 py-2 px-3 small">
            Không có dữ liệu ở trang này. Tổng: <strong>@Model.TotalCount</strong>
        </div>
        <div class="d-flex gap-2">
            <a asp-route-pageNumber="1" class="btn btn-sm btn-outline-secondary">
                <i class="bi bi-chevron-double-left"></i> Trang đầu
            </a>
            <a asp-route-pageNumber="@Model.TotalPages" class="btn btn-sm btn-outline-secondary">
                Trang cuối <i class="bi bi-chevron-double-right"></i>
            </a>
        </div>
    </div>
    return;
}
<div class="pager-wrapper">
    <div class="pager-info">
        @if (Model.TotalPages == 1)
        {
            <span>Tổng <strong>@Model.TotalCount</strong> bản ghi</span>
        }
        else
        {
            var from = Model.PageIndex * Model.PageSize + 1;
            var to = Model.PageNumber * Model.PageSize;
            if (to > Model.TotalCount) to = Model.TotalCount;
            if (from != to)
            {
                <span>Hiển thị <strong>@from – @to</strong> / @Model.TotalCount bản ghi</span>
            }
            else
            {
                <span>Bản ghi <strong>@from</strong> / @Model.TotalCount</span>
            }
        }
    </div>

    @if (Model.TotalPages > 1)
    {
        <nav aria-label="Page navigation">
            <ul class="pagination pagination-sm mb-0">
                <li class="page-item @(Model.PageIndex == 0 ? "disabled" : "")">
                    <a class="page-link" asp-route-pageNumber="@(Model.PageIndex)" aria-label="Trang trước">
                        <i class="bi bi-chevron-left"></i>
                    </a>
                </li>
                @for (var i = 0; i < Model.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.PageIndex ? "active" : "")">
                        <a class="page-link" asp-route-pageNumber="@(i + 1)">@(i + 1)</a>
                    </li>
                }
                <li class="page-item @(Model.PageNumber == Model.TotalPages ? "disabled" : "")">
                    <a class="page-link" asp-route-pageNumber="@(Model.PageNumber + 1)" aria-label="Trang sau">
                        <i class="bi bi-chevron-right"></i>
                    </a>
                </li>
            </ul>
        </nav>
    }
</div>