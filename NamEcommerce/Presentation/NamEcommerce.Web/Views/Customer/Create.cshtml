@using NamEcommerce.Web.Models.Customers
@model CreateCustomerModel
@{
    ViewData[ViewConstants.PageTitle] = "Thêm mới Khách hàng";
}

<div class="page-header">
    <div>
        <h1 class="page-header-title">Thêm mới Khách hàng</h1>
        <p class="page-header-subtitle">Tạo hồ sơ khách hàng mới</p>
    </div>
</div>

<div class="form-card">
    <div class="form-card-header">
        <h2 class="form-card-title"><i class="bi bi-person-circle me-2" style="color: #7c3aed;"></i>Thông tin khách hàng</h2>
        <a asp-action="List" class="form-card-breadcrumb">
            <i class="bi bi-arrow-left"></i> Trở về danh sách
        </a>
    </div>
    <div class="form-card-body">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="alert alert-warning alert-global mb-3"></div>
            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="FullName" class="form-label"></label>
                    <input asp-for="FullName" class="form-control" placeholder="Nhập họ tên đầy đủ" autofocus />
                    <span asp-validation-for="FullName" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="PhoneNumber" class="form-label"></label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-telephone text-muted"></i></span>
                        <input asp-for="PhoneNumber" class="form-control" placeholder="Số điện thoại liên lạc" />
                    </div>
                    <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                </div>
                <div class="col-12">
                    <label asp-for="Address" class="form-label"></label>
                    <textarea asp-for="Address" class="form-control" rows="2" placeholder="Địa chỉ thường trú"></textarea>
                    <span asp-validation-for="Address" class="text-danger small"></span>
                </div>
                <div class="col-12">
                    <label asp-for="Email" class="form-label"></label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-envelope text-muted"></i></span>
                        <input asp-for="Email" class="form-control" type="email" placeholder="Địa chỉ email" />
                    </div>
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>
                <div class="col-12">
                    <label asp-for="Note" class="form-label"></label>
                    <textarea asp-for="Note" class="form-control" rows="3" placeholder="Ghi chú thêm về khách hàng..."></textarea>
                    <span asp-validation-for="Note" class="text-danger small"></span>
                </div>
            </div>
            <div class="form-card-footer" style="margin: 1.5rem -1.5rem -1.5rem; border-radius: 0 0 var(--card-radius) var(--card-radius);">
                <a asp-action="List" class="btn btn-outline-secondary">Hủy</a>
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-plus-lg me-1"></i>Thêm mới
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
