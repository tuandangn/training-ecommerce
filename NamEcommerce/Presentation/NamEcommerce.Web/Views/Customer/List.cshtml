@using System.Text.Encodings.Web
@using NamEcommerce.Web.Contracts.Models.Customers
@using NamEcommerce.Web.Models.Customers
@inject UrlEncoder MyUrlEncoder
@model CustomerListModel
@{
    ViewData[ViewConstants.PageTitle] = "Khách hàng";
    var successMessage = TempData[ViewConstants.CustomerSuccessMessage] as string;
    var errorMessage = TempData[ViewConstants.CustomerErrorMessage] as string;
    string? query = Model.Keywords;
}

<div class="page-header">
    <div>
        <h1 class="page-header-title">Khách hàng</h1>
        <p class="page-header-subtitle">Quản lý thông tin khách hàng</p>
    </div>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-person-plus-fill me-1"></i>Thêm mới
    </a>
</div>

@if (!string.IsNullOrEmpty(successMessage))
{
    <div class="alert alert-success alert-dismissible fade show alert-global mb-3" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i>@successMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger alert-dismissible fade show alert-global mb-3" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-2"></i>@errorMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="content-card">
    <div class="action-toolbar">
        <partial name="_Search" model="@(new CustomerListSearchModel { Keywords = query })" />
    </div>

    <div class="table-responsive">
        <table class="table data-table">
            <thead>
                <tr>
                    <th class="ps-4">Họ tên</th>
                    <th><i class="bi bi-telephone me-1"></i>Điện thoại</th>
                    <th style="width: 100px;"></th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Data.Pagination.TotalCount > 0)
                {
                    @foreach (var item in Model.Data)
                    {
                        <tr>
                            <td class="ps-4 fw-medium">@item.FullName</td>
                            <td>
                                <a href="tel:@item.PhoneNumber" class="text-decoration-none text-muted">
                                    <i class="bi bi-telephone me-1"></i>@item.PhoneNumber
                                </a>
                            </td>
                            <td class="text-end pe-3">
                                <a class="btn-table-action me-1" asp-action="Edit" asp-route-id="@item.Id" title="Chỉnh sửa">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <button type="button" class="btn-table-action danger btnDelete"
                                        data-id="@item.Id" data-name="@item.FullName" title="Xóa">
                                    <i class="bi bi-trash"></i>
                                </button>
                                <form id="deleteForm@(item.Id)" asp-action="Delete" asp-route-id="@item.Id"
                                      method="post" style="display:none;"></form>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="3">
                            <div class="empty-state">
                                <div class="empty-icon"><i class="bi bi-people"></i></div>
                                <h5>Chưa có khách hàng nào</h5>
                                <p>Thêm khách hàng để bắt đầu quản lý.</p>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (Model.Data.Pagination.TotalCount > 0)
    {
        <partial name="_Pager" model="Model.Data.Pagination" />
    }
</div>

@section Scripts {
    <script type="module">
        import { confirm } from "/modules/modals.js";
        (function () {
            $('.btnDelete').on('click', async function (e) {
                const name = $(this).data('name');
                const id = $(this).data('id');
                const confirmed = await confirm('Xác nhận xóa', `Bạn có chắc chắn muốn xóa khách hàng <strong>${name}</strong>?`);
                if (confirmed) { $(`#deleteForm${id}`).submit(); }
            });
        })();
    </script>
}
