@model NamEcommerce.Web.Contracts.Models.Orders.OrderListModel
@{
    ViewData["Title"] = "Quản lý Đơn hàng";
    
    string GetStatusBadgeClass(int status) => status switch
    {
        0 => "bg-secondary",   // Pending
        1 => "bg-primary",     // Processing
        2 => "bg-success",     // Completed
        3 => "bg-danger",      // Cancelled
        _ => "bg-dark"
    };

    string GetStatusText(int status) => status switch
    {
        0 => "Đang chờ",
        1 => "Đang xử lý",
        2 => "Hoàn thành",
        3 => "Đã hủy",
        _ => "Không xác định"
    };
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-0 fw-bold text-dark">Quản lý Đơn hàng</h1>
            <p class="text-muted small mb-0">Theo dõi và quản lý các đơn hàng của khách hàng.</p>
        </div>
        <a asp-action="Create" class="btn btn-primary px-4 py-2 rounded-3 shadow-sm">
            <i class="bi bi-plus-lg me-1"></i> Tạo đơn hàng mới
        </a>
    </div>

    <!-- Filters & Search -->
    <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-body p-3">
            <form id="filterForm" method="get" class="row g-3 align-items-center">
                <div class="col-md-5">
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0"><i class="bi bi-search text-muted"></i></span>
                        <input type="text" name="keywords" class="form-control border-start-0 ps-0" placeholder="Tìm theo mã đơn, tên khách..." value="@Context.Request.Query["keywords"]">
                    </div>
                </div>
                <div class="col-md-3">
                    <select name="status" class="form-select border-0 bg-light rounded-3">
                        <option value="">Tất cả trạng thái</option>
                        <option value="0" selected="@(Context.Request.Query["status"] == "0")">Đang chờ</option>
                        <option value="1" selected="@(Context.Request.Query["status"] == "1")">Đang xử lý</option>
                        <option value="2" selected="@(Context.Request.Query["status"] == "2")">Hoàn thành</option>
                        <option value="3" selected="@(Context.Request.Query["status"] == "3")">Đã hủy</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-dark w-100 rounded-3">Lọc</button>
                </div>
                <div class="col-md-2">
                    <a asp-action="List" class="btn btn-outline-secondary w-100 rounded-3">Xóa lọc</a>
                </div>
            </form>
        </div>
    </div>

    <!-- Orders Table -->
    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light text-muted small text-uppercase">
                        <tr>
                            <th class="ps-4" style="width: 15%">Mã đơn hàng</th>
                            <th style="width: 30%">Khách hàng</th>
                            <th class="text-end" style="width: 20%">Tổng tiền</th>
                            <th class="text-center" style="width: 20%">Trạng thái</th>
                            <th class="text-end pe-4" style="width: 15%">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Items != null && Model.Items.Any())
                        {
                            @foreach (var item in Model.Items)
                            {
                                <tr>
                                    <td class="ps-4">
                                        <span class="fw-bold text-primary">#@item.Id.ToString()[..8].ToUpper()</span>
                                    </td>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <div class="bg-light rounded-circle p-2 me-2">
                                                <i class="bi bi-person text-primary"></i>
                                            </div>
                                            <div>
                                                <div class="fw-bold text-dark">@item.CustomerName</div>
                                                <div class="text-muted small">ID: @item.CustomerId.ToString()[..8]...</div>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="text-end fw-bold">
                                        @item.TotalAmount.ToString("N0") đ
                                    </td>
                                    <td class="text-center">
                                        <span class="badge rounded-pill @GetStatusBadgeClass(item.Status) px-3 py-2 fw-normal">
                                            @GetStatusText(item.Status)
                                        </span>
                                    </td>
                                    <td class="text-end pe-4">
                                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary rounded-pill px-3">
                                            Chi tiết
                                        </a>
                                        <button class="btn btn-sm btn-light border-0 ms-1 rounded-circle" type="button" data-bs-toggle="dropdown">
                                            <i class="bi bi-three-dots"></i>
                                        </button>
                                        <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0">
                                            <li><a class="dropdown-item" asp-action="Details" asp-route-id="@item.Id"><i class="bi bi-pencil-square me-2"></i> Chỉnh sửa</a></li>
                                            <li><hr class="dropdown-divider"></li>
                                            <li><button class="dropdown-item text-danger"><i class="bi bi-trash me-2"></i> Xóa đơn</button></li>
                                        </ul>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="py-5 text-center text-muted">
                                    <div class="mb-2"><i class="bi bi-inbox fs-1 opacity-25"></i></div>
                                    Không tìm thấy đơn hàng nào phù hợp.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    
    <!-- Placeholder for Pagination -->
    <div class="mt-4 d-flex justify-content-center">
        @* Pager logic can go here *@
    </div>
</div>

<style>
    .card { transition: box-shadow 0.2s ease; }
    .card:hover { box-shadow: 0 .5rem 1.5rem rgba(0,0,0,.08) !important; }
    .table thead th { border-top: 0; padding-top: 1rem; padding-bottom: 1rem; }
    .table tbody td { padding-top: 1rem; padding-bottom: 1rem; }
    .badge { letter-spacing: 0.3px; }
    .dropdown-item { font-size: 0.9rem; padding: 0.6rem 1rem; }
</style>
