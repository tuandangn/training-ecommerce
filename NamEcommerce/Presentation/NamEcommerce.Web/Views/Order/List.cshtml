@model OrderListModel
@inject IWebHelper WebHelper
@{
    ViewData["Title"] = "Đơn hàng";
    var successMessage = TempData[ViewConstants.OrderSuccessMessage] as string;
    var errorMessage = TempData[ViewConstants.OrderErrorMessage] as string;
}

<div class="page-header">
    <div>
        <h1 class="page-header-title">Đơn hàng</h1>
        <p class="page-header-subtitle">Theo dõi và quản lý đơn hàng</p>
    </div>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-lg me-1"></i> Tạo đơn
    </a>
</div>

@if (!string.IsNullOrEmpty(successMessage))
{
    <div class="alert alert-success alert-dismissible fade show alert-global mb-3" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i>@successMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-warning alert-dismissible fade show alert-global mb-3" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-2"></i>@errorMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="content-card">
    <div class="action-toolbar">
        <partial name="_Search" model="@(new OrderListSearchModel { Keywords = Model.Keywords, Status = Model.Status })" />
    </div>

    <div class="table-responsive">
        <table class="table data-table">
            <thead>
                <tr>
                    <th class="ps-4">Mã đơn</th>
                    <th>Khách hàng</th>
                    <th class="text-end">Tổng đơn</th>
                    <th class="text-center">Dự kiến giao</th>
                    <th class="text-center">Trạng thái</th>
                    <th class="text-center d-none d-lg-table-cell">Ngày tạo</th>
                    <th style="width: 100px;"></th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Data.Pagination.TotalCount > 0)
                {
                    @foreach (var order in Model.Data)
                    {
                        <tr>
                            <td class="ps-4">
                                <div class="position-relative">
                                    <a asp-action="Details" asp-route-id="@order.Id" class="fw-medium text-primary d-block text-nowrap text-decoration-none">
                                        @HighlighHelper.Highlight(order.Code, Model.Keywords)
                                    </a>
                                    <span class="text-muted small d-inline d-lg-none">@order.CreatedOn.ToString(ViewConstants.DefaultDateTimeFormat)</span>
                                </div>
                            </td>
                            <td>
                                <div class="position-relative">
                                    <a asp-action="Edit" asp-controller="Customer" asp-route-id="@order.CustomerId" class="stretched-link fw-medium text-decoration-none">                                        <i class="bi bi-person me-1"></i>
                                        @HighlighHelper.Highlight(order.CustomerName, Model.Keywords)
                                    </a>
                                    @if (!string.IsNullOrEmpty(order.CustomerPhone))
                                    {
                                        <div>
                                            <a href="tel:@order.CustomerPhone" class="text-muted small text-decoration-none">
                                                <i class="bi bi-telephone me-1"></i> @HighlighHelper.Highlight(order.CustomerPhone, Model.Keywords)
                                            </a>
                                        </div>
                                    }
                                </div>
                            </td>
                            <td class="text-end text-danger fw-bold text-nowrap">
                                @order.TotalAmount.ToString(ViewConstants.CurrencyDisplayFormat)
                            </td>
                            <td class="text-center text-muted">
                                @order.ExpectedShippingDate?.ToString(ViewConstants.DefaultDateFormat)
                            </td>
                            <td class="text-center">
                                @{
                                    var itemOrderStatus = (OrderStatus)order.Status;
                                }
                                <span class="badge rounded-pill @itemOrderStatus.GetDisplayColor() px-2 py-1 fw-normal">
                                    @itemOrderStatus.GetDisplayText()
                                </span>
                            </td>
                            <td class="text-center d-none d-lg-table-cell">
                                <span class="text-muted">@order.CreatedOn.ToString(ViewConstants.DefaultDateTimeFormat)</span>
                            </td>
                            <td class="text-end pe-3">
                                @if (order.CanUpdateInfo)
                                {
                                    <a class="btn-table-action" asp-action="Details" asp-route-id="@order.Id" title="Chỉnh sửa">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                }
                                else
                                {
                                    <a class="btn-table-action" asp-action="Details" asp-route-id="@order.Id" title="Xem">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                }
                                <div class="btn-group dropstart">
                                    <button class="btn-table-action" type="button" data-bs-toggle="dropdown" aria-expanded="false" title="Thêm">
                                        <i class="bi bi-three-dots-vertical"></i>
                                    </button>
                                    <ul class="dropdown-menu border-0 shadow-sm rounded-3">
                                        <li>
                                            <a class="dropdown-item py-2 dropdown-item-custom" asp-controller="DeliveryNote" asp-action="Create" asp-route-orderId="@order.Id">
                                                <i class="bi bi-box-seam me-2 text-muted"></i> Tạo phiếu xuất kho
                                            </a>
                                        </li>
                                        <li>
                                            <button type="button" class="dropdown-item py-2 text-danger btnDelete dropdown-item-custom" data-id="@order.Id" data-code="@order.Code">
                                                <i class="bi bi-trash me-2"></i> Xóa đơn màng
                                            </button>
                                        </li>
                                    </ul>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6">
                            <div class="empty-state">
                                <div class="empty-icon"><i class="bi bi-inbox"></i></div>
                                <h5>Không có đơn hàng nào</h5>
                                <p>Tạo mới đơn hàng để bắt đầu bán hàng.</p>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    
    @if (Model.Data.Pagination.TotalCount > 0)
    {
        <partial name="_Pager" model="Model.Data.Pagination" />
    }
</div>

@foreach (var item in Model.Data)
{
    <partial name="_DeleteForm" model="@item.Id" />
}
@section Scripts {
    <script type="module" defer>
        import { confirm } from "/modules/modals.js";
        (function () {
        $('.btnDelete').on('click', async function (e) {
        e.preventDefault();
        const code = $(this).data('code');
        $(this).prop('disabled', true);
        const confirmed = await confirm('Xóa đơn hàng', `Bạn muốn xóa đơn hàng <strong>${code}</strong>?`);
        if (!confirmed) { $(this).prop('disabled', false); return; }
        $(`#deleteForm${$(this).data('id')}`).submit();
        });
        })();
    </script>
}
