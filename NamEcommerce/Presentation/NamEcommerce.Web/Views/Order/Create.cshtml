@model CreateOrderModel
@{
    ViewData["Title"] = "Tạo Đơn hàng mới";
}
<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div>
                    <nav aria-label="breadcrumb">
                        <ol class="breadcrumb mb-1">
                            <li class="breadcrumb-item">
                                <a asp-action="List" class="text-decoration-none">Đơn hàng</a>
                            </li>
                            <li class="breadcrumb-item active" aria-current="page">Tạo mới</li>
                        </ol>
                    </nav>
                    <h1 class="h3 mb-0 fw-bold">Tạo Đơn hàng mới</h1>
                </div>
                <a asp-action="List" class="btn btn-outline-secondary px-4 rounded-3">
                    <i class="bi bi-x-lg me-1"></i>
                    Hủy bỏ
                </a>
            </div>
            <div asp-validation-summary="ModelOnly" class="alert alert-warning alert-global"></div>
            <form method="post" id="createOrderForm">
                <div class="row g-4">
                    <div class="col-md-8">
                        <div class="card border-0 shadow-sm rounded-4 mb-4">
                            <div class="card-header bg-white border-0 py-3">
                                <h5 class="mb-0 fw-bold">
                                    <i class="bi bi-person-plus me-2 text-primary"></i>
                                    Thông tin Khách hàng
                                </h5>
                            </div>
                            <div class="card-body">
                                <div class="position-relative mb-3 @(Model.CustomerId.HasValue ? "d-none" : "")">
                                    <label class="form-label small fw-bold text-muted" for="customerSearch">
                                        Tìm kiếm khách hàng
                                    </label>
                                    <div class="input-group">
                                        <span class="input-group-text bg-white border-end-0">
                                            <i class="bi bi-search text-muted"></i>
                                        </span>
                                        <input type="text" id="customerSearch" class="form-control border-start-0 ps-0"
                                               placeholder="Nhập tên, số điện thoại hoặc địa chỉ" autocomplete="off" />
                                    </div>
                                    <div id="customerSuggestions"
                                         class="list-group position-absolute w-100 shadow-lg mt-1"
                                         style="z-index: 1050; display: none;"></div>
                                </div>
                                <div id="selectedCustomerDisplay" class="alert alert-primary @(Model.CustomerId.HasValue ? "" : "d-none") border-0 rounded-3 d-flex align-items-center mb-0">
                                    <i class="bi bi-person-check-fill fs-4 me-3"></i>
                                    <div>
                                        <div class="fw-bold" id="displayName">@Model.CustomerDisplayName</div>
                                        <div class="small text-muted" id="displayPhone">@Model.CustomerDisplayPhone</div>
                                        <div class="small text-muted" id="displayAddress">@Model.CustomerDisplayAddress</div>
                                    </div>
                                    <button type="button" class="btn-close ms-auto" id="resetCustomer"></button>
                                </div>
                                <input type="text" class="visually-hidden" asp-for="CustomerId" />
                                <span asp-validation-for="CustomerId" class="small text-danger"></span>
                            </div>
                        </div>

                        <div class="card border-0 shadow-sm rounded-4">
                            <div class="card-header bg-white border-0 py-3 d-flex justify-content-between align-items-center">
                                <h5 class="mb-0 fw-bold">
                                    <i class="bi bi-box-seam me-2 text-success"></i>
                                    Danh sách hàng hóa
                                </h5>
                                <button type="button" class="btn btn-sm btn-outline-success rounded-pill"
                                        data-bs-toggle="modal" data-bs-target="#addProductModal">
                                    <i class="bi bi-plus-lg"></i>
                                    <span class="d-none d-lg-inline ms-1">
                                        Thêm sản phẩm
                                    </span>
                                    <span class="d-inline d-lg-none ms-1">
                                        Thêm
                                    </span>
                                </button>
                            </div>
                            <div class="card-body p-0">
                                <div class="table-responsive">
                                    <table class="table table-hover align-middle mb-0" id="orderItemsTable">
                                        <thead class="bg-light text-muted small text-uppercase">
                                            <tr>
                                                <th class="ps-4">Sản phẩm</th>
                                                <th class="text-center" style="width: 100px">Số lượng</th>
                                                <th class="text-end" style="width: 150px">Đơn giá</th>
                                                <th class="text-end d-none d-lg-table-cell" style="width: 150px">Thành tiền</th>
                                                <th class="text-end pe-2 pe-lg-4 w-auto"></th>
                                            </tr>
                                        </thead>
                                        <tbody id="itemsTableBody">
                                            @for (var i = 0; i < Model.Items.Count; i++)
                                            {
                                                var item = Model.Items[i];
                                                <tr id="row-@i" class="align-top">
                                                    <td class="ps-4">
                                                        <div class="d-flex gap-3">
                                                            <div class="text-center d-none d-lg-block" style="min-width:45px;">
                                                                @if (!string.IsNullOrEmpty(item.ProductDisplayPicture))
                                                                {
                                                                    <img src="@item.ProductDisplayPicture" class="img-fluid img-thumbnail" style="width:45px;" />
                                                                }
                                                                else
                                                                {
                                                                    <i class="bi bi-image fs-4 text-muted"></i>
                                                                }
                                                            </div>
                                                            <div>
                                                                <div class="fw-bold text-dark text-nowrap">@item.ProductDisplayName</div>
                                                                <div class="small text-muted">
                                                                    Tồn kho: @item.ProductDisplayQty?.ToString(ViewConstants.NumberCustomFormat)
                                                                </div>
                                                                <span class="small text-danger field-validation-valid" data-valmsg-for="Items[@i].ProductId" data-valmsg-replace="true"></span>
                                                            </div>
                                                        </div>
                                                        <input type="text" class="visually-hidden" name="Items[@i].ProductId" value="@item.ProductId"
                                                               data-val="true" data-val-required="Vui lòng chọn hàng hóa." />
                                                        <span class="small text-danger field-validation-valid" data-valmsg-for="Items[@i].ProductId" data-valmsg-replace="true"></span>
                                                    </td>
                                                    <td class="text-center">
                                                        <input type="number" name="Items[@i].Quantity" value="@item.Quantity" class="form-control form-control-sm text-center row-qty"
                                                               step="any" min="0.00000001" data-val="true" data-val-required="Vui lòng nhập số lượng."
                                                               placeholder="0"
                                                               data-val-range="Số lượng phải lớn hơn 0." data-val-range-min="0.000000000000000001" data-val-number="Số lượng không đúng." />
                                                        <span class="small text-danger field-validation-valid" data-valmsg-for="Items[@i].Quantity" data-valmsg-replace="true"></span>
                                                    </td>
                                                    <td class="text-end">
                                                        <input type="number" name="Items[@i].UnitPrice" value="@item.UnitPrice" style="min-width:80px;"
                                                               class="form-control form-control-sm text-end row-price" min="0" data-val="true" data-val-required="Vui lòng nhập đơn giá."
                                                               placeholder="0"
                                                               data-val-range="Đơn giá phải lớn hơn hoặc bằng 0." data-val-range-min="0" data-val-number="Đơn giá không đúng." />
                                                        <span class="small text-danger field-validation-valid" data-valmsg-for="Items[@i].UnitPrice" data-valmsg-replace="true"></span>
                                                    </td>
                                                    <td class="text-end fw-bold text-primary px-3 row-total text-nowrap d-none d-lg-table-cell">
                                                        @item.ItemSubTotal.ToString(ViewConstants.NumberCustomFormat) @ViewConstants.DefaultCurrencySymbol
                                                    </td>
                                                    <td class="text-end pe-2 pe-lg-4 w-auto">
                                                        <button type="button" class="btn btn-link link-danger p-0 border-0" onclick="this.closest('tr').remove(); window.updateGrandTotal();">
                                                            <i class="bi bi-trash"></i>
                                                        </button>
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                                <div class="bg-light @(Model.Items.Count > 0 ? "" : "d-none") d-flex flex-column px-4" id="tableFooter">
                                    <div class="d-flex justify-content-end gap-4">
                                        <div class="text-end fw-bold py-2 border-0">TẠM TÍNH</div>
                                        <div class="text-end fw-bold py-2 border-0" id="subTotal">@Model.OrderSubTotal @ViewConstants.DefaultCurrencySymbol</div>
                                    </div>
                                    <div class="d-flex justify-content-end gap-4">
                                        <div colspan="3" class="text-end fw-bold py-2 border-0">GIẢM GIÁ</div>
                                        <div class="text-end fw-bold py-2 border-0 text-danger" id="discountDisplay">
                                            - @(Model.OrderDiscount ?? 0) đ
                                        </div>
                                    </div>
                                    <div class="border-top d-flex justify-content-end gap-4">
                                        <div colspan="3" class="text-end fw-bold py-3">TỔNG CỘNG</div>
                                        <div class="text-end fw-bold py-3 text-primary fs-5" id="grandTotal">
                                            @Model.OrderTotal @ViewConstants.DefaultCurrencySymbol
                                        </div>
                                    </div>
                                </div>
                                <div id="noItemsMessage" class="py-5 text-center text-muted italic" style="display:@(Model.Items.Count == 0 ? "block" : "none")">
                                    <div>
                                        Chưa có sản phẩm nào được chọn.
                                    </div>
                                    <span asp-validation-for="Items" class="text-danger small"></span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-4">
                        <div class="card border-0 shadow-sm rounded-4 mb-4">
                            <div class="card-header bg-white border-0 py-3">
                                <h5 class="mb-0 fw-bold">
                                    <i class="bi bi-info-circle"></i>
                                    Thông tin bổ sung
                                </h5>
                            </div>
                            <div class="card-body">
                                <div class="mb-4">
                                    <label asp-for="ExpectedShippingDate" class="form-label small fw-bold text-muted"></label>
                                    <input type="date" asp-for="ExpectedShippingDate" class="form-control" />
                                    <span asp-validation-for="ExpectedShippingDate" class="small text-danger"></span>
                                </div>
                                <div class="mb-4">
                                    <label asp-for="OrderDiscount" class="form-label small fw-bold text-muted"></label>
                                    <input type="number" asp-for="OrderDiscount" class="form-control" min="0" placeholder="0" />
                                    <span asp-validation-for="OrderDiscount" class="small text-danger"></span>
                                </div>
                                <div class="mb-4">
                                    <label asp-for="Note" class="form-label small fw-bold text-muted"></label>
                                    <textarea asp-for="Note" class="form-control" rows="3" placeholder="Nhập ghi chú (nếu có)..."></textarea>
                                    <span asp-validation-for="Note" class="small text-danger"></span>
                                </div>
                                <hr class="border-light my-4">
                                <div class="d-grid gap-2">
                                    <button type="submit" class="btn btn-primary py-3 rounded-3 shadow-sm fw-bold">
                                        <i class="bi bi-check2-circle me-2"></i>
                                        Tạo đơn
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Add Product Modal -->
<div class="modal fade" id="addProductModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow rounded-4">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold">Thêm sản phẩm</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form action="#" method="post">
                <div class="modal-body py-4">
                    <div class="mb-3">
                        <label class="form-label small fw-bold text-muted uppercase">Tìm kiếm sản phẩm</label>
                        <div class="input-group">
                            <span class="input-group-text bg-white border-end-0"><i class="bi bi-box text-muted"></i></span>
                            <input type="text" id="productSearch" class="form-control border-start-0 ps-0"
                                   placeholder="Nhập tên sản phẩm..." autocomplete="off">
                        </div>
                        <div id="productSuggestions" class="list-group shadow-lg mt-1"
                             style="display: none; max-height: 200px; overflow-y: auto;"></div>
                    </div>

                    <div id="modalProductInfo" class="d-none">
                        <div class="alert alert-light border-0 rounded-3 mb-3 d-flex align-items-start gap-3">
                            <img class="img-fluid img-thumbnail d-none" style="width: 70px;" id="itemProductHasPicture" alt="Product image" />
                            <i class="bi bi-box-seam-fill text-primary me-2 fs-5" id="itemProductNoPicture"></i>
                            <div>
                                <div class="fw-bold" id="itemProductName"></div>
                                <div class="text-muted small">Tồn kho: <span id="itemProductStock"></span></div>
                            </div>
                        </div>
                        <div class="row g-3">
                            <div class="col-6">
                                <label class="form-label small fw-bold text-muted" for="itemQuantity">Số lượng</label>
                                <input type="number" id="itemQuantity" name="itemProductQuantity" class="form-control rounded-3"
                                       value="1" min="0.01" step="any" data-val="true"
                                       placeholder="0"
                                       data-val-range="Số lượng phải lớn hơn 0." data-val-range-min="0.000000000000000001"
                                       data-val-number="Số lượng không đúng." data-val-required="Vui lòng nhập số lượng." />
                                <span class="small text-danger field-validation-valid" data-valmsg-for="itemProductQuantity" data-valmsg-replace="true"></span>
                            </div>
                            <div class="col-6">
                                <label class="form-label small fw-bold text-muted noRefill" for="itemUnitPrice">Đơn giá</label>
                                <input type="number" id="itemUnitPrice" name="itemProductUnitPrice" class="form-control rounded-3"
                                       step="any" min="0" data-val="true"
                                       placeholder="0"
                                       data-val-range="Đơn giá phải lớn hơn 0." data-val-range-min="0"
                                       data-val-number="Đơn giá không đúng." data-val-required="Vui lòng nhập đơn giá." />
                                <span class="small text-danger field-validation-valid" data-valmsg-for="itemProductUnitPrice" data-valmsg-replace="true"></span>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-0 pt-0 pb-4">
                    <button type="button" class="btn btn-light px-4 rounded-3" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" id="addItemToTable" class="btn btn-success px-4 rounded-3 shadow-sm d-none noDisabled">
                        <i class="bi bi-plus-lg me-1"></i>
                        Thêm vào
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/modules/order.create.js" type="module"></script>
}
@section Styles {
    <style>
        .letter-spacing-1 {
            letter-spacing: 1px;
        }

        .uppercase {
            text-transform: uppercase;
        }

        .italic {
            font-style: italic;
        }

        .list-group-item {
            cursor: pointer;
        }

            .list-group-item:hover {
                background-color: var(--bs-light);
                color: var(--bs-primary);
            }

        .bg-light {
            background-color: #f8f9fa !important;
        }
    </style>
}
