@model OrderDetailsModel
@{
    ViewData["Title"] = $"Đơn hàng #{Model.Id.ToString()[..8].ToUpper()}";

    string GetStatusBadgeClass(int status) => status switch
    {
        0 => "bg-secondary",   // Pending
        1 => "bg-primary",     // Processing
        2 => "bg-success",     // Completed
        3 => "bg-danger",      // Cancelled
        _ => "bg-dark"
    };

    string GetStatusText(int status) => status switch
    {
        0 => "Đang chờ",
        1 => "Đang xử lý",
        2 => "Hoàn thành",
        3 => "Đã hủy",
        _ => "Không xác định"
    };

    string GetPaymentStatusText(int status) => status switch
    {
        0 => "Chưa thanh toán",
        1 => "Đã thanh toán",
        2 => "Đã hoàn tiền",
        _ => "Không xác định"
    };

    string GetPaymentMethodText(int? method) => method switch
    {
        0 => "Tiền mặt",
        1 => "Chuyển khoản",
        2 => "COD",
        3 => "Khác",
        _ => "Chưa có"
    };

    string GetShippingStatusText(int status) => status switch
    {
        0 => "Chưa giao",
        1 => "Đang giao",
        2 => "Đã giao",
        3 => "Bị trả lại",
        _ => "Không xác định"
    };
}

<div class="container py-4">
    @if (TempData[ViewConstants.OrderSuccessMessage] != null)
    {
        <div class="alert alert-success alert-dismissible fade show mb-4 rounded-3 shadow-sm" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> 
            @TempData[ViewConstants.OrderSuccessMessage]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData[ViewConstants.OrderErrorMessage] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show mb-4 rounded-3 shadow-sm" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> 
            @TempData[ViewConstants.OrderErrorMessage]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-1">
                    <li class="breadcrumb-item"><a asp-action="List" class="text-decoration-none">Đơn hàng</a></li>
                    <li class="breadcrumb-item active" aria-current="page">Chi tiết</li>
                </ol>
            </nav>
            <h1 class="h3 mb-0 fw-bold">Chi tiết Đơn hàng <span class="text-primary">@Model.Code</span></h1>
        </div>
        <div class="d-flex gap-2">
            <a asp-action="List" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left me-1"></i> Quay lại
            </a>
            <button type="button" class="btn btn-outline-primary" onclick="window.print()">
                <i class="bi bi-printer me-1"></i> In hóa đơn
            </button>
        </div>
    </div>
    <div class="row g-4">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-4 mb-4">
                <div class="card-header bg-white border-0 py-3 d-flex justify-content-between align-items-center">
                    <h5 class="mb-0 fw-bold"><i class="bi bi-box-seam me-2 text-primary"></i>Danh sách Sản phẩm</h5>
                    <span class="badge bg-light text-dark border fw-normal">@Model.Items.Count sản phẩm</span>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="bg-light text-muted small text-uppercase">
                                <tr>
                                    <th class="ps-4" style="width: 40%">Sản phẩm</th>
                                    <th class="text-center" style="width: 15%">Số lượng</th>
                                    <th class="text-end" style="width: 20%">Đơn giá</th>
                                    <th class="text-end" style="width: 20%">Thành tiền</th>
                                    <th class="text-end pe-4" style="width: 5%"></th>
                                </tr>
                            </thead>
                            <tbody id="itemsTableBody">
                                @foreach (var item in Model.Items)
                                {
                                    <tr data-item-id="@item.Id">
                                        <td class="ps-4">
                                            <div class="d-flex align-items-center gap-3">
                                                <div>
                                                    @if (string.IsNullOrEmpty(item.ProductPicture))
                                                    {
                                                        <div class="product-icon-placeholder me-3 rounded-3 bg-light d-flex align-items-center justify-content-center" style="width: 48px; height: 48px;">
                                                            <i class="bi bi-image text-muted fs-4"></i>
                                                        </div>
                                                    }
                                                    else
                                                    {
                                                        <div>
                                                            <img src="@item.ProductPicture" class="img-fluid img-thumbnail item-product-img" style="width:45px;"/>
                                                        </div>
                                                    }
                                                </div>
                                                <div>
                                                    <div class="fw-bold text-dark">@item.ProductName</div>
                                                    <div class="text-muted small">Tồn kho: @item.ProductAvailableQty</div>
                                                </div>
                                            </div>
                                        </td>
                                        <td class="text-center">
                                            <span class="fw-semibold quantity-text">@item.Quantity.ToString(ViewConstants.NumberCustomFormat)</span>
                                        </td>
                                        <td class="text-end">
                                            <span class="unit-price-text">@item.UnitPrice.ToString(ViewConstants.NumberCustomFormat) @ViewConstants.DefaultCurrencySymbol</span>
                                        </td>
                                        <td class="text-end fw-bold text-primary">
                                            <span class="total-price-text">@(item.SubTotal.ToString(ViewConstants.NumberCustomFormat)) đ</span>
                                        </td>
                                        <td class="text-end pe-4">
                                            <div class="dropdown">
                                                <button class="btn btn-sm btn-light border-0" type="button" data-bs-toggle="dropdown">
                                                    <i class="bi bi-three-dots-vertical"></i>
                                                </button>
                                                <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0">
                                                    <li>
                                                        <button class="dropdown-item btnEditItem" data-id="@item.Id" 
                                                            data-product="@item.ProductName" data-availableQty="@item.ProductAvailableQty?.ToString(ViewConstants.NumberCustomFormat)"
                                                            data-qty="@item.Quantity" data-price="@item.UnitPrice">
                                                            <i class="bi bi-pencil me-2 text-primary"></i> 
                                                            Chỉnh sửa
                                                        </button>
                                                    </li>
                                                    <li><hr class="dropdown-divider"></li>
                                                    <li>
                                                        <button class="dropdown-item text-danger btnRemoveItem" data-id="@item.Id" data-name="@item.ProductName">
                                                            <i class="bi bi-trash me-2"></i> Xóa
                                                        </button>
                                                    </li>
                                                </ul>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot class="bg-light">
                                <tr>
                                    <td colspan="3" class="text-end ps-4 py-2 text-muted small">Tạm tính:</td>
                                    <td class="text-end py-2 fw-semibold">@((Model.TotalAmount + Model.OrderDiscount).ToString("N0")) đ</td>
                                    <td></td>
                                </tr>
                                <tr>
                                    <td colspan="3" class="text-end ps-4 py-2 text-muted small">
                                        Giảm giá:
                                        <button type="button" class="btn btn-sm btn-link p-0 ms-1" data-bs-toggle="modal" data-bs-target="#editDiscountModal">
                                            <i class="bi bi-pencil-square text-primary"></i>
                                        </button>
                                    </td>
                                    <td class="text-end py-2 text-danger">- @Model.OrderDiscount.ToString("N0") đ</td>
                                    <td></td>
                                </tr>
                                <tr>
                                    <td colspan="3" class="text-end ps-4 py-3 fw-bold fs-5">TỔNG CỘNG:</td>
                                    <td class="text-end py-3 fw-bold fs-5 text-primary">@Model.TotalAmount.ToString("N0") đ</td>
                                    <td class="pe-4 py-3"></td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </div>
            </div>

            <!-- Add Item Card -->
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-header bg-white border-0 py-3">
                    <h5 class="mb-0 fw-bold"><i class="bi bi-plus-circle me-2 text-success"></i>Thêm Sản phẩm</h5>
                </div>
                <div class="card-body">
                    <form id="addItemForm" method="post" action="@Url.Action("AddItem")" class="row g-3">
                        <input type="hidden" name="OrderId" value="@Model.Id" />
                        <input type="hidden" id="productId" name="ProductId" required />
                        
                        <div class="col-md-6 position-relative">
                            <label class="form-label small fw-bold text-muted uppercase">Tìm kiếm sản phẩm</label>
                            <div class="input-group">
                                <span class="input-group-text bg-white border-end-0"><i class="bi bi-search text-muted"></i></span>
                                <input id="productPickerDisplay" class="form-control border-start-0 ps-0" placeholder="Nhập tên sản phẩm..." autocomplete="off" />
                            </div>
                            <div id="productSuggestions" class="list-group position-absolute w-100 shadow-lg mt-1" style="z-index: 1050; max-height: 250px; overflow-y: auto; display: none;"></div>
                        </div>
                        
                        <div class="col-md-3">
                            <label class="form-label small fw-bold text-muted uppercase">Số lượng</label>
                            <input type="number" id="quantityInput" name="Quantity" class="form-control" value="1" min="1" step="any" required />
                        </div>
                        
                        <div class="col-md-3">
                            <label class="form-label small fw-bold text-muted uppercase">Đơn giá</label>
                            <div class="input-group">
                                <input type="number" id="unitPriceInput" name="UnitPrice" class="form-control border-end-0" placeholder="0" min="0" step="any" required />
                                <span class="input-group-text bg-white border-start-0 text-muted small">đ</span>
                            </div>
                        </div>
                        
                        <div class="col-12 mt-4 text-end">
                            <button type="submit" class="btn btn-primary px-4 py-2 rounded-3 shadow-sm">
                                <i class="bi bi-plus-lg me-1"></i> Thêm vào đơn hàng
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <!-- Sidebar -->
        <div class="col-lg-4">
            <!-- Order Status Card -->
            <div class="card border-0 shadow-sm rounded-4 mb-4 overflow-hidden">
                <div class="card-body p-0">
                    <div class="p-4 text-center @GetStatusBadgeClass(Model.Status) text-white bg-gradient">
                        <div class="small fw-normal mb-1 opacity-75 text-uppercase letter-spacing-1">Trạng thái đơn hàng</div>
                        <div class="fs-3 fw-bold">@GetStatusText(Model.Status)</div>
                    </div>
                    <div class="p-4">
                        <form asp-action="ChangeStatus" method="post">
                            <input type="hidden" name="OrderId" value="@Model.Id" />
                            <div class="mb-3">
                                <label class="form-label small fw-bold text-muted">Cập nhật trạng thái</label>
                                <select name="Status" class="form-select border-0 bg-light rounded-3" onchange="this.form.submit()">
                                    <option value="0" selected="@(Model.Status == 0)">Đang chờ</option>
                                    <option value="1" selected="@(Model.Status == 1)">Đang xử lý</option>
                                    <option value="2" selected="@(Model.Status == 2)">Hoàn thành</option>
                                    <option value="3" selected="@(Model.Status == 3)">Đã hủy</option>
                                </select>
                            </div>
                        </form>
                    </div>
                </div>
            </div>

            <!-- Customer Card -->
            <div class="card border-0 shadow-sm rounded-4 mb-4">
                <div class="card-header bg-white border-0 py-3">
                    <h5 class="mb-0 fw-bold"><i class="bi bi-person-circle me-2 text-primary"></i>Khách hàng</h5>
                </div>
                <div class="card-body">
                    <div class="d-flex align-items-center mb-4">
                        <div class="bg-primary bg-opacity-10 text-primary rounded-circle p-3 me-3">
                            <i class="bi bi-person-fill fs-3"></i>
                        </div>
                        <div>
                            <div class="fs-5 fw-bold">@Model.CustomerName</div>
                            <div class="text-muted small">ID: @Model.CustomerId.ToString()[..8]...</div>
                        </div>
                    </div>
                    <a asp-controller="Customer" asp-action="Edit" asp-route-id="@Model.CustomerId" class="btn btn-sm btn-outline-primary w-100 rounded-3">
                        <i class="bi bi-eye me-1"></i> Xem thông tin khách hàng
                    </a>
                </div>
            </div>

            <!-- Note Card -->
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-header bg-white border-0 py-3 d-flex justify-content-between align-items-center">
                    <h5 class="mb-0 fw-bold"><i class="bi bi-sticky me-2 text-warning"></i>Ghi chú</h5>
                    <button type="button" class="btn btn-sm btn-link p-0" onclick="editNote()">
                         <i class="bi bi-pencil small"></i>
                    </button>
                </div>
                <div class="card-body bg-light border-radius-bottom-4">
                    <p class="mb-0 text-muted italic" id="orderNoteText">
                        @(string.IsNullOrEmpty(Model.Note) ? "Không có ghi chú cho đơn hàng này." : Model.Note)
                    </p>
                </div>
            </div>

            <!-- Payment Card -->
            <div class="card border-0 shadow-sm rounded-4 mt-4">
                <div class="card-header bg-white border-0 py-3 d-flex justify-content-between align-items-center">
                    <h5 class="mb-0 fw-bold"><i class="bi bi-wallet2 me-2 text-success"></i>Thanh toán</h5>
                    @if (Model.PaymentStatus == 0 && Model.Status != 3) {
                        <button type="button" class="btn btn-sm btn-outline-success" data-bs-toggle="modal" data-bs-target="#paymentModal">
                            Xác nhận thanh toán
                        </button>
                    }
                </div>
                <div class="card-body">
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">Trạng thái:</span>
                        <span class="fw-bold @(Model.PaymentStatus == 1 ? "text-success" : (Model.PaymentStatus == 0 ? "text-warning" : "text-danger"))">@GetPaymentStatusText(Model.PaymentStatus)</span>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">Phương thức:</span>
                        <span class="fw-medium">@GetPaymentMethodText(Model.PaymentMethod)</span>
                    </div>
                    @if (Model.PaidOnUtc.HasValue) {
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted">Ngày trả:</span>
                            <span class="fw-medium">@Model.PaidOnUtc.Value.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</span>
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(Model.PaymentNote)) {
                        <div class="mt-3 p-3 bg-light rounded-3">
                            <p class="small mb-0 italic">"@Model.PaymentNote"</p>
                        </div>
                    }
                </div>
            </div>

            <!-- Shipping Card -->
            <div class="card border-0 shadow-sm rounded-4 mt-4">
                <div class="card-header bg-white border-0 py-3 d-flex justify-content-between align-items-center">
                    <h5 class="mb-0 fw-bold"><i class="bi bi-truck me-2 text-info"></i>Vận chuyển</h5>
                    @if (Model.Status != 3 && Model.ShippingStatus != 2) {
                        <button type="button" class="btn btn-sm btn-outline-info" data-bs-toggle="modal" data-bs-target="#shippingModal">
                            Cập nhật
                        </button>
                    }
                </div>
                <div class="card-body">
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">Trạng thái:</span>
                        <span class="fw-bold @(Model.ShippingStatus == 2 ? "text-success" : "text-info")">@GetShippingStatusText(Model.ShippingStatus)</span>
                    </div>
                    <div class="mb-2">
                        <span class="text-muted d-block mb-1">Địa chỉ giao hàng:</span>
                        <span class="fw-medium">@(string.IsNullOrEmpty(Model.ShippingAddress) ? "Chưa có địa chỉ" : Model.ShippingAddress)</span>
                    </div>
                    @if (Model.ShippedOnUtc.HasValue) {
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted">Ngày giao:</span>
                            <span class="fw-medium">@Model.ShippedOnUtc.Value.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</span>
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(Model.ShippingNote)) {
                        <div class="mt-3 p-3 bg-light rounded-3">
                            <p class="small mb-0 italic">"@Model.ShippingNote"</p>
                        </div>
                    }
                </div>
            </div>

            <!-- Cancellation -->
            @if (Model.Status == 3) {
            <div class="card border-0 shadow-sm rounded-4 mt-4 border-danger border border-2">
                <div class="card-body">
                    <h5 class="text-danger fw-bold"><i class="bi bi-x-circle-fill me-2"></i>Đơn hàng đã hủy</h5>
                    <p class="mb-0 mt-2"><strong>Lý do:</strong> @Model.CancellationReason</p>
                </div>
            </div>
            } else if (Model.Status != 2) {
            <div class="mt-4 text-end">
                <button type="button" class="btn btn-outline-danger" data-bs-toggle="modal" data-bs-target="#cancelModal">
                    <i class="bi bi-trash"></i> Hủy đơn hàng này
                </button>
            </div>
            }
        </div>
    </div>
</div>

<!-- Edit Item Modal -->
<div class="modal fade" id="editItemModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow rounded-4">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold">Chỉnh sửa sản phẩm</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body py-4">
                <div id="modalProductDisplay" class="alert alert-light border-0 rounded-3 mb-4 d-flex align-items-center">
                    <i class="bi bi-box-seam me-3 fs-4 text-primary"></i>
                    <div>
                        <div class="small text-muted mb-1 text-uppercase fw-bold letter-spacing-1">Sản phẩm đang chọn</div>
                        <div id="editProductName" class="fw-bold fs-5">Product Name</div>
                    </div>
                </div>
                
                <form id="editItemForm" method="post" action="#">
                    <input type="hidden" id="editItemId" name="ItemId" />
                    <input type="hidden" name="OrderId" value="@Model.Id" />
                    
                    <div id="modalProductInfo" class="d-none">
                        <div class="alert alert-light border-0 rounded-3 mb-3 d-flex align-items-start gap-3">
                            <img class="img-fluid img-thumbnail d-none" style="width: 70px;" id="editProductHasPicture" alt="Product image" />
                            <i class="bi bi-box-seam-fill text-primary me-2 fs-5" id="editProductNoPicture"></i>
                            <div>
                                <div class="fw-bold" id="editProductName"></div>
                                <div class="text-muted small">Tồn kho: <span id="editProductStock"></span></div>
                            </div>
                        </div>
                        <div class="row g-3">
                            <div class="col-6">
                                <label class="form-label small fw-bold text-muted" for="editQuantity">Số lượng</label>
                                <input type="number" id="editQuantity" name="Quantity" class="form-control rounded-3"
                                       value="1" min="0.01" step="any" data-val="true"
                                       placeholder="0"
                                       data-val-range="Số lượng phải lớn hơn 0." data-val-range-min="0.000000000000000001"
                                       data-val-number="Số lượng không đúng." data-val-required="Vui lòng nhập số lượng." />
                                <span class="small text-danger field-validation-valid" data-valmsg-for="Quantity" data-valmsg-replace="true"></span>
                            </div>
                            <div class="col-6">
                                <label class="form-label small fw-bold text-muted noRefill" for="editUnitPrice">Đơn giá</label>
                                <input type="number" id="editUnitPrice" name="UnitPrice" class="form-control rounded-3"
                                       step="any" min="0" data-val="true"
                                       placeholder="0"
                                       data-val-range="Đơn giá phải lớn hơn 0." data-val-range-min="0"
                                       data-val-number="Đơn giá không đúng." data-val-required="Vui lòng nhập đơn giá." />
                                <span class="small text-danger field-validation-valid" data-valmsg-for="UnitPrice" data-valmsg-replace="true"></span>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer border-0 pt-0 pb-4">
                <button type="button" class="btn btn-light px-4 rounded-3" data-bs-dismiss="modal">Hủy bỏ</button>
                <button type="button" id="submitEditItem" class="btn btn-primary px-4 rounded-3 shadow-sm">Lưu thay đổi</button>
            </div>
        </div>
    </div>
</div>

<!-- Add Product Modal -->
<div class="modal fade" id="addProductModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow rounded-4">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold">Thêm sản phẩm</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form action="#" method="post">
                <div class="modal-body py-4">
                    <div class="mb-3">
                        <label class="form-label small fw-bold text-muted uppercase">Tìm kiếm sản phẩm</label>
                        <div class="input-group">
                            <span class="input-group-text bg-white border-end-0"><i class="bi bi-box text-muted"></i></span>
                            <input type="text" id="productSearch" class="form-control border-start-0 ps-0"
                                   placeholder="Nhập tên sản phẩm..." autocomplete="off">
                        </div>
                        <div id="productSuggestions" class="list-group shadow-lg mt-1"
                             style="display: none; max-height: 200px; overflow-y: auto;"></div>
                    </div>

                    <div id="modalProductInfo" class="d-none">
                        <div class="alert alert-light border-0 rounded-3 mb-3 d-flex align-items-start gap-3">
                            <img class="img-fluid img-thumbnail d-none" style="width: 70px;" id="itemProductHasPicture" alt="Product image" />
                            <i class="bi bi-box-seam-fill text-primary me-2 fs-5" id="itemProductNoPicture"></i>
                            <div>
                                <div class="fw-bold" id="itemProductName"></div>
                                <div class="text-muted small">Tồn kho: <span id="itemProductStock"></span></div>
                            </div>
                        </div>
                        <div class="row g-3">
                            <div class="col-6">
                                <label class="form-label small fw-bold text-muted" for="itemQuantity">Số lượng</label>
                                <input type="number" id="itemQuantity" name="itemProductQuantity" class="form-control rounded-3"
                                       value="1" min="0.01" step="any" data-val="true"
                                       placeholder="0"
                                       data-val-range="Số lượng phải lớn hơn 0." data-val-range-min="0.000000000000000001"
                                       data-val-number="Số lượng không đúng." data-val-required="Vui lòng nhập số lượng." />
                                <span class="small text-danger field-validation-valid" data-valmsg-for="itemProductQuantity" data-valmsg-replace="true"></span>
                            </div>
                            <div class="col-6">
                                <label class="form-label small fw-bold text-muted noRefill" for="itemUnitPrice">Đơn giá</label>
                                <input type="number" id="itemUnitPrice" name="itemProductUnitPrice" class="form-control rounded-3"
                                       step="any" min="0" data-val="true"
                                       placeholder="0"
                                       data-val-range="Đơn giá phải lớn hơn 0." data-val-range-min="0"
                                       data-val-number="Đơn giá không đúng." data-val-required="Vui lòng nhập đơn giá." />
                                <span class="small text-danger field-validation-valid" data-valmsg-for="itemProductUnitPrice" data-valmsg-replace="true"></span>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-0 pt-0 pb-4">
                    <button type="button" class="btn btn-light px-4 rounded-3" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" id="addItemToTable" class="btn btn-success px-4 rounded-3 shadow-sm d-none noDisabled">
                        <i class="bi bi-plus-lg me-1"></i>
                        Thêm vào
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Edit Discount Modal -->
<div class="modal fade" id="editDiscountModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content border-0 shadow rounded-4">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold">Giảm giá đơn hàng</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body py-3">
                <form id="editDiscountForm">
                    <input type="hidden" name="Id" value="@Model.Id" />
                    <label class="form-label small fw-bold text-muted">MỨC GIẢM GIÁ (Đ)</label>
                    <input type="number" name="OrderDiscount" class="form-control rounded-3" value="@Model.OrderDiscount" min="0" step="any" required />
                </form>
            </div>
            <div class="modal-footer border-0 pt-0 pb-4">
                <button type="button" id="submitDiscount" class="btn btn-primary w-100 rounded-3 shadow-sm">Cập nhật</button>
            </div>
        </div>
    </div>
</div>

<!-- Payment Modal -->
<div class="modal fade" id="paymentModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow rounded-4">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold">Xác nhận thanh toán</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body py-4">
                <form id="paymentForm" method="post" action="@Url.Action("MarkAsPaid")">
                    <input type="hidden" name="OrderId" value="@Model.Id" />
                    
                    <div class="mb-3">
                        <label class="form-label fw-bold text-muted small">PHƯƠNG THỨC THANH TOÁN</label>
                        <select name="PaymentMethod" class="form-select rounded-3" required>
                            <option value="0">Tiền mặt</option>
                            <option value="1">Chuyển khoản</option>
                            <option value="2">COD</option>
                            <option value="3">Khác</option>
                        </select>
                    </div>
                    
                    <div class="mb-3">
                        <label class="form-label fw-bold text-muted small">MÃ GIAO DỊCH / GHI CHÚ</label>
                        <input type="text" name="Note" class="form-control rounded-3" placeholder="Ví dụ: CK VCB 123456" />
                    </div>
                    
                    <div class="text-end mt-4">
                        <button type="button" class="btn btn-light px-4 rounded-3" data-bs-dismiss="modal">Hủy</button>
                        <button type="submit" class="btn btn-success px-4 rounded-3 shadow-sm">Xác nhận đã thu tiền</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Shipping Modal -->
<div class="modal fade" id="shippingModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow rounded-4">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold">Cập nhật Vận chuyển</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body py-4">
                <form id="shippingForm" method="post" action="@Url.Action("UpdateShipping")">
                    <input type="hidden" name="OrderId" value="@Model.Id" />
                    
                    <div class="mb-3">
                        <label class="form-label fw-bold text-muted small">TRẠNG THÁI GIAO HÀNG</label>
                        <select name="ShippingStatus" class="form-select rounded-3" required>
                            <option value="0" selected="@(Model.ShippingStatus == 0)">Chưa giao</option>
                            <option value="1" selected="@(Model.ShippingStatus == 1)">Đang giao</option>
                            <option value="2" selected="@(Model.ShippingStatus == 2)">Đã giao hàng (Hoàn tất)</option>
                            <option value="3" selected="@(Model.ShippingStatus == 3)">Bị trả lại / Không nhận</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold text-muted small">ĐỊA CHỈ GIAO HÀNG</label>
                        <textarea name="Address" class="form-control rounded-3" rows="2">@Model.ShippingAddress</textarea>
                    </div>
                    
                    <div class="mb-3">
                        <label class="form-label fw-bold text-muted small">MÃ VẬN ĐƠN / GHI CHÚ VẬN CHUYỂN</label>
                        <input type="text" name="Note" class="form-control rounded-3" value="@Model.ShippingNote" placeholder="Ví dụ: GHTK 9999123" />
                    </div>
                    
                    <div class="text-end mt-4">
                        <button type="button" class="btn btn-light px-4 rounded-3" data-bs-dismiss="modal">Hủy</button>
                        <button type="submit" class="btn btn-info text-white px-4 rounded-3 shadow-sm">Lưu cập nhật</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Cancel Modal -->
<div class="modal fade" id="cancelModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow rounded-4">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold text-danger">Xác nhận hủy đơn hàng</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="alert alert-warning m-3 border-0 rounded-3 small">
                <i class="bi bi-exclamation-triangle-fill me-2"></i> Hệ thống sẽ tự động hoàn trả số lượng vào Tồn kho (trạng thái Available).
            </div>
            <div class="modal-body py-2">
                <form id="cancelForm" method="post" action="@Url.Action("CancelOrder")">
                    <input type="hidden" name="OrderId" value="@Model.Id" />
                    
                    <div class="mb-3">
                        <label class="form-label fw-bold text-muted small">LÝ DO HỦY ĐƠN HÀNG</label>
                        <textarea name="Reason" class="form-control rounded-3" rows="3" required placeholder="Vui lòng nhập lý do hủy..."></textarea>
                    </div>
                    
                    <div class="text-end mt-4 text-end">
                        <button type="button" class="btn btn-light px-4 rounded-3" data-bs-dismiss="modal">Đóng</button>
                        <button type="submit" class="btn btn-danger px-4 rounded-3 shadow-sm">Xác nhận Hủy đơn</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/modules/order.details.js" type="module"></script>
}
@section Styles {
    <style>
        .letter-spacing-1 { letter-spacing: 1px; }
        .product-icon-placeholder { transition: all 0.3s ease; }
        tr:hover .product-icon-placeholder { background-color: var(--bs-primary-bg-subtle) !important; transform: scale(1.05); }
        .card { transition: transform 0.2s ease, box-shadow 0.2s ease; }
        .card:hover { box-shadow: 0 .5rem 1.5rem rgba(0,0,0,.08) !important; }
        .bg-gradient { background: linear-gradient(135deg, rgba(255,255,255,0.1) 0%, rgba(0,0,0,0.1) 100%); }
        .table thead th { border-top: 0; }
        .italic { font-style: italic; }
    </style>
}
