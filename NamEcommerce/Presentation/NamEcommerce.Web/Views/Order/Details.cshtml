@model OrderDetailsModel
@using System.Text
@inject IWebHelper WebHelper
@{
    ViewData["Title"] = $"Đơn hàng {Model.Code}";
}

<div class="container py-4">
    @if (TempData[ViewConstants.OrderSuccessMessage] != null)
    {
        <div class="alert alert-success alert-dismissible fade show mb-4 rounded-3 shadow-sm" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> 
            @TempData[ViewConstants.OrderSuccessMessage]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData[ViewConstants.OrderErrorMessage] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show mb-4 rounded-3 shadow-sm" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> 
            @TempData[ViewConstants.OrderErrorMessage]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    <div class="d-flex flex-wrap justify-content-between align-items-center mb-4">
        <div class="mb-3">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-1">
                    <li class="breadcrumb-item"><a asp-action="List" class="text-decoration-none">Đơn hàng</a></li>
                    <li class="breadcrumb-item active" aria-current="page">Chi tiết</li>
                </ol>
            </nav>
            <h1 class="h3 mb-0 fw-bold">
                Chi tiết Đơn hàng 
                <span class="text-muted text-nowrap small">@Model.Code</span>
            </h1>
        </div>
        <div class="d-flex gap-2 justify-content-between flex-grow-1 flex-lg-grow-0">
            <a asp-action="List" class="btn btn-light">
                <i class="bi bi-arrow-left me-1"></i> Quay lại
            </a>
            <button type="button" class="btn btn-outline-info" onclick="window.print()">
                <i class="bi bi-printer me-1"></i> In hóa đơn
            </button>
        </div>
    </div>
    <div class="row g-4">
        <div class="col-lg-8 order-1 order-lg-0">
            <div class="card border-0 shadow-sm rounded-4 mb-4">
                <div class="card-header bg-white border-0 py-3 d-flex justify-content-between align-items-center">
                    <h5 class="mb-0 fw-bold"><i class="bi bi-box-seam me-2 text-primary"></i>Danh sách Sản phẩm</h5>
                    <span class="badge bg-light text-dark border fw-normal">@Model.Items.Count sản phẩm</span>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="bg-light text-muted small text-uppercase">
                                <tr>
                                    <th class="ps-4">Sản phẩm</th>
                                    <th class="text-center" style="width: 15%">Số lượng</th>
                                    <th class="text-end" style="width: 20%">Đơn giá</th>
                                    <th class="text-end d-none d-lg-table-cell pe-4 pe-lg-0" style="width: 20%">Thành tiền</th>
                                    @if (Model.CanUpdateOrderItems)
                                    {
                                        <th class="text-end pe-4" style="width: 5%"></th>
                                    }
                                </tr>
                            </thead>
                            <tbody id="itemsTableBody">
                                @foreach (var item in Model.Items)
                                {
                                    <tr data-item-id="@item.Id">
                                        <td class="ps-4">
                                            <div class="d-flex align-items-center gap-3">
                                                <div class="d-none d-lg-block">
                                                    @if (string.IsNullOrEmpty(item.ProductPicture))
                                                    {
                                                        <div class="product-icon-placeholder me-3 rounded-3 bg-light d-flex align-items-center justify-content-center" style="width: 48px; height: 48px;">
                                                            <i class="bi bi-image text-muted fs-4"></i>
                                                        </div>
                                                    }
                                                    else
                                                    {
                                                        <div>
                                                            <img src="@item.ProductPicture" class="img-fluid img-thumbnail item-product-img" style="width:45px;"/>
                                                        </div>
                                                    }
                                                </div>
                                                <div>
                                                    <div class="fw-bold text-dark">@item.ProductName</div>
                                                </div>
                                            </div>
                                        </td>
                                        <td class="text-center">
                                            <span class="fw-semibold quantity-text">@item.Quantity.ToString(ViewConstants.NumberCustomFormat)</span>
                                        </td>
                                        <td class="text-end">
                                            <span class="unit-price-text">@item.UnitPrice.ToString(ViewConstants.NumberCustomFormat) @ViewConstants.DefaultCurrencySymbol</span>
                                        </td>
                                        <td class="text-end fw-bold text-primary d-none d-lg-table-cell pe-4 pe-lg-0">
                                            <span class="total-price-text">@(item.SubTotal.ToString(ViewConstants.NumberCustomFormat)) @ViewConstants.DefaultCurrencySymbol</span>
                                        </td>
                                        @if (Model.CanUpdateOrderItems) {
                                            <td class="text-end pe-4">
                                                <div class="dropdown">
                                                    <button class="btn btn-sm btn-light border-0" type="button" data-bs-toggle="dropdown">
                                                        <i class="bi bi-three-dots-vertical"></i>
                                                    </button>
                                                    <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0">
                                                        <li>
                                                            <button class="dropdown-item btnEditItem" data-id="@item.Id" 
                                                                data-product="@item.ProductName" data-availableQty="@item.ProductAvailableQty?.ToString(ViewConstants.NumberCustomFormat)"
                                                                data-qty="@item.Quantity.ToString("#")" data-price="@item.UnitPrice.ToString("#")">
                                                                <i class="bi bi-pencil me-2 text-primary"></i> 
                                                                Chỉnh sửa
                                                            </button>
                                                        </li>
                                                        @if(Model.Items.Count > 1){
                                                            <li><hr class="dropdown-divider"></li>
                                                            <li>
                                                                <button class="dropdown-item text-danger btnRemoveItem" data-id="@item.Id" data-order="@Model.Id" data-name="@item.ProductName">
                                                                    <i class="bi bi-trash me-2"></i> 
                                                                    Xóa
                                                                </button>
                                                            </li>
                                                        }
                                                    </ul>
                                                </div>
                                            </td>
                                        }
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                    <div class="bg-light @(Model.Items.Count > 0 ? "" : "d-none") d-flex flex-column px-4" id="tableFooter">
                        <div class="d-flex justify-content-end gap-4">
                            <div class="text-end fw-bold py-2 border-0">Tạm tính</div>
                            <div class="text-end fw-bold py-2 border-0" id="subTotal">@Model.OrderSubTotal.ToString(ViewConstants.NumberCustomFormat) @ViewConstants.DefaultCurrencySymbol</div>
                        </div>
                        <div class="d-flex justify-content-end gap-4">
                            <div colspan="3" class="text-end fw-bold py-2 border-0">
                                Giảm giá
                            </div>
                            <div class="text-end fw-bold py-2 border-0" id="discountDisplay">
                                @if (Model.CanUpdateInfo)
                                {
                                    <a href="#" class="text-decoration-none text-danger" role="button" data-bs-toggle="modal" data-bs-target="#editDiscountModal">
                                        -@Model.OrderDiscount.ToString(ViewConstants.NumberCustomFormat) @ViewConstants.DefaultCurrencySymbol
                                        <i class="bi bi-pencil-square"></i>
                                        <span class="visually-hidden">Thay đổi</span>
                                    </a>
                                }
                                else
                                {
                                    <span class="text-danger">
                                        -@Model.OrderDiscount.ToString(ViewConstants.NumberCustomFormat) @ViewConstants.DefaultCurrencySymbol
                                    </span>
                                }
                            </div>
                        </div>
                        <div class="border-top d-flex justify-content-end gap-4">
                            <div colspan="3" class="text-end fw-bold py-3">Tổng cộng</div>
                            <div class="text-end fw-bold py-3 text-primary fs-5" id="grandTotal">
                                @Model.TotalAmount.ToString(ViewConstants.NumberCustomFormat) @ViewConstants.DefaultCurrencySymbol
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            @if (Model.CanUpdateOrderItems)
            {
                <div class="card border-0 shadow-sm rounded-4">
                    <div class="card-header bg-white border-0 py-3">
                        <h5 class="mb-0 fw-bold"><i class="bi bi-plus-circle me-2 text-success"></i>Thêm Sản phẩm</h5>
                    </div>
                    <div class="card-body">
                        <form id="addItemForm" method="post" asp-action="AddOrderItem" class="row g-3">
                            <input type="hidden" name="OrderId" value="@Model.Id" />
                            <input type="text" id="productId" name="ProductId" class="visually-hidden" 
                                data-val="true" data-val-required="Vui lòng chọn hàng hóa."/>
                            <div class="col-md-6 position-relative">
                                <label class="form-label small fw-bold text-muted uppercase">Tìm kiếm sản phẩm</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-white border-end-0"><i class="bi bi-search text-muted"></i></span>
                                    <input id="productPickerDisplay" class="form-control border-start-0 ps-0" placeholder="Nhập tên sản phẩm..." autocomplete="off" />
                                </div>
                                <div id="productSuggestions" class="list-group position-absolute w-100 shadow-lg mt-1" style="z-index: 1050; max-height: 250px; overflow-y: auto; display: none;"></div>
                                <span class="small text-danger field-validation-valid" data-valmsg-for="ProductId" data-valmsg-replace="true"></span>
                            </div>
                            <div class="col-md-3">
                                <label class="form-label small fw-bold text-muted uppercase" for="quantityInput">Số lượng</label>
                                <input type="number" id="quantityInput" name="Quantity" class="form-control" value="" min="1" step="any" 
                                       placeholder="0" data-val="true" disabled
                                       data-val-range="Số lượng phải lớn hơn 0." data-val-range-min="0.000000000000000001"
                                       data-val-number="Số lượng không đúng." data-val-required="Vui lòng nhập số lượng."/>
                                <span class="small text-danger field-validation-valid" data-valmsg-for="Quantity" data-valmsg-replace="true"></span>
                            </div>
                            <div class="col-md-3">
                                <label class="form-label small fw-bold text-muted uppercase" for="unitPriceInput">Đơn giá</label>
                                <div class="input-group">
                                    <input type="number" id="unitPriceInput" name="UnitPrice" class="form-control border-end-0"
                                        placeholder="0" min="0" step="any" data-val="true" disabled
                                        data-val-range="Đơn giá phải lớn hơn 0." data-val-range-min="0"
                                        data-val-number="Đơn giá không đúng." data-val-required="Vui lòng nhập đơn giá." />
                                    <span class="input-group-text bg-white border-start-0 text-muted small">@ViewConstants.DefaultCurrencySymbol</span>
                                </div>
                                <span class="small text-danger field-validation-valid" data-valmsg-for="UnitPrice" data-valmsg-replace="true"></span>
                            </div>
                            <div class="col-12 mt-4 text-end">
                                <button type="submit" class="btn btn-outline-primary px-4 py-2 rounded-3 shadow-sm" id="btnAddItemSubmit" disabled>
                                    <i class="bi bi-plus-lg me-1"></i> 
                                    Thêm vào đơn hàng
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            }
        </div>

        <!-- Sidebar -->
        <div class="col-lg-4 order-0 order-lg-1">
            <!-- Order Status Card -->
            @{
                var orderStatus = (OrderStatus)Model.Status;
            }
            <div class="card border-0 shadow-sm rounded-4 mb-4 overflow-hidden">
                <div class="card-body p-0">
                    <div class="p-4 text-center @orderStatus.GetDisplayColor() text-white bg-gradient">
                        <div class="small fw-normal mb-1 opacity-75 text-uppercase letter-spacing-1">Trạng thái đơn hàng</div>
                        <div class="fs-3 fw-bold">@orderStatus.GetDisplayText()</div>
                        @if (Model.Status == (int) OrderStatus.Locked) {
                            <div class="text-warning opacity-75 italic">
                                 "@Model.LockOrderReason"
                            </div>
                        } 
                    </div>
                </div>
            </div>
            
            @if (Model.CanLockOrder) {
                <div class="mb-4 d-grid d-lg-none">
                    <button type="button" class="btn btn-outline-danger" data-bs-toggle="modal" data-bs-target="#lockModal">
                        <i class="bi bi-lock-fill"></i> Khóa đơn hàng này
                    </button>
                </div>
            }

            <!-- Customer Card -->
            <div class="card border-0 shadow-sm rounded-4 mb-4">
                <div class="card-header bg-white border-0 py-3">
                    <h5 class="mb-0 fw-bold">
                        <i class="bi bi-person-circle me-2 text-success"></i>
                        Khách hàng
                    </h5>
                </div>
                <div class="card-body">
                    <div class="d-flex align-items-center mb-4">
                        <div class="bg-success bg-opacity-10 text-success rounded-circle p-3 me-3">
                            <i class="bi bi-person-fill fs-3"></i>
                        </div>
                        <div>
                            <div class="fs-5 fw-bold">@Model.CustomerName</div>
                            <div>
                                @if (!string.IsNullOrEmpty(Model.CustomerPhoneNumber))
                                {
                                    <a href="tel:@Model.CustomerPhoneNumber" class="text-decoration-none text-muted small">
                                        <i class="bi bi-telephone me-1"></i>
                                        @Model.CustomerPhoneNumber
                                    </a>
                                }
                            </div>
                            <div>
                                @if (!string.IsNullOrEmpty(Model.CustomerAddress))
                                {
                                    var encodedAddress = WebHelper.EncodeUrlComponent(Model.CustomerAddress);
                                    <a href="https://www.google.com/maps/search/@encodedAddress" target="_blank"
                                       class="text-decoration-none text-muted small">
                                        <i class="bi bi-geo-alt me-1"></i>
                                        @Model.CustomerAddress
                                    </a>
                                }
                            </div>
                        </div>
                    </div>
                    <a asp-controller="Customer" asp-action="Edit" asp-route-id="@Model.CustomerId" class="btn btn-sm btn-outline-success w-100 rounded-3">
                        <i class="bi bi-eye me-1"></i> 
                        Xem thông tin
                    </a>
                </div>
            </div>

            <!-- Note Card -->
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-header bg-white border-0 py-3 d-flex justify-content-between align-items-center">
                    <h5 class="mb-0 fw-bold"><i class="bi bi-sticky me-2 text-secondary"></i>Ghi chú</h5>
                    @if (Model.CanUpdateInfo)
                    {
                        <button type="button" class="btn btn-sm btn-light" data-bs-toggle="modal" data-bs-target="#changeNoteModal">
                            <i class="bi bi-pencil small"></i>
                            <span class="visually-hidden">
                                Viết ghi chú
                            </span>
                        </button>
                    }
                </div>
                <div class="card-body bg-light border-radius-bottom-4">
                    @if (!string.IsNullOrEmpty(Model.Note))
                    {
                        <p class="mb-0" id="orderNoteText">
                            @Model.Note
                        </p>
                    }
                    else
                    {
                        <span class="text-muted italic" id="orderNoteText">
                            Không có ghi chú
                        </span>
                    }
                </div>
            </div>
            
            <!-- Shipping Card -->
            <div class="card border-0 shadow-sm rounded-4 mt-4">
                <div class="card-header bg-white border-0 py-3 d-flex justify-content-between align-items-center">
                    <h5 class="mb-0 fw-bold"><i class="bi bi-truck me-2 text-warning"></i>Vận chuyển</h5>
                    @if (Model.CanUpdateInfo) {
                        <button type="button" class="btn btn-sm btn-outline-warning" data-bs-toggle="modal" data-bs-target="#shippingModal">
                            <i class="bi bi-pencil small"></i>
                            Cập nhật
                        </button>
                    }
                </div>
                <div class="card-body">
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">Ngày dự kiến:</span>
                        <span class="fw-bold">@(Model.ExpectedShippingDate?.ToString(ViewConstants.DefaultDateFormat) ?? "-")</span>
                    </div>
                    <div>
                        <div class="mb-1">
                            <span class="text-muted">
                                Địa chỉ giao hàng
                            </span>
                        </div>
                        <span class="fw-medium">
                            @if (!string.IsNullOrEmpty(Model.ShippingAddress))
                            {
                                var encodedAddress = WebHelper.EncodeUrlComponent(Model.ShippingAddress);
                                @Model.ShippingAddress
                                <a href="https://www.google.com/maps/search/@encodedAddress" target="_blank" class="ps-2 text-muted text-decoration-none small">
                                    <i class="bi bi-geo-alt me-1"></i> Xem
                                </a>
                            }
                            else
                            {
                                @:Chưa có địa chỉ
                            }
                        </span>
                    </div>
                </div>
            </div>

            @if (Model.CanLockOrder) {
                <div class="mt-4 d-none d-lg-grid">
                    <button type="button" class="btn btn-outline-danger" data-bs-toggle="modal" data-bs-target="#lockModal">
                        <i class="bi bi-shield-lock-fill"></i> Khóa đơn hàng này
                    </button>
                </div>
            }
        </div>
    </div>
</div>

@if (Model.CanUpdateOrderItems)
{
    <!-- Edit item modal -->
    <div class="modal fade" id="editItemModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow rounded-4">
                <div class="modal-header border-0 pb-0">
                    <h5 class="modal-title fw-bold">Chỉnh sửa sản phẩm</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <form id="editItemForm" method="post" asp-action="UpdateOrderItem">
                    <div class="modal-body py-4">
                        <div id="modalProductDisplay" class="mb-3 d-flex align-items-center gap-3">
                            <img class="img-fluid img-thumbnail d-none" style="width: 70px;" id="editProductHasPicture" alt="" />
                            <i class="bi bi-box-seam-fill text-primary me-2 fs-5" id="editProductNoPicture"></i>
                            <div class="d-flex flex-column gap-2">
                                <div class="small text-muted">Sản phẩm đang chọn</div>
                                <div class="fw-bold" id="editProductName"></div>
                                <div class="text-muted small">Tồn kho: <span id="editProductStock"></span></div>
                            </div>
                        </div>
                        <input type="hidden" id="editItemId" name="ItemId" />
                        <input type="hidden" name="OrderId" value="@Model.Id" />
                        <div class="row g-3">
                            <div class="col-6">
                                <label class="form-label small fw-bold text-muted" for="editQuantity">Số lượng</label>
                                <input type="number" id="editQuantity" name="Quantity" class="form-control rounded-3"
                                value="1" min="0.01" step="any" data-val="true"
                                placeholder="0"
                                data-val-range="Số lượng phải lớn hơn 0." data-val-range-min="0.000000000000000001"
                                data-val-number="Số lượng không đúng." data-val-required="Vui lòng nhập số lượng." />
                                <span class="small text-danger field-validation-valid" data-valmsg-for="Quantity" data-valmsg-replace="true"></span>
                            </div>
                            <div class="col-6">
                                <label class="form-label small fw-bold text-muted noRefill" for="editUnitPrice">Đơn giá</label>
                                <input type="number" id="editUnitPrice" name="UnitPrice" class="form-control rounded-3"
                                step="any" min="0" data-val="true"
                                placeholder="0"
                                data-val-range="Đơn giá phải lớn hơn 0." data-val-range-min="0"
                                data-val-number="Đơn giá không đúng." data-val-required="Vui lòng nhập đơn giá." />
                                <span class="small text-danger field-validation-valid" data-valmsg-for="UnitPrice" data-valmsg-replace="true"></span>
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer border-0 pt-0 pb-4">
                        <button type="button" class="btn btn-light px-4 rounded-3" data-bs-dismiss="modal">Hủy bỏ</button>
                        <button type="submit" id="submitEditItem" class="btn btn-primary px-4 rounded-3 shadow-sm">Lưu thay đổi</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Add product modal -->
    <div class="modal fade" id="addProductModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow rounded-4">
                <div class="modal-header border-0 pb-0">
                    <h5 class="modal-title fw-bold">Thêm sản phẩm</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <form action="#" method="post">
                    <div class="modal-body py-4">
                        <div class="mb-3">
                            <label class="form-label small fw-bold text-muted uppercase">Tìm kiếm sản phẩm</label>
                            <div class="input-group">
                                <span class="input-group-text bg-white border-end-0"><i class="bi bi-box text-muted"></i></span>
                                <input type="text" id="productSearch" class="form-control border-start-0 ps-0"
                                placeholder="Nhập tên sản phẩm..." autocomplete="off">
                            </div>
                            <div id="productSuggestions" class="list-group shadow-lg mt-1"
                            style="display: none; max-height: 200px; overflow-y: auto;"></div>
                        </div>

                        <div id="modalProductInfo" class="d-none">
                            <div class="alert alert-light border-0 rounded-3 mb-3 d-flex align-items-start gap-3">
                                <img class="img-fluid img-thumbnail d-none" style="width: 70px;" id="itemProductHasPicture" alt="Product image" />
                                <i class="bi bi-box-seam-fill text-primary me-2 fs-5" id="itemProductNoPicture"></i>
                                <div>
                                    <div class="fw-bold" id="itemProductName"></div>
                                    <div class="text-muted small">Tồn kho: <span id="itemProductStock"></span></div>
                                </div>
                            </div>
                            <div class="row g-3">
                                <div class="col-6">
                                    <label class="form-label small fw-bold text-muted" for="itemQuantity">Số lượng</label>
                                    <input type="number" id="itemQuantity" name="itemProductQuantity" class="form-control rounded-3"
                                    value="1" min="0.01" step="any" data-val="true"
                                    placeholder="0"
                                    data-val-range="Số lượng phải lớn hơn 0." data-val-range-min="0.000000000000000001"
                                    data-val-number="Số lượng không đúng." data-val-required="Vui lòng nhập số lượng." />
                                    <span class="small text-danger field-validation-valid" data-valmsg-for="itemProductQuantity" data-valmsg-replace="true"></span>
                                </div>
                                <div class="col-6">
                                    <label class="form-label small fw-bold text-muted noRefill" for="itemUnitPrice">Đơn giá</label>
                                    <input type="number" id="itemUnitPrice" name="itemProductUnitPrice" class="form-control rounded-3"
                                    step="any" min="0" data-val="true"
                                    placeholder="0"
                                    data-val-range="Đơn giá phải lớn hơn 0." data-val-range-min="0"
                                    data-val-number="Đơn giá không đúng." data-val-required="Vui lòng nhập đơn giá." />
                                    <span class="small text-danger field-validation-valid" data-valmsg-for="itemProductUnitPrice" data-valmsg-replace="true"></span>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer border-0 pt-0 pb-4">
                        <button type="button" class="btn btn-light px-4 rounded-3" data-bs-dismiss="modal">Hủy</button>
                        <button type="submit" id="addItemToTable" class="btn btn-success px-4 rounded-3 shadow-sm d-none noDisabled">
                            <i class="bi bi-plus-lg me-1"></i>
                            Thêm vào
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}

@if (Model.CanUpdateInfo) 
{
    <!-- Change order note modal -->
    <div class="modal fade" id="changeNoteModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow rounded-4">
                <div class="modal-header border-0 pb-0">
                    <h5 class="modal-title fw-bold text-secondary">Ghi chú đơn hàng</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <form id="changeNoteForm" method="post" asp-action="UpdateOrderNote">
                        <input type="hidden" name="OrderId" value="@Model.Id" />
                        <div class="mb-3">
                            <label class="form-label fw-bold text-muted small" for="orderNote">Ghi chú</label>
                            <textarea id="orderNote" name="Note" class="form-control rounded-3" rows="3"
                            placeholder="Viết ghi chú cho đơn hàng"
                            data-val-maxlength="Lý do hủy đơn tối đa 1000 ký tự." data-val-maxlength-max="1000">@Model.Note</textarea>
                            <span class="small text-danger field-validation-valid" data-valmsg-for="Note" data-valmsg-replace="true"></span>
                        </div>
                        <div class="text-end mt-4 text-end">
                            <button type="button" class="btn btn-light px-4 rounded-3" data-bs-dismiss="modal">Đóng</button>
                            <button type="submit" class="btn btn-secondary px-4 rounded-3 shadow-sm">
                                Cập nhật
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <!-- Edit discount modal -->
    <div class="modal fade" id="editDiscountModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-sm">
            <div class="modal-content border-0 shadow rounded-4">
                <div class="modal-header border-0 pb-0">
                    <h5 class="modal-title fw-bold">Giảm giá đơn hàng</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <form id="editDiscountForm" method="post" asp-action="UpdateOrderDiscount">
                    <div class="modal-body">
                        <input type="hidden" name="OrderId" value="@Model.Id" />
                        <div class="mb-3">
                            <label class="form-label small fw-bold text-muted" for="orderDiscount">Giảm giá</label>
                            <input type="number" id="orderDiscount" name="OrderDiscount" class="form-control rounded-3" 
                            value="@Model.OrderDiscount.ToString("#")" min="0" step="any" data-val="true"
                            placeholder="0"
                            data-val-range="Giảm giá phải lớn hơn hoặc bằng 0." data-val-range-min="0"
                            data-val-number="Giảm giá không đúng." data-val-required="Vui lòng nhập giảm giá." />
                            <span class="small text-danger field-validation-valid" data-valmsg-for="Reason" data-valmsg-replace="true"></span>
                        </div>

                        <div class="text-end mt-4 text-end">
                            <button type="button" class="btn btn-light px-4 rounded-3" data-bs-dismiss="modal">Đóng</button>
                            <button type="submit" class="btn btn-danger px-4 rounded-3 shadow-sm">
                                Lưu lại
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="modal fade" id="shippingModal" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content border-0 shadow rounded-4">
                    <div class="modal-header border-0 pb-0">
                        <h5 class="modal-title fw-bold text-warning">Cập nhật vận chuyển</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body py-4">
                        <form id="shippingForm" method="post" asp-action="UpdateShipping">
                            <input type="hidden" name="OrderId" value="@Model.Id" />
                            <div class="mb-3">
                                <label class="form-label fw-bold text-muted small" for="shippingExpectedDate">Ngày giao dự kiến</label>
                                <input type="date" id="shippingExpectedDate" name="ExpectedShippingDate" class="form-control"/>
                            <span class="small text-danger field-validation-valid" data-valmsg-for="ExpectedShippingDate" data-valmsg-replace="true"></span>
                            </div>
                            <div class="mb-3">
                                <label class="form-label fw-bold text-muted small" for="shippingAddress">Địa chỉ giao hàng</label>
                                <input id="shippingAddress" name="Address" class="form-control" data-val="true" data-val-required="Vui lòng nhập địa chỉ giao hàng."/>
                            <span class="small text-danger field-validation-valid" data-valmsg-for="Address" data-valmsg-replace="true"></span>
                            </div>
                            <div class="text-end mt-4">
                                <button type="button" class="btn btn-light px-4 rounded-3" data-bs-dismiss="modal">Hủy</button>
                                <button type="submit" class="btn btn-warning px-4 rounded-3 shadow-sm">Cập nhật</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
}

<!-- Lock modal -->
@if (Model.CanLockOrder)
{
    <div class="modal fade" id="lockModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow rounded-4">
                <div class="modal-header border-0 pb-0">
                    <h5 class="modal-title fw-bold text-danger">Xác nhận khóa đơn hàng</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <form id="lockForm" method="post" asp-action="LockOrder">
                        <input type="hidden" name="OrderId" value="@Model.Id" />
                        <div class="mb-3">
                            <label class="form-label fw-bold text-muted small" for="cancelReason">Lý do khóa đơn</label>
                            <textarea id="cancelReason" name="Reason" class="form-control rounded-3" rows="3"
                            placeholder="Nhập lý do khóa đơn"
                            data-val="true" 
                            data-val-maxlength="Lý do khóa đơn tối đa 1000 ký tự." data-val-maxlength-max="1000"></textarea>
                            <span class="small text-danger field-validation-valid" data-valmsg-for="Reason" data-valmsg-replace="true"></span>
                        </div>
                        <div class="text-end mt-4 text-end">
                            <button type="button" class="btn btn-light px-4 rounded-3" data-bs-dismiss="modal">Đóng</button>
                            <button type="submit" class="btn btn-danger px-4 rounded-3 shadow-sm">
                                Khóa đơn
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/modules/order.details.js" type="module"></script>
}
@section Styles {
    <style>
        .letter-spacing-1 { letter-spacing: 1px; }
        .product-icon-placeholder { transition: all 0.3s ease; }
        tr:hover .product-icon-placeholder { background-color: var(--bs-primary-bg-subtle) !important; transform: scale(1.05); }
        .card { transition: transform 0.2s ease, box-shadow 0.2s ease; }
        .card:hover { box-shadow: 0 .5rem 1.5rem rgba(0,0,0,.08) !important; }
        .bg-gradient { background: linear-gradient(135deg, rgba(255,255,255,0.1) 0%, rgba(0,0,0,0.1) 100%); }
        .table thead th { border-top: 0; }
        .italic { font-style: italic; }
    </style>
}
