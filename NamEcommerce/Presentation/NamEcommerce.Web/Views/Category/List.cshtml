@model CategoryListModel
@{
    ViewData[ViewConstants.PageTitle] = "Danh mục";
    string? query = Model.Keywords;
}

<div class="page-header">
    <div>
        <h1 class="page-header-title">Danh mục</h1>
        <p class="page-header-subtitle">Quản lý danh mục phân loại hàng hóa</p>
    </div>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-lg me-1"></i>Thêm mới
    </a>
</div>

<div class="content-card">
    <div class="action-toolbar">
        <div class="search-group">
            <div class="search-input-group input-group">
                <span class="input-group-text"><i class="bi bi-search text-muted"></i></span>
                <partial name="_Search" model="@(new CategoryListSearchModel { Keywords = Model.Keywords })" />
            </div>
            @if (!string.IsNullOrEmpty(query))
            {
                <a asp-action="List" class="btn btn-sm btn-outline-secondary">
                    <i class="bi bi-x"></i> Xóa lọc
                </a>
            }
        </div>
    </div>

    <div class="table-responsive">
        <table class="table data-table">
            <thead>
                <tr>
                    <th class="ps-4">Tên danh mục</th>
                    <th class="text-center" style="width: 120px;">Thứ tự</th>
                    <th style="width: 100px;"></th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Data.Pagination.TotalCount > 0)
                {
                    @foreach (var item in Model.Data)
                    {
                        <tr>
                            <td class="ps-4">
                                @if (Model.BreadcrumbOpts.Disabled)
                                {
                                    @HighlighHelper.Highlight(item.Name, query)
                                }
                                else if (Model.BreadcrumbOpts.ExcludeCurrent)
                                {
                                    @if (!string.IsNullOrEmpty(item.Breadcrumb))
                                    {
                                        <span class="text-muted small me-1">
                                            @item.Breadcrumb @Model.BreadcrumbOpts.Separator
                                        </span>
                                    }
                                    @HighlighHelper.Highlight(item.Name, query)
                                }
                                else
                                {
                                    @item.Breadcrumb
                                }
                            </td>
                            <td class="text-center text-muted">@item.DisplayOrder</td>
                            <td class="text-end pe-3">
                                <a class="btn-table-action me-1" asp-action="Edit" asp-route-id="@item.Id" title="Chỉnh sửa">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <button type="button" class="btn-table-action danger btnDelete"
                                        data-id="@item.Id" data-name="@item.Name" title="Xóa">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="3">
                            <div class="empty-state">
                                <div class="empty-icon"><i class="bi bi-grid"></i></div>
                                <h5>Chưa có danh mục nào</h5>
                                <p>Tạo danh mục đầu tiên để phân loại hàng hóa.</p>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (Model.Data.Pagination.TotalCount > 0)
    {
        <partial name="_Pager" model="Model.Data.Pagination" />
    }
</div>

@foreach (var item in Model.Data)
{
    <partial name="_DeleteForm" model="@item.Id" />
}

@section Scripts {
    <script type="module" defer>
        import { confirm } from "/modules/modals.js";
        (function () {
            $('.btnDelete').on('click', async function (e) {
                e.preventDefault();
                const name = $(this).data('name');
                $(this).prop('disabled', true);
                const confirmed = await confirm('Xóa danh mục', `Bạn muốn xóa danh mục <strong>${name}</strong>?`);
                if (!confirmed) { $(this).prop('disabled', false); return; }
                $(`#deleteForm${$(this).data('id')}`).submit();
            });
        })();
    </script>
}
