@model EditCategoryModel
@{
    ViewData[ViewConstants.PageTitle] = "Chỉnh sửa Danh mục";
}
<section class="content-title my-4 text-center">
    <h1>
        Chỉnh sửa
        <a asp-action="List" class="text-muted d-block fs-3 ps-2 text-decoration-none">Danh mục</a>
    </h1>
</section>
<section class="content-data">
    <div>
        <div class="p-4 shadow offset-lg-3 col-lg-6 offset-md-2 col-md-8">
            <div class="d-flex justify-content-end mb-3">
                <a asp-action="List" class="text-muted small text-decoration-none">
                    <i class="bi bi-arrow-90deg-left"></i>
                    Trở lại
                </a>
            </div>
            <div asp-validation-summary="ModelOnly" class="alert alert-warning"></div>
            <form class="row g-3" method="post" asp-antiforgery="true">
                <input type="hidden" asp-for="Id" />
                <ul class="nav nav-tabs" id="categoryTabs" role="tablist">
                    <li class="nav-item" role="presentation">
                        <button class="nav-link active" id="infoTab" data-bs-toggle="tab" data-bs-target="#info" type="button" role="tab" aria-controls="info" aria-selected="true">
                            Thông tin
                        </button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link" id="additionalTab" data-bs-toggle="tab" data-bs-target="#additional" type="button" role="tab" aria-controls="additional" aria-selected="false">
                            Cài đặt
                        </button>
                    </li>
                </ul>
                <div class="tab-content" id="categoryContent">
                    <div class="tab-pane fade show active" id="info" role="tabpanel" aria-labelledby="infoTab">
                        <div class="col-12 mb-3">
                            <label asp-for="Name" class="form-label"></label>
                            <input asp-for="Name" class="form-control" placeholder="@Html.DisplayNameFor(m => m.Name)" autofocus />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>
                        <div class="col-12 mb-3">
                            <label asp-for="ParentId" class="form-label"></label>
                            <select asp-for="ParentId" class="form-select" placeholder="@Html.DisplayNameFor(m => m.ParentId)">
                                <option selected="@(!Model.ParentId.HasValue)" value="@string.Empty">(Không chọn)</option>
                                @if (Model.AvailableParents is not null)
                                {
                                    foreach (var parent in Model.AvailableParents)
                                    {
                                        <option value="@parent.Id" selected="@(parent.Id == Model.ParentId)">
                                            @parent.Name
                                        </option>
                                    }
                                }
                            </select>
                            <span asp-validation-for="ParentId" class="text-danger small"></span>
                        </div>
                    </div>
                    <div class="tab-pane fade" id="additional" role="tabpanel" aria-labelledby="additionalTab">
                        <div class="col-12 mb-3">
                            <label asp-for="DisplayOrder" class="form-label"></label>
                            <input asp-for="DisplayOrder" class="form-control w-50" placeholder="@Html.DisplayNameFor(m => m.DisplayOrder)" />
                            <span asp-validation-for="DisplayOrder" class="text-danger small"></span>
                        </div>
                    </div>
                </div>
                <div class="col-12">
                    <button type="submit" class="btn btn-primary">Chỉnh sửa</button>
                </div>
            </form>
        </div>
    </div>
</section>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}