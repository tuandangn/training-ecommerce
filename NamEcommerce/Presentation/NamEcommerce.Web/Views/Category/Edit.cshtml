@model EditCategoryModel
@{
    ViewData[ViewConstants.PageTitle] = "Chỉnh sửa Danh mục";
}

<div class="page-header">
    <div>
        <h1 class="page-header-title">Chỉnh sửa Danh mục</h1>
        <p class="page-header-subtitle">Cập nhật thông tin danh mục</p>
    </div>
</div>

<div class="form-card">
    <div class="form-card-header">
        <h2 class="form-card-title"><i class="bi bi-grid me-2 text-primary"></i>Thông tin danh mục</h2>
        <a asp-action="List" class="form-card-breadcrumb">
            <i class="bi bi-arrow-left"></i> Trở về danh sách
        </a>
    </div>
    <div class="form-card-body">
        <div asp-validation-summary="ModelOnly" class="alert alert-warning alert-global"></div>
        <form class="row g-3" method="post" asp-antiforgery="true">
            <input type="hidden" asp-for="Id" />
            <ul class="nav nav-tabs" id="categoryTabs" role="tablist">
                <li class="nav-item" role="presentation">
                    <button class="nav-link active" id="infoTab" data-bs-toggle="tab" data-bs-target="#info"
                            type="button" role="tab" aria-selected="true">
                        <i class="bi bi-info-circle me-1"></i>Thông tin
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" id="additionalTab" data-bs-toggle="tab" data-bs-target="#additional"
                            type="button" role="tab" aria-selected="false">
                        <i class="bi bi-sliders me-1"></i>Cài đặt
                    </button>
                </li>
            </ul>
            <div class="tab-content pt-3" id="categoryContent">
                <div class="tab-pane fade show active" id="info" role="tabpanel">
                    <div class="row g-3">
                        <div class="col-12">
                            <label asp-for="Name" class="form-label"></label>
                            <input asp-for="Name" class="form-control" placeholder="@Html.DisplayNameFor(m => m.Name)" autofocus />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>
                        <div class="col-12">
                            <label asp-for="ParentId" class="form-label"></label>
                            <select asp-for="ParentId" class="form-select">
                                <option selected="@(!Model.ParentId.HasValue)" value="@string.Empty">(Không có danh mục cha)</option>
                                @if (Model.AvailableParents is not null)
                                {
                                    foreach (var parent in Model.AvailableParents)
                                    {
                                        <option value="@parent.Id" selected="@(parent.Id == Model.ParentId)">@parent.Name</option>
                                    }
                                }
                            </select>
                            <span asp-validation-for="ParentId" class="text-danger small"></span>
                        </div>
                    </div>
                </div>
                <div class="tab-pane fade" id="additional" role="tabpanel">
                    <div class="row g-3">
                        <div class="col-sm-6 col-md-4">
                            <label asp-for="DisplayOrder" class="form-label"></label>
                            <input asp-for="DisplayOrder" class="form-control" placeholder="0" />
                            <span asp-validation-for="DisplayOrder" class="text-danger small"></span>
                        </div>
                    </div>
                </div>
            </div>
            <div class="form-card-footer" style="margin: 0 -1.5rem -1.5rem; border-radius: 0 0 var(--card-radius) var(--card-radius);">
                <a asp-action="List" class="btn btn-outline-secondary">Hủy</a>
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-check-lg me-1"></i>Lưu thay đổi
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}