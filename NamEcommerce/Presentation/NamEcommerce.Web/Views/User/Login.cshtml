@using NamEcommerce.Web.Models.Users
@model LoginModel
@{
    ViewData[ViewConstants.PageTitle] = "Đăng nhập";
    string? returnUrl = Context.Request.Query["ReturnUrl"];
}
<div class="d-flex align-items-center justify-content-center" style="min-height: calc(100vh - 120px);">
    <div class="w-100" style="max-width: 420px;">
        <!-- Logo / Brand -->
        <div class="text-center mb-4">
            <div class="mb-2" style="color: var(--primary); font-size: 2.8rem;">
                <i class="bi bi-bag-heart-fill"></i>
            </div>
            <h1 class="fw-bold mb-0" style="font-size: 1.5rem; color: var(--gray-900);">@Information.Name</h1>
            <p class="text-muted small mt-1">Đăng nhập để tiếp tục quản lý</p>
        </div>

        <!-- Login Card -->
        <div class="content-card">
            <div class="content-card-body" style="padding: 2rem;">
                <div asp-validation-summary="ModelOnly" class="alert alert-warning alert-global"></div>
                <input type="hidden" name="ReturnUrl" value="@returnUrl" />

                <form class="row g-3" method="post" asp-antiforgery="true">
                    <div class="col-12">
                        <label asp-for="Username" class="form-label"></label>
                        <div class="input-group">
                            <span class="input-group-text bg-white" style="border-right: none; border-color: var(--gray-200);">
                                <i class="bi bi-person text-muted"></i>
                            </span>
                            <input asp-for="Username" class="form-control" placeholder="Tên đăng nhập" value="admin12"
                                   style="border-left: none;" autofocus />
                        </div>
                        <span asp-validation-for="Username" class="text-danger small"></span>
                    </div>
                    <div class="col-12">
                        <label asp-for="Password" class="form-label"></label>
                        <div class="input-group">
                            <span class="input-group-text bg-white" style="border-right: none; border-color: var(--gray-200);">
                                <i class="bi bi-lock text-muted"></i>
                            </span>
                            <input asp-for="Password" class="form-control" placeholder="Mật khẩu" value="adminadmin"
                                   style="border-left: none;" />
                        </div>
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>
                    <div class="col-12">
                        <button type="submit" class="btn btn-primary w-100 py-2" style="font-size: 0.95rem;">
                            <i class="bi bi-box-arrow-in-right me-2"></i>Đăng nhập
                        </button>
                    </div>
                </form>
            </div>
        </div>

        <p class="text-center text-muted small mt-3">
            &copy; 2026 @Information.Name
        </p>
    </div>
</div>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}