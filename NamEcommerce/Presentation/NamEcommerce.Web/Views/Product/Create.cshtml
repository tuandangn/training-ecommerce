@model CreateProductModel
@{
    ViewData[ViewConstants.PageTitle] = "Thêm mới Hàng hóa";
}
<section class="content-title my-4 text-center">
    <h1>
        Thêm mới
        <a asp-action="List" class="text-muted d-block fs-3 ps-2 text-decoration-none">Hàng hóa</a>
    </h1>
</section>
<section class="content-data">
    <div>
        <div class="p-4 shadow offset-lg-2 col-lg-8">
            <div class="d-flex justify-content-end mb-2">
                <a asp-action="List" class="text-muted small text-decoration-none">
                    <i class="bi bi-arrow-90deg-left"></i>
                    Trở lại
                </a>
            </div>
            <div asp-validation-summary="ModelOnly" class="alert alert-warning"></div>
            <form class="row g-3" method="post" asp-antiforgery="true">
                <ul class="nav nav-tabs" id="productTabs" role="tablist">
                    <li class="nav-item" role="presentation">
                        <button class="nav-link active" id="infoTab" data-bs-toggle="tab" data-bs-target="#info" type="button" role="tab" aria-controls="info" aria-selected="true">
                            Thông tin
                        </button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link" id="additionalTab" data-bs-toggle="tab" data-bs-target="#additional" type="button" role="tab" aria-controls="additional" aria-selected="false">
                            Cài đặt
                        </button>
                    </li>
                </ul>
                <div class="tab-content" id="productContent">
                    <div class="tab-pane fade show active" id="info" role="tabpanel" aria-labelledby="infoTab">
                        <div class="row">
                            <div class="col-12 col-lg-4 order-0 order-lg-2">
                                <partial name="_UploadPicture" for="ImageFile" />
                            </div>
                            <div class="col-12 col-lg-8 order-1">
                                <div class="row">
                                    <div class="col-12 mb-3">
                                        <label asp-for="Name" class="form-label"></label>
                                        <input asp-for="Name" class="form-control" placeholder="@Html.DisplayNameFor(m => m.Name)" autofocus />
                                        <span asp-validation-for="Name" class="text-danger small"></span>
                                    </div>
                                    <div class="col-12 col-md-8 mb-3">
                                        <label asp-for="CategoryId" class="form-label"></label>
                                        <select asp-for="CategoryId" class="form-select" placeholder="@Html.DisplayNameFor(m => m.CategoryId)">
                                            <option selected="@(!Model.CategoryId.HasValue)" value="@string.Empty">(Không chọn)</option>
                                            @if (Model.Categories is not null)
                                            {
                                                foreach (var category in Model.Categories)
                                                {
                                                    <option value="@category.Id" selected="@(category.Id == Model.CategoryId)">
                                                        @category.Name
                                                    </option>
                                                }
                                            }
                                        </select>
                                        <span asp-validation-for="CategoryId" class="text-danger small"></span>
                                    </div>
                                    <div class="col-12 col-md-4 mb-3">
                                        <label asp-for="DisplayOrder" class="form-label"></label>
                                        <input asp-for="DisplayOrder" class="form-control" placeholder="@Html.DisplayNameFor(m => m.DisplayOrder)" />
                                        <span asp-validation-for="DisplayOrder" class="text-danger small"></span>
                                    </div>
                                    <div class="col-12 mb-3">
                                        <label asp-for="ShortDesc" class="form-label"></label>
                                        <textarea asp-for="ShortDesc" class="form-control" rows="3" placeholder="@Html.DisplayNameFor(m => m.ShortDesc)"></textarea>
                                        <span asp-validation-for="ShortDesc" class="text-danger small"></span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="tab-pane fade" id="additional" role="tabpanel" aria-labelledby="additionalTab">
                        <div class="col-12 mb-3">
                            <label asp-for="DisplayOrder" class="form-label"></label>
                            <input asp-for="DisplayOrder" class="form-control w-25" placeholder="@Html.DisplayNameFor(m => m.DisplayOrder)" />
                            <span asp-validation-for="DisplayOrder" class="text-danger small"></span>
                        </div>
                    </div>
                </div>
                <div class="col-12">
                    <button type="submit" class="btn btn-primary">Thêm mới</button>
                </div>
            </form>
        </div>
    </div>
</section>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}