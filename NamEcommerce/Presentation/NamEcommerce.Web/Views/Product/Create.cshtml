@model CreateProductModel
@{
    ViewData[ViewConstants.PageTitle] = "Thêm mới Hàng hóa";
}

<div class="page-header">
    <div>
        <h1 class="page-header-title">Thêm mới Hàng hóa</h1>
        <p class="page-header-subtitle">Thêm sản phẩm mới vào danh mục hàng hóa</p>
    </div>
</div>

<div class="form-card" style="max-width: 1100px;">
    <div class="form-card-header">
        <h2 class="form-card-title"><i class="bi bi-tags me-2" style="color: var(--warning);"></i>Thông tin hàng hóa</h2>
        <a asp-action="List" class="form-card-breadcrumb">
            <i class="bi bi-arrow-left"></i> Trở về danh sách
        </a>
    </div>
    <form method="post" asp-antiforgery="true">
        <div class="form-card-body">
            <div asp-validation-summary="ModelOnly" class="alert alert-warning alert-global"></div>
            <ul class="nav nav-tabs" id="productTabs" role="tablist">
                <li class="nav-item" role="presentation">
                    <button class="nav-link active" id="infoTab" data-bs-toggle="tab" data-bs-target="#info"
                            type="button" role="tab" aria-selected="true">
                        <i class="bi bi-info-circle me-1"></i>Thông tin
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" id="additionalTab" data-bs-toggle="tab" data-bs-target="#additional"
                            type="button" role="tab" aria-selected="false">
                        <i class="bi bi-sliders me-1"></i>Cài đặt
                    </button>
                </li>
            </ul>
            <div class="tab-content px-3 pt-4" id="productContent">
                <div class="tab-pane fade show active" id="info" role="tabpanel">
                    <div class="row g-3">
                        <div class="col-12 col-lg-4 order-0 order-lg-2">
                            <partial name="_UploadPicture" for="ImageFile" />
                        </div>
                        <div class="col-12 col-lg-8 order-1">
                            <div class="row g-3">
                                <div class="col-12 col-md-8">
                                    <label asp-for="Name" class="form-label"></label>
                                    <input asp-for="Name" class="form-control" placeholder="@Html.DisplayNameFor(m => m.Name)" autofocus />
                                    <span asp-validation-for="Name" class="text-danger small"></span>
                                </div>
                                <div class="col-12 col-md-4">
                                    <label asp-for="UnitMeasurementId" class="form-label"></label>
                                    <select asp-for="UnitMeasurementId" class="form-select">
                                        <option selected="@(!Model.UnitMeasurementId.HasValue)" value="@string.Empty">(Không chọn)</option>
                                        @if (Model.AvailableUnitMeasurements is not null)
                                        {
                                            foreach (var unitMeasurement in Model.AvailableUnitMeasurements)
                                            {
                                                <option value="@unitMeasurement.Id" selected="@(unitMeasurement.Id == Model.UnitMeasurementId)">
                                                    @unitMeasurement.Name
                                                </option>
                                            }
                                        }
                                    </select>
                                    <span asp-validation-for="UnitMeasurementId" class="text-danger small"></span>
                                </div>
                                <div class="col-12">
                                    <label asp-for="CategoryId" class="form-label"></label>
                                    <select asp-for="CategoryId" class="form-select">
                                        <option selected="@(!Model.CategoryId.HasValue)" value="@string.Empty">(Không chọn)</option>
                                        @if (Model.AvailableCategories is not null)
                                        {
                                            foreach (var category in Model.AvailableCategories)
                                            {
                                                <option value="@category.Id" selected="@(category.Id == Model.CategoryId)">
                                                    @category.Name
                                                </option>
                                            }
                                        }
                                    </select>
                                    <span asp-validation-for="CategoryId" class="text-danger small"></span>
                                </div>
                                <div class="col-12 col-md-6">
                                    <label asp-for="CostPrice" class="form-label"></label>
                                    @Html.EditorFor(m => m.CostPrice)
                                    <span asp-validation-for="CostPrice" class="text-danger small"></span>
                                </div>
                                <div class="col-12 col-md-6">
                                    <label asp-for="UnitPrice" class="form-label"></label>
                                    @Html.EditorFor(m => m.UnitPrice)
                                    <span asp-validation-for="UnitPrice" class="text-danger small"></span>
                                </div>
                                <div class="col-12">
                                    <label asp-for="ShortDesc" class="form-label"></label>
                                    <textarea asp-for="ShortDesc" class="form-control" rows="3" placeholder="Mô tả ngắn về hàng hóa..."></textarea>
                                    <span asp-validation-for="ShortDesc" class="text-danger small"></span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="tab-pane fade" id="additional" role="tabpanel">
                    <div class="row g-3">
                        <div class="col-sm-6 col-md-3">
                            <label asp-for="DisplayOrder" class="form-label"></label>
                            <input asp-for="DisplayOrder" class="form-control" placeholder="0" />
                            <span asp-validation-for="DisplayOrder" class="text-danger small"></span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="form-card-footer">
            <a asp-action="List" class="btn btn-outline-secondary">Hủy</a>
            <button type="submit" class="btn btn-primary flex-lg-grow-0 flex-grow-1">
                <i class="bi bi-plus-lg me-1"></i>
                Thêm mới
            </button>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}