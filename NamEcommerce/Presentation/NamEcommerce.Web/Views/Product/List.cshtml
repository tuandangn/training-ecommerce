@inject IWebHelper WebHelper
@model ProductListModel
@{
    ViewData[ViewConstants.PageTitle] = "Hàng hóa";
    string? query = Model.Keywords;
}

<div class="page-header">
    <div>
        <h1 class="page-header-title">Hàng hóa</h1>
        <p class="page-header-subtitle">Quản lý danh mục sản phẩm và hàng hóa</p>
    </div>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-lg me-1"></i>Thêm mới
    </a>
</div>

<div class="content-card">
    <div class="action-toolbar">
        <div class="search-group">
            <partial name="_Search" model="@(new ProductSearchModel { Q = Model.Keywords })" />
        </div>
    </div>
    <div class="table-responsive">
        <table class="table data-table">
            <thead>
                <tr>
                    <th class="ps-4" style="width: 80px;">Ảnh</th>
                    <th>Tên hàng hóa</th>
                    <th class="text-end">Giá bán</th>
                    <th class="d-none d-lg-table-cell">Danh mục</th>
                    <th class="text-end">Tồn kho</th>
                    <th class="d-none d-md-table-cell">Đơn vị</th>
                    <th>Nhà cung cấp</th>
                    <th style="width: 100px;"></th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Data.Pagination.TotalCount > 0)
                {
                    @foreach (var product in Model.Data)
                    {
                        <tr>
                            <td class="ps-4">
                                @if (string.IsNullOrEmpty(product.PictureUrl))
                                {
                                    <div class="d-flex align-items-center justify-content-center rounded"
                                         style="width: 44px; height: 44px; background: var(--gray-100);">
                                        <i class="bi bi-image text-muted"></i>
                                    </div>
                                }
                                else
                                {
                                    <a href="@product.PictureUrl" target="_blank" data-lightbox="products">
                                        <img src="@product.PictureUrl" alt="@product.Name"
                                             class="rounded" style="width: 44px; height: 44px; object-fit: cover;" />
                                    </a>
                                }
                            </td>
                            <td>
                                <span class="fw-medium d-block">@HighlighHelper.Highlight(product.Name, query)</span>
                                @if (product.CategoryId.HasValue)
                                {
                                    <span class="d-inline d-lg-none text-muted small">
                                        @HighlighHelper.Highlight(product.CategoryBreadcrumb, query)
                                    </span>
                                }
                            </td>
                            <td class="text-end">
                                <span class="fw-medium d-block text-nowrap">
                                    @product.UnitPrice.DisplayCurrency()
                                    @if (!string.IsNullOrEmpty(product.UnitMeasurementName))
                                    {
                                        <span class="d-lg-none text-muted small">/ @product.UnitMeasurementName</span>
                                    }
                                </span>
                            </td>
                            <td class="text-muted d-none d-lg-table-cell">
                                @if (product.CategoryId.HasValue)
                                {
                                    @HighlighHelper.Highlight(product.CategoryBreadcrumb, query)
                                }
                            </td>
                            <td class="text-end text-nowrap">
                                <span class="fw-medium">
                                    @product.StockQuantity.DisplayQuantity()
                                </span>
                            </td>
                            <td class="d-none d-md-table-cell text-muted">
                                @product.UnitMeasurementName
                            </td>
                            <td>
                                @foreach (var vendor in product.VendorNames)
                                {
                                    <span class="badge bg-light text-muted fw-normal text-truncate d-inline-block me-2" style="font-size: 0.9rem; max-width: 120px;">
                                        @HighlighHelper.Highlight(vendor, query)
                                    </span>
                                }
                            </td>
                            <td class="text-end pe-3">
                                <a class="btn-table-action" asp-action="Edit" asp-route-id="@product.Id" title="Chỉnh sửa">
                                    <i class="bi bi-pencil"></i>
                                    <span class="visually-hidden"></span>
                                </a>
                                <button type="button" class="btn-table-action danger btnDelete"
                                        data-id="@product.Id" data-name="@product.Name" title="Xóa">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="4">
                            <div class="empty-state">
                                <div class="empty-icon"><i class="bi bi-tags"></i></div>
                                <h5>Chưa có hàng hóa nào</h5>
                                <p>Thêm hàng hóa để bắt đầu quản lý kho và bán hàng.</p>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (Model.Data.Pagination.TotalCount > 0)
    {
        <partial name="_Pager" model="Model.Data.Pagination" />
    }
</div>

@foreach (var item in Model.Data)
{
    <partial name="_DeleteForm" model="@item.Id" />
}

@section Scripts {
    <script type="module" defer>
        import { confirm } from "/modules/modals.js";

        (function () {
        $('.btnDelete').on('click', async function (e) {
        e.preventDefault();
        const name = $(this).data('name');
        $(this).prop('disabled', true);
        const confirmed = await confirm('Xóa hàng hóa', `Bạn muốn xóa hàng hóa <strong>${name}</strong>?`);
        if (!confirmed) {
        $(this).prop('disabled', false); return;
        }
        $(`#deleteForm${$(this).data('id')}`).submit();
        });
        })();
    </script>
}
