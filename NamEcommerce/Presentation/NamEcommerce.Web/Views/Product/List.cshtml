@using System.Text.Encodings.Web
@inject UrlEncoder MyUrlEncoder
@model ProductListModel
@{
    ViewData[ViewConstants.PageTitle] = "Hàng hóa";
    var successMessage = TempData[ViewConstants.ProductSuccessMessage] as string;
    var errorMessage = TempData[ViewConstants.ProductErrorMessage] as string;
    string? query = Model.Keywords;
}

<div class="page-header">
    <div>
        <h1 class="page-header-title">Hàng hóa</h1>
        <p class="page-header-subtitle">Quản lý danh mục sản phẩm và hàng hóa</p>
    </div>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-lg me-1"></i>Thêm mới
    </a>
</div>

@if (!string.IsNullOrEmpty(successMessage))
{
    <div class="alert alert-success alert-dismissible fade show alert-global mb-3" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i>@successMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-warning alert-dismissible fade show alert-global mb-3" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-2"></i>@errorMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="content-card">
    <div class="action-toolbar">
        <div class="search-group">
            <div class="search-input-group input-group">
                <span class="input-group-text"><i class="bi bi-search text-muted"></i></span>
                <partial name="_Search" model="@(new ProductListSearchModel { Keywords = Model.Keywords })" />
            </div>
            @if (!string.IsNullOrEmpty(query))
            {
                <a asp-action="List" class="btn btn-sm btn-outline-secondary">
                    <i class="bi bi-x"></i> Xóa lọc
                </a>
            }
        </div>
    </div>

    <div class="table-responsive">
        <table class="table data-table">
            <thead>
                <tr>
                    <th class="ps-4" style="width: 80px;">Ảnh</th>
                    <th>Tên hàng hóa</th>
                    <th class="d-none d-md-table-cell">Danh mục</th>
                    <th style="width: 100px;"></th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Data.Pagination.TotalCount > 0)
                {
                    @foreach (var item in Model.Data)
                    {
                        <tr>
                            <td class="ps-4">
                                @if (string.IsNullOrEmpty(item.PictureUrl))
                                {
                                    <div class="d-flex align-items-center justify-content-center rounded"
                                         style="width: 44px; height: 44px; background: var(--gray-100);">
                                        <i class="bi bi-image text-muted"></i>
                                    </div>
                                }
                                else
                                {
                                    <a href="@item.PictureUrl" target="_blank" data-lightbox="products">
                                        <img src="@item.PictureUrl" alt="@item.Name"
                                             class="rounded" style="width: 44px; height: 44px; object-fit: cover;" />
                                    </a>
                                }
                            </td>
                            <td class="fw-medium">@HighlighHelper.Highlight(item.Name, query)</td>
                            <td class="d-none d-md-table-cell text-muted small">
                                @if (item.CategoryId.HasValue)
                                {
                                    @item.CategoryBreadcrumb
                                }
                            </td>
                            <td class="text-end pe-3">
                                <a class="btn-table-action me-1" asp-action="Edit" asp-route-id="@item.Id" title="Chỉnh sửa">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <button type="button" class="btn-table-action danger btnDelete"
                                        data-id="@item.Id" data-name="@item.Name" title="Xóa">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="4">
                            <div class="empty-state">
                                <div class="empty-icon"><i class="bi bi-tags"></i></div>
                                <h5>Chưa có hàng hóa nào</h5>
                                <p>Thêm hàng hóa để bắt đầu quản lý kho và bán hàng.</p>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (Model.Data.Pagination.TotalCount > 0)
    {
        <partial name="_Pager" model="Model.Data.Pagination" />
    }
</div>

@foreach (var item in Model.Data)
{
    <partial name="_DeleteForm" model="@item.Id" />
}

@section Scripts {
    <script type="module" defer>
        import { confirm } from "/modules/modals.js";
        (function () {
            $('.btnDelete').on('click', async function (e) {
                e.preventDefault();
                const name = $(this).data('name');
                $(this).prop('disabled', true);
                const confirmed = await confirm('Xóa hàng hóa', `Bạn muốn xóa hàng hóa <strong>${name}</strong>?`);
                if (!confirmed) { $(this).prop('disabled', false); return; }
                $(`#deleteForm${$(this).data('id')}`).submit();
            });
        })();
    </script>
}
