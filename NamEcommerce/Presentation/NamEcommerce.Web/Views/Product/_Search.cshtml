@model ProductListSearchModel

<form method="get" class="d-flex flex-wrap align-items-center gap-2 w-100">
    <div class="search-input-group flex-grow-1" style="min-width: 200px; max-width: 320px;">
        <div class="input-group">
            <span class="input-group-text bg-white border-end-0">
                <i class="bi bi-search text-muted"></i>
            </span>
            <input asp-for="Keywords" class="form-control border-start-0 ps-0" placeholder="Tìm kiếm sản phẩm..." />
        </div>
    </div>
    <button class="btn btn-primary px-3" type="submit">
        <i class="bi bi-search me-1"></i>Lọc
    </button>
    @if (!string.IsNullOrEmpty(Model.Keywords))
    {
        <a asp-action="List" class="btn btn-outline-secondary px-3" title="Bỏ lọc">
            <i class="bi bi-x-lg"></i>
        </a>
    }
</form>