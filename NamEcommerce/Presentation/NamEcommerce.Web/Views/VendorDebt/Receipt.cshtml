@using NamEcommerce.Domain.Shared.Enums.Debts
@using NamEcommerce.Domain.Shared.Enums.Orders
@using NamEcommerce.Web.Contracts.Models.Debts
@using NamEcommerce.Web.Extensions
@model VendorPaymentReceiptModel
@inject InfoOptions Info
@{
    Layout = null;
    var paymentType = (PaymentType)Model.PaymentType;
    var paymentMethod = (PaymentMethod)Model.PaymentMethod;
    var title = paymentType == PaymentType.AdvancePayment ? "Phiếu ứng trước NCC" : "Phiếu chi NCC";
}
<!DOCTYPE html>
<html lang="vi">
<head>
<meta charset="utf-8" />
<title>@title — @Model.PaymentCode</title>
<style>
* { box-sizing: border-box; margin: 0; padding: 0; }
body { font-family: Arial, sans-serif; font-size: 12px; color: #000; background: #eee; }
.page { width: 110mm; padding: 10mm 12mm 12mm; margin: 8mm auto; background: #fff; }
.shop { text-align: center; margin-bottom: 10px; border-bottom: 2px solid #000; padding-bottom: 8px; }
.shop-name { font-size: 14px; font-weight: bold; text-transform: uppercase; letter-spacing: 0.5px; }
.shop-sub { font-size: 10px; color: #555; margin-top: 2px; }
.title { text-align: center; font-size: 15px; font-weight: bold; text-transform: uppercase;
         letter-spacing: 1px; margin: 10px 0 2px; }
.type-badge { text-align: center; margin-bottom: 4px; }
.type-badge span { background: #f5f5f5; border: 1px solid #ddd; font-size: 10px;
                   padding: 2px 8px; border-radius: 99px; color: #555; }
.code-line { text-align: center; font-size: 10.5px; color: #555; margin-bottom: 12px; }
table.info { width: 100%; border-collapse: collapse; margin-bottom: 10px; }
table.info td { padding: 4px 5px; font-size: 11.5px; vertical-align: top; }
table.info td:first-child { color: #555; white-space: nowrap; width: 38%; }
table.info td:last-child { font-weight: bold; }
.divider { border: none; border-top: 1px dashed #ccc; margin: 8px 0; }
.amt-box { border: 2px solid #222; padding: 8px 12px; text-align: center; margin: 12px 0; border-radius: 4px; }
.amt-lbl { font-size: 9.5px; text-transform: uppercase; color: #555; letter-spacing: .5px; }
.amt-val { font-size: 24px; font-weight: bold; margin-top: 3px; }
.sig-row { display: flex; justify-content: space-around; margin-top: 20px; }
.sig-box { text-align: center; width: 44%; font-size: 10.5px; }
.sig-box strong { display: block; font-size: 11px; }
.sig-box em { font-size: 9.5px; color: #666; }
.sig-space { height: 34px; }
@@media print { body { background: #fff; } .page { margin: 0; } }
</style>
</head>
<body onload="window.print()">
<div class="page">

  <div class="shop">
    <div class="shop-name">@Info.Name</div>
    <div class="shop-sub">SĐT: @Info.PhoneNumber</div>
    <div class="shop-sub">Địa chỉ: @Info.Address</div>
  </div>

  <div class="title">@title</div>
  <div class="type-badge">
    <span>@paymentType.GetDisplayText() · @paymentMethod.GetDisplayText()</span>
  </div>
  <div class="code-line">@Model.PaymentCode</div>

  <table class="info">
    <tr>
      <td>Nhà cung cấp</td>
      <td>@Model.VendorName</td>
    </tr>
    <tr>
      <td>Hình thức</td>
      <td>@paymentMethod.GetDisplayText()</td>
    </tr>
    <tr>
      <td>Ngày chi</td>
      <td>@Model.PaidOn.ToString(ViewConstants.DefaultDateTimeFormat)</td>
    </tr>
    @if (!string.IsNullOrEmpty(Model.DebtCode))
    {
    <tr>
      <td>Phiếu công nợ</td>
      <td>@Model.DebtCode</td>
    </tr>
    }
    @if (!string.IsNullOrEmpty(Model.PurchaseOrderCode))
    {
    <tr>
      <td>Đơn nhập</td>
      <td>@Model.PurchaseOrderCode</td>
    </tr>
    }
    @if (!string.IsNullOrEmpty(Model.Note))
    {
    <tr>
      <td>Ghi chú</td>
      <td style="font-weight:normal; font-style:italic;">@Model.Note</td>
    </tr>
    }
  </table>

  <div class="amt-box">
    <div class="amt-lbl">@(paymentType == PaymentType.AdvancePayment ? "Số tiền ứng trước" : "Số tiền chi")</div>
    <div class="amt-val">@Model.Amount.DisplayCurrency()</div>
  </div>

  <div class="sig-row">
    <div class="sig-box">
      <strong>NHÀ CUNG CẤP</strong>
      <em>(Xác nhận đã nhận tiền)</em>
      <div class="sig-space"></div>
    </div>
    <div class="sig-box">
      <strong>NGƯỜI CHI TIỀN</strong>
      <em>(Ký, ghi rõ họ tên)</em>
      <div class="sig-space"></div>
    </div>
  </div>

</div>
</body>
</html>
