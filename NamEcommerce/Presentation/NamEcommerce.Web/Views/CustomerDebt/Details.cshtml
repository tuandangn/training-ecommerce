@using NamEcommerce.Domain.Shared.Enums.Debts
@using NamEcommerce.Domain.Shared.Enums.Orders
@using NamEcommerce.Web.Contracts.Models.Debts
@using NamEcommerce.Web.Extensions
@model CustomerDebtDetailsModel
@{
    ViewData[ViewConstants.PageTitle] = $"Chi tiết công nợ {Model.Code}";
    var debtStatus = (DebtStatus)Model.Status;
}

<div class="page-header">
    <div class="d-flex align-items-center">
        <a asp-action="List" class="btn btn-icon btn-light me-3 shadow-sm border">
            <i class="bi bi-arrow-left"></i>
        </a>
        <div>
            <h1 class="page-header-title">Chi tiết công nợ @Model.Code</h1>
            <div class="d-flex align-items-center gap-2">
                <span class="badge rounded-pill @debtStatus.GetDisplayColor() px-2 py-1 fw-normal">
                    @debtStatus.GetDisplayText()
                </span>
                <span class="text-muted small">• @Model.CreatedOnUtc.ToString(ViewConstants.DefaultDateTimeFormat)</span>
            </div>
        </div>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Print" asp-route-id="@Model.Id" target="_blank" class="btn btn-outline-info shadow-sm border">
            <i class="bi bi-printer me-1"></i> In sao kê
        </a>
        @if (Model.RemainingAmount > 0)
        {
            <button type="button" class="btn btn-primary shadow-sm" data-bs-toggle="modal" data-bs-target="#recordPaymentModal">
                <i class="bi bi-cash-coin me-1"></i> Thu tiền nợ
            </button>
        }
    </div>
</div>

<div class="row g-4 mb-4">
    <div class="col-lg-4">
        <div class="card border-0 shadow-sm rounded-4 h-100 overflow-hidden">
            <div class="card-header bg-white border-bottom py-3 px-4">
                <h6 class="mb-0 fw-bold text-uppercase small text-muted">Thông tin chung</h6>
            </div>
            <div class="card-body p-4">
                <div class="d-flex flex-column gap-3">
                    <div class="info-group">
                        <label class="text-muted small text-uppercase fw-bold d-block mb-1">Khách hàng</label>
                        <div class="fw-bold fs-5">@Model.CustomerName</div>
                    </div>
                    <div class="info-group">
                        <label class="text-muted small text-uppercase fw-bold d-block mb-1">Liên quan đến</label>
                        <div class="d-flex flex-column gap-1">
                            <div>
                                <span class="text-muted small">Đơn hàng:</span>
                                <a asp-controller="Order" asp-action="Details" asp-route-id="@Model.OrderId" class="text-decoration-none fw-medium text-primary ms-1">@Model.OrderCode</a>
                            </div>
                            <div>
                                <span class="text-muted small">Phiếu xuất:</span>
                                <span class="fw-medium text-dark ms-1">@Model.DeliveryNoteCode</span>
                            </div>
                        </div>
                    </div>
                    @if (Model.DueDateUtc.HasValue)
                    {
                        <div class="info-group">
                            <label class="text-muted small text-uppercase fw-bold d-block mb-1">Hạn thanh toán</label>
                            <div class="fw-medium @(Model.DueDateUtc.Value < DateTime.Now ? "text-danger" : "text-dark")">
                                <i class="bi bi-calendar-event me-1"></i>@Model.DueDateUtc.Value.ToString(ViewConstants.DefaultDateFormat)
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm rounded-4 h-100 overflow-hidden" style="background: linear-gradient(135deg, #ffffff 0%, #f9fbfd 100%);">
            <div class="card-body p-4">
                <div class="row g-4 text-center align-items-center h-100">
                    <div class="col-md-4 border-end border-light">
                        <div class="py-2">
                            <div class="text-muted small text-uppercase fw-bold mb-2">Tổng công nợ</div>
                            <div class="fs-4 fw-bold text-dark">@Model.TotalAmount.ToString(ViewConstants.CurrencyDisplayFormat)</div>
                        </div>
                    </div>
                    <div class="col-md-4 border-end border-light">
                        <div class="py-2">
                            <div class="text-muted small text-uppercase fw-bold mb-2">Đã thanh toán</div>
                            <div class="fs-4 fw-bold text-success">@Model.PaidAmount.ToString(ViewConstants.CurrencyDisplayFormat)</div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="py-2">
                            <div class="text-muted small text-uppercase fw-bold mb-2">Còn lại phải thu</div>
                            <div class="fs-2 fw-bold text-danger">@Model.RemainingAmount.ToString(ViewConstants.CurrencyDisplayFormat)</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm rounded-4 overflow-hidden mb-4">
    <div class="card-header bg-white border-bottom py-3 px-4 d-flex justify-content-between align-items-center">
        <h6 class="mb-0 fw-bold text-uppercase small text-muted">Lịch sử thanh toán</h6>
        <span class="badge bg-light text-dark border fw-normal">@Model.Payments.Count bản ghi</span>
    </div>
    <div class="table-responsive">
        <table class="table align-middle mb-0">
            <thead class="bg-light bg-opacity-50">
                <tr>
                    <th class="ps-4 border-0 small text-uppercase text-muted fw-bold">Mã biên lai</th>
                    <th class="border-0 small text-uppercase text-muted fw-bold">Ngày thu</th>
                    <th class="border-0 small text-uppercase text-muted fw-bold">Hình thức</th>
                    <th class="border-0 small text-uppercase text-muted fw-bold">Loại giao dịch</th>
                    <th class="text-end border-0 small text-uppercase text-muted fw-bold">Số tiền</th>
                    <th class="border-0 small text-uppercase text-muted fw-bold" style="width: 200px;">Ghi chú</th>
                    <th class="text-end pe-4 border-0" style="width: 80px;"></th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Payments.Any())
                {
                    @foreach (var payment in Model.Payments)
                    {
                        <tr>
                            <td class="ps-4">
                                <span class="fw-bold text-dark">@payment.Code</span>
                            </td>
                            <td>
                                <span class="text-muted">@payment.PaidOnUtc.ToString(ViewConstants.DefaultDateTimeFormat)</span>
                            </td>
                            <td>
                                @{
                                    var method = (PaymentMethod)payment.PaymentMethod;
                                }
                                <div class="d-flex align-items-center gap-1">
                                    <i class="bi @(method == PaymentMethod.BankTransfer ? "bi-bank" : "bi-cash-stack") text-muted"></i>
                                    <span>@method.ToString()</span>
                                </div>
                            </td>
                            <td>
                                @{
                                    var type = (PaymentType)payment.PaymentType;
                                }
                                <span class="badge bg-@(type == PaymentType.DebtPayment ? "info" : "warning") text-dark fw-normal">
                                    @(type == PaymentType.DebtPayment ? "Trả nợ" : "Tiền cọc")
                                </span>
                            </td>
                            <td class="text-end fw-bold text-success">
                                @payment.Amount.ToString(ViewConstants.CurrencyDisplayFormat)
                            </td>
                            <td>
                                <span class="small text-muted line-clamp-1">@payment.Note</span>
                            </td>
                            <td class="text-end pe-4">
                                @* Link to print receipt *@
                                <a href="#" class="btn btn-xs btn-outline-secondary border-0" title="In biên lai">
                                    <i class="bi bi-printer"></i>
                                </a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="7" class="text-center py-5 text-muted">
                            Chưa có giao dịch thanh toán nào
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Record Payment Modal -->
<div class="modal fade" id="recordPaymentModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4 overflow-hidden">
            <div class="modal-header bg-white border-bottom-0 pt-4 px-4 pb-0">
                <h5 class="modal-title fw-bold">Thu tiền nợ khách hàng</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form id="recordPaymentForm">
                <input type="hidden" name="customerId" value="@Model.CustomerId" />
                <input type="hidden" name="customerDebtId" value="@Model.Id" />
                <input type="hidden" name="orderId" value="@Model.OrderId" />
                <input type="hidden" name="paymentType" value="@((int)PaymentType.DebtPayment)" />

                <div class="modal-body p-4">
                    <div class="alert alert-info border-0 rounded-3 small mb-4">
                        <i class="bi bi-info-circle me-2"></i>Số tiền tối đa có thể thu: <strong class="text-primary">@Model.RemainingAmount.ToString(ViewConstants.CurrencyDisplayFormat)</strong>
                    </div>

                    <div class="row g-3">
                        <div class="col-12">
                            <label class="form-label small fw-bold text-muted text-uppercase mb-2">Số tiền thu <span class="text-danger">*</span></label>
                            <div class="input-group input-group-lg bg-light rounded-3 shadow-none border">
                                <input type="number" class="form-control bg-transparent border-0 fw-bold text-primary" name="amount" id="paymentAmount" value="@Model.RemainingAmount" max="@Model.RemainingAmount" min="1" step="1000" required />
                                <span class="input-group-text bg-transparent border-0 fw-bold text-primary">đ</span>
                            </div>
                        </div>

                        <div class="col-12">
                            <label class="form-label small fw-bold text-muted text-uppercase mb-2">Phương thức </label>
                            <div class="d-flex gap-2">
                                <input type="radio" class="btn-check" name="paymentMethod" id="methodCash" value="@((int)PaymentMethod.Cash)" checked>
                                <label class="btn btn-outline-secondary w-100 py-2 rounded-3" for="methodCash">
                                    <i class="bi bi-cash-stack me-1"></i>Tiền mặt
                                </label>

                                <input type="radio" class="btn-check" name="paymentMethod" id="methodBank" value="@((int)PaymentMethod.BankTransfer)">
                                <label class="btn btn-outline-secondary w-100 py-2 rounded-3" for="methodBank">
                                    <i class="bi bi-bank me-1"></i>Chuyển khoản
                                </label>
                            </div>
                        </div>

                        <div class="col-12">
                            <label class="form-label small fw-bold text-muted text-uppercase mb-2">Ngày thu phí</label>
                            <input type="datetime-local" class="form-control rounded-3" name="paidOnUtc" value="@DateTime.Now.ToString("yyyy-MM-ddTHH:mm")" required />
                        </div>

                        <div class="col-12">
                            <label class="form-label small fw-bold text-muted text-uppercase mb-2">Ghi chú</label>
                            <textarea class="form-control rounded-3" name="note" rows="2" placeholder="VD: Khách trả qua số tài khoản TCB..."></textarea>
                        </div>
                    </div>
                </div>
                <div class="modal-footer bg-light border-top-0 p-4">
                    <button type="button" class="btn btn-light px-4 rounded-3 border" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" id="btnSubmitPayment" class="btn btn-primary px-4 rounded-3 shadow-sm fw-bold">
                        <i class="bi bi-check2-circle me-1"></i>Xác nhận thu tiền
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script type="module" defer>
        import { toast } from "/modules/modals.js";

        (function () {
            const form = document.getElementById('recordPaymentForm');
            const submitBtn = document.getElementById('btnSubmitPayment');

            $(form).on('submit', async function (e) {
                e.preventDefault();

                if (!form.checkValidity()) {
                    form.reportValidity();
                    return;
                }

                submitBtn.disabled = true;
                const originalText = submitBtn.innerHTML;
                submitBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Đang xử lý...';

                try {
                    const formData = $(form).serialize();
                    const response = await $.ajax({
                        url: '@Url.Action("RecordPayment")',
                        type: 'POST',
                        data: formData
                    });

                    if (response.success) {
                        toast('Thành công', response.message, 'success');
                        setTimeout(() => location.reload(), 1500);
                    } else {
                        toast('Lỗi', response.message, 'error');
                        submitBtn.disabled = false;
                        submitBtn.innerHTML = originalText;
                    }
                } catch (err) {
                    toast('Lỗi', 'Có lỗi xảy ra trong quá trình xử lý.', 'error');
                    submitBtn.disabled = false;
                    submitBtn.innerHTML = originalText;
                }
            });
        })();
    </script>
}
