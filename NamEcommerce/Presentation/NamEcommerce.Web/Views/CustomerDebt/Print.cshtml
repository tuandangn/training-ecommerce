@using NamEcommerce.Domain.Shared.Enums.Debts
@using NamEcommerce.Domain.Shared.Enums.Orders
@using NamEcommerce.Web.Contracts.Models.Debts
@model CustomerDebtDetailsModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Sao kê công nợ - @Model.Code</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            font-size: 14px;
            color: #000;
            margin: 0;
            padding: 0;
            background-color: #f0f0f0;
        }
        .print-page {
            width: 210mm;
            min-height: 297mm;
            padding: 20mm;
            margin: 10mm auto;
            border: 1px #D3D3D3 solid;
            background: white;
            box-shadow: 0 0 5px rgba(0, 0, 0, 0.1);
        }
        .header {
            text-align: center;
            margin-bottom: 30px;
        }
        .header h1 {
            margin: 0;
            font-size: 26px;
            text-transform: uppercase;
        }
        .header p {
            margin: 5px 0 0 0;
        }
        .info-section {
            display: flex;
            justify-content: space-between;
            margin-bottom: 30px;
            border-bottom: 2px solid #EEE;
            padding-bottom: 15px;
        }
        .info-box h3 {
            margin: 0 0 10px 0;
            font-size: 18px;
            color: #333;
        }
        .info-box p {
            margin: 3px 0;
        }
        .summary-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 20px;
            margin-bottom: 30px;
        }
        .summary-item {
            background: #f8f9fa;
            padding: 15px;
            border-radius: 8px;
            text-align: center;
            border: 1px solid #EEE;
        }
        .summary-label {
            display: block;
            font-size: 12px;
            text-transform: uppercase;
            color: #666;
            margin-bottom: 5px;
            font-weight: bold;
        }
        .summary-value {
            font-size: 20px;
            font-weight: bold;
        }
        .payment-table {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 30px;
        }
        .payment-table th, .payment-table td {
            border: 1px solid #DDD;
            padding: 10px;
            text-align: left;
        }
        .payment-table th {
            background-color: #F2F2F2;
            font-size: 12px;
            text-transform: uppercase;
        }
        .text-right { text-align: right !important; }
        .footer {
            margin-top: 50px;
            display: flex;
            justify-content: space-around;
        }
        .sig-box {
            text-align: center;
            width: 200px;
        }
        @@media print {
            body { background: white; margin: 0; padding: 0; }
            .print-page { margin: 0; border: none; box-shadow: none; width: 100%; }
        }
    </style>
</head>
<body onload="window.print()">
    <div class="print-page">
        <div style="display: flex; justify-content: space-between; margin-bottom: 20px;">
            <div>
                <strong>CỬA HÀNG VLXD TUẤN KHÔI</strong><br />
                Số 123 Đường ABCD, Quận XYZ, TP.HCM<br />
                Hotline: 0909.123.456
            </div>
            <div class="text-right">
                Ngày in: @DateTime.Now.ToString("dd/MM/yyyy HH:mm")
            </div>
        </div>

        <div class="header">
            <h1>SAO KÊ CÔNG NỢ</h1>
            <p>Mã quản lý: @Model.Code</p>
        </div>

        <div class="info-section">
            <div class="info-box">
                <h3>Khách hàng</h3>
                <p><strong>@Model.CustomerName</strong></p>
                <p>Chứng từ gốc: @Model.DeliveryNoteCode / Đơn: @Model.OrderCode</p>
                <p>Ngày ghi nhận: @Model.CreatedOnUtc.ToString("dd/MM/yyyy")</p>
            </div>
            <div class="info-box text-right">
                <h3>Trạng thái</h3>
                <p><strong>@(((DebtStatus)Model.Status).ToString())</strong></p>
                @if (Model.DueDateUtc.HasValue)
                {
                    <p>Hạn thanh toán: @Model.DueDateUtc.Value.ToString("dd/MM/yyyy")</p>
                }
            </div>
        </div>

        <div class="summary-grid">
            <div class="summary-item">
                <span class="summary-label">Tổng nợ phát sinh</span>
                <div class="summary-value">@Model.TotalAmount.ToString("N0") đ</div>
            </div>
            <div class="summary-item">
                <span class="summary-label">Đã thanh toán</span>
                <div class="summary-value" style="color: green;">@Model.PaidAmount.ToString("N0") đ</div>
            </div>
            <div class="summary-item" style="background: #FFF5F5; border-color: #FEB2B2;">
                <span class="summary-label" style="color: #C53030;">Còn lại phải thu</span>
                <div class="summary-value" style="color: #C53030;">@Model.RemainingAmount.ToString("N0") đ</div>
            </div>
        </div>

        <h3 style="border-left: 4px solid #3182CE; padding-left: 10px; margin-bottom: 15px;">Lịch sử thanh toán</h3>
        <table class="payment-table">
            <thead>
                <tr>
                    <th>STT</th>
                    <th>Ngày thu</th>
                    <th>Mã biên lai</th>
                    <th>Hình thức</th>
                    <th>Nội dung</th>
                    <th class="text-right">Số tiền</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Payments.Any())
                {
                    var i = 1;
                    foreach (var payment in Model.Payments)
                    {
                        <tr>
                            <td style="text-align: center;">@(i++)</td>
                            <td>@payment.PaidOnUtc.ToString("dd/MM/yyyy HH:mm")</td>
                            <td><strong>@payment.Code</strong></td>
                            <td>@(((PaymentMethod)payment.PaymentMethod).ToString())</td>
                            <td style="font-size: 12px;">@payment.Note</td>
                            <td class="text-right"><strong>@payment.Amount.ToString("N0")</strong></td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6" style="text-align: center; color: #999; padding: 20px;">Chưa có giao dịch thanh toán</td>
                    </tr>
                }
            </tbody>
        </table>

        <div class="footer">
            <div class="sig-box">
                <strong>KHÁCH HÀNG</strong><br />
                <span style="font-size: 11px; font-style: italic;">(Ký và ghi rõ họ tên)</span>
            </div>
            <div class="sig-box">
                <strong>NGƯỜI LẬP BẢNG</strong><br />
                <span style="font-size: 11px; font-style: italic;">(Ký và ghi rõ họ tên)</span>
            </div>
        </div>
    </div>
</body>
</html>
