@using NamEcommerce.Domain.Shared.Enums.Debts
@using NamEcommerce.Domain.Shared.Enums.Orders
@using NamEcommerce.Web.Contracts.Models.Debts
@using NamEcommerce.Web.Extensions
@model CustomerDebtDetailsModel
@inject InfoOptions Info
@{
    Layout = null;
    var allPayments = Model.Debts.SelectMany(d => d.Payments).OrderBy(p => p.PaidOnUtc).ToList();
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <title>Sao kê — @Model.CustomerName</title>
    <style>
* { box-sizing: border-box; margin: 0; padding: 0; }
body { font-family: Arial, sans-serif; font-size: 12px; color: #000; background: #eee; }
.page { width: 210mm; min-height: 297mm; padding: 15mm 18mm; margin: 8mm auto; background: #fff; }
/* Header */
.hdr { display: flex; justify-content: space-between; align-items: flex-start; border-bottom: 2px solid #000; padding-bottom: 8px; margin-bottom: 10px; }
.shop-name { font-size: 14px; font-weight: bold; }
.shop-sub { font-size: 11px; color: #444; margin-top: 3px; }
.doc-title { text-align: right; }
.doc-title h1 { font-size: 18px; text-transform: uppercase; letter-spacing: 1px; }
.doc-title p { font-size: 11px; color: #555; margin-top: 3px; }
/* Summary row */
.summary { display: flex; flex-direction: column; margin-bottom: 12px; }
.summary-row{ display: flex; align-items:center; justify-content: space-between; margin: 5px 0; padding: 0 5px; border-bottom: dashed 1px #ccc; }
.summary-row .lbl{ text-transform: uppercase; font-weight: bold; }
.val-danger { color: #c00; }
.val-green { color: #007a00; }
.val-blue { color: #0055aa; }
/* Section title */
.sec { font-size: 11px; font-weight: bold; text-transform: uppercase; letter-spacing: .5px;
       border-left: 3px solid #333; padding-left: 6px; margin: 12px 0 6px; }
/* Tables */
table { width: 100%; border-collapse: collapse; font-size: 11.5px; }
th { background: #f0f0f0; border: 1px solid #ccc; padding: 5px 7px; font-size: 10.5px; text-transform: uppercase; text-align: left; }
td { border: 1px solid #ccc; padding: 5px 7px; vertical-align: top; }
.r { text-align: right; }
.c { text-align: center; }
.bold { font-weight: bold; }
.red { color: #c00; }
.green { color: #007a00; }
/* Signature */
.sig-row { display: flex; justify-content: space-around; margin-top: 30px; }
.sig-box { text-align: center; width: 140px; font-size: 11px; }
.sig-box strong { display: block; margin-bottom: 3px; }
.sig-box em { font-size: 10px; color: #555; }
.sig-space { height: 36px; }
@@media print {
  body { background: #fff; }
  .page { margin: 0; padding: 12mm 15mm; }
}
.customer-sec{ text-align:center;margin: 15px 0 5px;}
.customer-sec .sub{ font-size: 14px; color: gray;}
.customer-sec .title{ font-size: 17px; font-weight: bold;}
</style>
</head>
<body onload="window.print()">
    <div class="page">
        <!-- Header -->
        <div class="hdr">
            <div>
                <div class="shop-name">@Info.Name</div>
                @if (!string.IsNullOrEmpty(Info.PhoneNumber))
                {
                    <div class="shop-sub">SĐT: @Info.PhoneNumber</div>
                }
                @if (!string.IsNullOrEmpty(Info.Address))
                {
                    <div class="shop-sub">Địa chỉ: @Info.Address</div>
                }
            </div>
            <div class="doc-title">
                <h1>Sao kê công nợ</h1>
                <p>Ngày @DateTime.Now.ToString("dd/MM/yyyy HH:mm")</p>
            </div>
        </div>
        <div class="customer-sec">
            <div class="sub">Khách hàng</div>
            <div class="title">
                @Model.CustomerName
            </div>
        </div>
        <!-- Summary -->
        <div class="summary">
            <div class="summary-row">
                <div class="lbl">Tổng nợ phát sinh</div>
                <div class="val val-danger bold">@Model.TotalDebtAmount.ToString("N0") đ</div>
            </div>
            <div class="summary-row">
                <div class="lbl">Đã thanh toán</div>
                <div class="val val-green bold">@Model.TotalPaidAmount.ToString("N0") đ</div>
            </div>
            <div class="summary-row">
                <div class="lbl">Còn phải thu</div>
                <div class="val bold">@Model.TotalRemainingAmount.ToString("N0") đ</div>
            </div>
            @if (Model.DepositBalance > 0)
            {
                <div class="summary-row">
                    <div class="lbl">Tiền cọc / dư</div>
                    <div class="val val-blue bold">@Model.DepositBalance.ToString("N0") đ</div>
                </div>
            }
        </div>

        <!-- Debts table -->
        <div class="sec">Danh sách công nợ</div>
        <table>
            <thead>
                <tr>
                    <th class="c" style="width:32px">STT</th>
                    <th class="c">Ngày tạo</th>
                    <th class="r">Số tiền</th>
                </tr>
            </thead>
            <tbody>
                @{
                    var i = 1;
                }
                @foreach (var d in Model.Debts)
                {
                    var st = (DebtStatus)d.Status;
                    <tr>
                        <td class="c">@(i++)</td>
                        <td class="c">@d.CreatedOnUtc.ToString("dd/MM/yy")</td>
                        <td class="r">@d.TotalAmount.ToString("N0")</td>
                    </tr>
                }
            </tbody>
            <tfoot>
                <tr style="background:#f8f8f8; font-weight:bold;">
                    <td></td>
                    <td class="c">Tổng cộng</td>
                    <td class="r">@Model.TotalDebtAmount.ToString("N0")</td>
                </tr>
            </tfoot>
        </table>

        <!-- Payment history -->
        @if (allPayments.Any())
        {
            <div class="sec">Lịch sử thanh toán</div>
            <table>
                <thead>
                    <tr>
                        <th class="c" style="width:32px">STT</th>
                        <th class="c">Ngày thu</th>
                        <th class="r">Số tiền (đ)</th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        var j = 1;
                    }
                    @foreach (var p in allPayments)
                    {
                        <tr>
                            <td class="c">@(j++)</td>
                            <td class="c">@p.PaidOnUtc.ToString("dd/MM/yy HH:mm")</td>
                            <td class="r">@p.Amount.ToString("N0")</td>
                        </tr>
                    }
                </tbody>
                <tfoot>
                    <tr style="background:#f8f8f8; font-weight:bold;">
                        <td></td>
                        <td class="c">Tổng đã thu</td>
                        <td class="r">@allPayments.Sum(p => p.Amount).ToString("N0")</td>
                    </tr>
                </tfoot>
            </table>
        }

        <!-- Signatures -->
        <div class="sig-row">
            <div class="sig-box">
                <strong>KHÁCH HÀNG</strong>
                <em>(Ký, ghi rõ họ tên)</em>
                <div class="sig-space"></div>
            </div>
            <div class="sig-box">
                <strong>NGƯỜI LẬP</strong>
                <em>(Ký, ghi rõ họ tên)</em>
                <div class="sig-space"></div>
            </div>
        </div>

    </div>
</body>
</html>
