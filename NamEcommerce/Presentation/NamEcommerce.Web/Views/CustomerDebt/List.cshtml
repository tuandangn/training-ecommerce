@using NamEcommerce.Web.Contracts.Models.Debts
@using NamEcommerce.Web.Models.CustomerDebts
@model CustomerDebtListModel
@{
    ViewData[ViewConstants.PageTitle] = "Công nợ khách hàng";
    var query = Model.Keywords;
}

<div class="page-header">
    <div>
        <h1 class="page-header-title">Công nợ khách hàng</h1>
        <p class="page-header-subtitle">Danh sách khách hàng còn nợ — nhấn vào tên để xem chi tiết từng khoản</p>
    </div>
</div>
<div class="content-card">
    <div class="action-toolbar">
        <partial name="_Search" model="@(new CustomerDebtListSearchModel { Keywords = query })" />
    </div>
    <div class="table-responsive">
        <table class="table data-table align-middle">
            <thead>
                <tr>
                    <th class="ps-4">Khách hàng</th>
                    <th class="text-center">Số phiếu nợ</th>
                    <th class="text-end">Tổng nợ phát sinh</th>
                    <th class="text-end">Đã thanh toán</th>
                    <th class="text-end">Còn phải thu</th>
                    <th class="text-end">Tiền cọc / dư</th>
                    <th style="width: 80px;"></th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Data?.Pagination.TotalCount > 0)
                {
                    @foreach (var item in Model.Data)
                    {
                        <tr>
                            <td class="ps-4">
                                <a asp-action="Details" asp-route-id="@item.CustomerId" class="fw-medium text-decoration-none">
                                    <i class="bi bi-person me-1"></i>
                                    @HighlighHelper.Highlight(item.CustomerName, Model.Keywords)
                                </a>
                                @if (!string.IsNullOrEmpty(item.CustomerPhone))
                                {
                                    <div>
                                        <a href="tel:@item.CustomerPhone" class="text-muted small text-decoration-none">
                                            <i class="bi bi-telephone me-1"></i> @HighlighHelper.Highlight(item.CustomerPhone, Model.Keywords)
                                        </a>
                                    </div>
                                }
                            </td>
                            <td class="text-center">
                                <span class="badge bg-light text-dark border fw-normal">@item.DebtCount phiếu</span>
                            </td>
                            <td class="text-end fw-medium text-dark">
                                @item.TotalDebtAmount.ToString(ViewConstants.CurrencyDisplayFormat)
                            </td>
                            <td class="text-end text-success fw-medium">
                                @item.TotalPaidAmount.ToString(ViewConstants.CurrencyDisplayFormat)
                            </td>
                            <td class="text-end fw-bold @(item.TotalRemainingAmount > 0 ? "text-danger" : "text-success")">
                                @item.TotalRemainingAmount.ToString(ViewConstants.CurrencyDisplayFormat)
                            </td>
                            <td class="text-end">
                                @if (item.DepositBalance > 0)
                                {
                                    <span class="badge bg-info-subtle text-info border border-info-subtle fw-normal">
                                        @item.DepositBalance.ToString(ViewConstants.CurrencyDisplayFormat)
                                    </span>
                                }
                                else
                                {
                                    <span class="text-muted small">—</span>
                                }
                            </td>
                            <td class="text-end pe-3">
                                <a class="btn-table-action" asp-action="Details" asp-route-customerId="@item.CustomerId" title="Xem chi tiết">
                                    <i class="bi bi-chevron-right"></i>
                                    <span class="visually-hidden">Chi tiết</span>
                                </a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="7">
                            <div class="empty-state py-5">
                                <div class="empty-icon"><i class="bi bi-wallet2"></i></div>
                                <h5>Không có công nợ nào</h5>
                                <p>Các khoản nợ sẽ được tạo tự động khi phiếu xuất kho được xác nhận giao hàng.</p>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (Model.Data?.Pagination.TotalCount > 0)
    {
        <partial name="_Pager" model="Model.Data.Pagination" />
    }
</div>
